                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="senātum: senate; singular masculine accusative from senātus, senātūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sequentia: following; plural neuter nominative present participle from sequor, sequī, sēcūtus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sī: if"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sibimet: to himself; singular dative of sē with +met intensifier"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Sīfrīdum: Sifrīdus, king of the Danes"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simul: together with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simulāta: feigned, having been simulated; singular feminine nominative perfect passive participle from simulō, simulāre, simulāvī, simulātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="statūta: statutes, laws; plural neuter accusative from statūtum, statūtī"/>
                <para PARENT="Vocab"/>
