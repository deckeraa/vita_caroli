        <PAGEOBJECT XPOS="136.0008" YPOS="2552.0112" OwnPage="5" ItemID="1076728298" PTYPE="4" WIDTH="522" HEIGHT="604.28162420382" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 604.282 L0 604.282 L0 0 Z" copath="M0 0 L522 0 L522 604.282 L0 604.282 L0 0 Z" gXpos="136.0008" gYpos="2552.0112" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <para PARENT="Chapter Heading"/>
                <ITEXT CH="Versiō Simplicissima"/>
                <para PARENT="Chapter Heading"/>
                <para PARENT="Chapter Heading"/>
                <tab/>
                <ITEXT CH="Francī vīvēbant in Galliā. Erant duo rēgēs Francōrum: Carolus et Carolomannus, frāter eius. In annō 771, Carolomannus mortuus"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" est. Posteā Carolus erat rēx omnium Francōrum. Carolus iit ad vīllam, quae Carbōnāta vocātur. Et illīc Carolus suscēpit omnēs procerēs Carolomannī. Omnēs procerēs sē subdidērunt Carolō."/>
                <para PARENT="Latin"/>
                <tab/>
                <ITEXT CH="Sed uxor Carolomannī, fīliī Carolomannī, et paucī aliī fūgērunt ad Ītaliam. Tunc vīvēbant sub mūnīmine rēgis Dēsīderiī."/>
                <para PARENT="Latin"/>
                <tab/>
                <ITEXT CH="Rēx Carolus celebrāvit Nātālem Dominī et Paschālia Fēsta in Attiniācō. Pāpa Paulus mortuus"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" est, et Adriānus suscēpit pontificātum."/>
                <para PARENT="Latin"/>
                <tab/>
                <ITEXT CH="Carolus collēgit procerēs ad concilium generāle in Wormaciā. Carolus dīxit: &quot;Volō pugnāre contrā Saxonēs in bellō.&quot; Cūr? Quia Saxonēs vīvēbant prope Francōs, et saepe invāsērunt fīnēs Francōrum."/>
                <para PARENT="Latin"/>
                <tab/>
                <ITEXT CH="Erant caedēs, incendia, et praedae prope fīnēs. Quoque, nātūra Saxonum erat ferōx et Saxonēs colēbant nōn Chrīstum sed daemōnēs."/>
                <para PARENT="Latin"/>
                <tab/>
                <ITEXT CH="Saxonēs nōn habēbant ūnum rēgem, sed habēbant multōs ducēs et multōs pāgōs. Ergō Saxonēs nōn potuērunt pugnāre pariter contrā Francōs."/>
                <para PARENT="Latin"/>
                <tab/>
                <ITEXT CH="Erant trēs partēs Saxonum: Westfalos in occiduā, Ostvalos in oriente, et Angariī inter Westfalos et Ostvalos."/>
                <para PARENT="Latin"/>
            </StoryText>
            <PageItemAttributes>
