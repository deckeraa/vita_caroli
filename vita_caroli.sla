                <para PARENT="Vocab"/>
                <ITEXT CH="pariter: together"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="penetrāvit: he entered, he penetrated; 3rd person singular perfect active from penetrō, penetrāre, penetrāvī, penetrātus"/>
                <para PARENT="Vocab"/>
