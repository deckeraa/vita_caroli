                <para PARENT="Vocab"/>
                <ITEXT CH="ūsus: ūsus erat = had experienced; singular masculine nominative perfect participle from ūtor, ūtī, ūsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ut: so that"/>
                <para PARENT="Vocab"/>
