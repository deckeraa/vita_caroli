                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēficerent: they defected; 3rd person plural imperfect subjunctive from dēficiō, dēficere, dēfēcī, dēfectus"/>
                <para PARENT="Vocab"/>
