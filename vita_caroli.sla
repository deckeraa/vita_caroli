        <PAGEOBJECT XPOS="136.0008" YPOS="8912.61906496815" OwnPage="19" ItemID="1107046410" PTYPE="4" WIDTH="522" HEIGHT="98.5987261146502" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 98.5987 L0 98.5987 L0 0 Z" copath="M0 0 L522 0 L522 98.5987 L0 98.5987 L0 0 Z" gXpos="136.0008" gYpos="8912.61906496815" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="So that rebellion might not occur."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="9208.0368" OwnPage="21" ItemID="1107831882" PTYPE="4" WIDTH="522" HEIGHT="324.607942675161" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 324.608 L0 324.608 L0 0 Z" copath="M0 0 L522 0 L522 324.608 L0 324.608 L0 0 Z" gXpos="136.0008" gYpos="9208.0368" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Annō 779"/>
                <para PARENT="Latin"/>
                <tab/>
                <ITEXT CH="Dux Spōlētānus, nōmine Hildibrandus, iit ad Carolum et dedit Carolō multa dōna."/>
                <para PARENT="Latin"/>
                <tab/>
                <ITEXT CH="Carolus iterum pugnābat contrā Saxonēs. Saxonēs pugnābant prope Rhēnum, sed nōn potuērunt vincere exercitum Carolī."/>
                <para PARENT="Latin"/>
                <para PARENT="Latin"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Annō 780"/>
                <para PARENT="Latin"/>
                <tab/>
                <ITEXT CH="Carolus vēnit ad flūmen Ovaccrum, et ibi invēnit magnam turbam Saxonum quī voluērunt crēdere Chrīstō. Et multī hominēs Saxonum suscēpērunt baptismam."/>
                <para PARENT="Latin"/>
                <tab/>
                <ITEXT CH="Posteā, Carolus iit ad Rōmam et ōrāvit. Pervēnit ad Ticinēnsem, et ibi celebrāvit Nātālem Dominī."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="9208.0368" OwnPage="22" ItemID="1112314762" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="9208.0368" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="annō: year; singular masculine ablative from annus, annī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolī: of Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty (genitive case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolō: to Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty (dative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolum: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty (accusative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolus: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty (nominative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="celebrāvit: he celebrated; 3rd person singular perfect active from celebrō, celebrāre, celebrāvī, celebrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Chrīstō: Christ"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="contrā: against, away from, facing"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="crēdere: to believe; present active infinitive from crēdō, crēdere, crēdidī, crēditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dedit: he gave; 3rd person singular perfect active from dō, dare, dedī, datus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Dominī: of the Lord; singular masculine genitive from dominus, dominī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dōna: gifts; plural neuter accusative from dōnum, dōnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dux: leader; singular masculine nominative from dux, ducis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="exercitum: army; singular masculine accusative from exercitus, exercitūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="flūmen: river; singular neuter accusative from flūmen, flūminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Hildibrandus: Hildeprand, Duke of Spoleto from 774 to 789"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hominēs: persons; plural masculine nominative from homō, hominis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ibī: there, then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="invēnit: he found; 3rd person singular perfect active from invenio, invenire, inveni, inventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iterum: again"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iit: he went; 3rd person singular perfect active from eō, īre, iī, itus (irregular)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="māgnam: large; singular feminine accusative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="multa: many; plural neuter accusative from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="multī: many; plural masculine nominative from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Nātālem: Nātālem Dominī = Christmas; singular common accusative from natalis, natalis, natale"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōmine: name; singular neuter ablative from nōmen, nōminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ōrāvit: he prayed; 3rd person singular perfect active from ōrō, ōrāre, ōrāvī, ōrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ovaccrum: probably the Oker River, a tributary of the River Aller, in Lower Saxony"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pervēnit: he arrived; 3rd person singular perfect active from perveniō, pervenīre, pervēnī, perventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="posteā: thereafter, later"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="potuērunt: they were able to; 3rd person plural perfect active from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prope: near, close"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pugnābant: they were fighting; 3rd person plural imperfect active from pugnō, pugnāre, pugnāvī, pugnātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pugnābat: he was fighting; 3rd person singular imperfect active from pugnō, pugnāre, pugnāvī, pugnātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Rhēnum: the Rhine; singular masculine accusative from Rhēnus, Rhēnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Rōmam: Rome; singular feminine accusative from Rōma, Rōmae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxonēs: the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnum: of the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Spōlētānus: of the Duchy of Spoleto, located in the region of Umbria, Italy"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suscēpērunt: they undertook; 3rd person plural perfect active from suscipiō, suscipere, suscēpī, susceptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ticinēnsem: Ticino, one of the cantons (regions) of Switzerland"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="turbam: crowd; singular feminine accusative from turba, turbae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēnit: he came; 3rd person singular perfect active from veniō, venīre, vēnī, ventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vincere: to conquer; present active infinitive from vincō, vincere, vīcī, victus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="voluērunt: they wanted; 3rd person plural perfect active from volō, velle, voluī, -"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
