                <ITEXT CH="ruptūrōs: to be breaking, destroying; plural masculine accusative future participle from rumpō, rumpere, rūpī, ruptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rūrsus: backwards, on the flipside"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxonēs: the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sē: himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēcum: with oneself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="semper: always"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sollempnia: solemnities, sacred rites; plural neuter accusative from sollempnis, sollempne, sollempnior -or -us, sollempnissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suīs: their; plural dative of suus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suspectōs: having been suspected; plural masculine accusative from suspectus, suspecta -um, suspectior -or -us, suspectissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tempore: time, period; singular neuter ablative from tempus, temporis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tenenda: holding; singular feminine nominative future passive participle from teneō, tenēre, tenuī, tentus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trānsīvisset: it having had passed; 3rd person singular pluperfect active subjunctive from trānseō, trānsīre, trānsivi(iī), trānsitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tum: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="valērent: they were able; 3rd person plural imperfect active subjunctive from valeo, valere, valui, valitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="variīs: various, diverse; plural ablative from varius, varia, varium"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="velle: to want; 2nd person singular present active imperative from vello, vellere, velli, vulsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēris: spring; singular neuter genitive from vēr, vēris"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="30840.12" OwnPage="73" ItemID="1031690394" PTYPE="4" WIDTH="522" HEIGHT="232.480509554134" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 232.481 L0 232.481 L0 0 Z" copath="M0 0 L522 0 L522 232.481 L0 232.481 L0 0 Z" gXpos="136.0008" gYpos="30840.12" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Tantō conciliō locus est ēlēctus"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" agendō,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quem Pāthalbrunnon"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" vocitant, quō nōn habet ipsa"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Gēns alium nātūrālī plūs nōbilitāte"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Īnsignem, quī praecipuae redimītus abundat"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Fontibus et nitidīs et plūribus, et trahit inde"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Barbaricae nōmen linguae sermōne vetustum."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tunc ibi vīlla fuit tantum, nunc pontificālis"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ecclesiae"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" cōnstrūcta nitet clārissima sēdēs"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH="."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="31072.6005095541" OwnPage="73" ItemID="1032039546" PTYPE="4" WIDTH="522" HEIGHT="182.522292993675" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 182.522 L0 182.522 L0 0 Z" copath="M0 0 L522 0 L522 182.522 L0 182.522 L0 0 Z" gXpos="136.0008" gYpos="31072.6005095541" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="A place was chosen for conducting such a council."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Which they call Pathalbrunnon, in which the people themselves have another remarkable (place) of greater natural nobility (than other places in that area), which having been especially crowned abounds with springs, shimmering and plentiful."/>
                <ITEXT CH=" Pathalbrunnon is Aachen, a city in modern-day North Rhine-Westphalia. It is known for having many hot springs. The name Pathalbrunnon, which the narrator relates is from the barbaric (German) tongue, appears to come from "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="athal"/>
                <ITEXT CH=", meaning noble, and "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="brunno"/>
                <ITEXT CH=", meaning well."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH="The Aachen Cathedral was constructed between 796-798 AD. At the time of its completion it was the largest cathedral north of the Alps."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH="Normally spelled "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Ecclēsiae"/>
                <ITEXT CH=", but the "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="e"/>
                <ITEXT CH=" must be short to fit the meter. If poetic license was not taken, then that word could never be used, since long-long-short-long can never fit in dactylic hexameter."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Now a pontifical seat (a cathedral) of the church, having been constructed, shines brightly (meaning it is a renowned building)."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="30840.12" OwnPage="74" ItemID="1034730314" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="30840.12" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="abundat: it abounds; 3rd person singular present active from abundō, abundāre, abundāvī, abundātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agendō: conducting, doing; singular masculine ablative gerund from agō, agere, ēgī, āctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="alium: other; singular masculine accusative from alius, alia, aliud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="barbaricae: barbaric; singular feminine genitive from barbaricus, barbarica, barbaricum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="clārissima: very famous; singular feminine nominative from clārus, clāra -um, clārior -or -us, clārissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="conciliō: council; singular neuter ablative from cōnsilium, cōnsiliī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnstrūcta: having been constructed; singular feminine nominative perfect passive participle from cōnstruō, cōnstruere, cōnstrūxī, cōnstrūctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ecclēsiae: church; singular feminine genitive from ecclēsia, ecclēsiae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ēlēctus: ēlēctus est = it was chosen; singular masculine nominative perfect passive participle from ēligō, ēligere, ēlēgī, ēlēctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="est: he is; 3rd person singular present active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fontibus: fountains; plural masculine ablative from fōns, fontis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fuit: he was; 3rd person singular perfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gēns: people, clan, nation; singular feminine nominative from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="habet: he has; 3rd person singular present active from habeō, habēre, habuī, habitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ibi: there, then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="inde: from there, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnsignem: distinguished; singular common accusative from īnsignis, īnsignis, īnsigne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipsa: itself; singular feminine nominative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="linguae: language; singular feminine genitive from lingua, linguae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="locus: place; singular masculine nominative from locus, locī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nātūrālī: natural; singular ablative from nātūrālis, nātūrālis, nātūrāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nitet: it shines, glitters, thrives; 3rd person singular present active from niteō, nitēre, nituī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nitidīs: shining, bright; plural ablative from nitidus, nitida, nitidum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōbilitāte: fame, nobility; singular feminine ablative from nōbilitās, nōbilitātis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōmen: name; singular neuter accusative from nōmen, nōminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nunc: now"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plūribus: many; plural ablative from plus, (gen.), pluris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plūs: more, from mūltus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pontificālis: pontifical, relating to the Pope; singular common nominative from pontificalis, pontificalis, pontificale"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praecipuae: particular, special; singular feminine genitive from praecipuus, praecipua, praecipuum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quem: which, singular masculine accusative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quō: in which; singular ablative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="redimītus: having been crowned; singular masculine nominative perfect passive participle from redimiō, redimīre, redimiī, redimītum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēdēs: seat; singular feminine nominative from sēdēs, sēdis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sermōne: speech; singular masculine ablative from sermō, sermōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tantō: such, so much, so great; singular masculine ablative from tantus, tanta, tantum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tantum: only; singular neuter nominative from tantus, tanta, tantum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trahit: it draws; 3rd person singular present active from trahō, trahere, trāxī, tractus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tunc: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Pāthalbrunnon: Aachen, a city in modern-day North Rhine-Westphalia"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vetustum: ancient; singular neuter nominative from vetustus, vetusta, vetustum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vīlla: farm, villa; singular feminine nominative from vīlla, vīllae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vocitant: they call; 3rd person plural present active from vocitō, vocitāre, vocitāvī, vocitātus"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="31672.1232" OwnPage="75" ItemID="1034933754" PTYPE="4" WIDTH="522" HEIGHT="470.846936305727" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 470.847 L0 470.847 L0 0 Z" copath="M0 0 L522 0 L522 470.847 L0 470.847 L0 0 Z" gXpos="136.0008" gYpos="31672.1232" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Quō Carolus veniēns, collēctōs repperit omnēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Paene ducēs, populumque simul, tōtumque senātum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Saxonum, nisi quod quīdam Widokindus"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" abinde"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Aufūgit, rēgem veritus; nam cōnscius īdem"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Audācis sibimet factī multīque reātūs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sīfrīdum petiit Dānōrum scēptra regentem."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Porro ducēs illīc aliī cum plēbe gregātī"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Suppliciter cūnctī veniam pācemque petentēs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Pāruerant rēgī sub tālī conditiōne,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ut cūnctā scelerum dīmissā mōle"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" priōrum,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sī post audērent eius violāre statūta,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Lībertāte simul prīscā patriāque carērent."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quōrum"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" tum Chrīstō sē crēdere velle professa"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Magna salūtiferum suscēpit turba lavācrum."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sed simulāta"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" fidēs versūtō prōdiit ōre,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quod nōtum multīs fēcēre sequentia gesta."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="32148.9701363057" OwnPage="75" ItemID="1035543658" PTYPE="4" WIDTH="522" HEIGHT="152.713375796178" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 152.713 L0 152.713 L0 0 Z" copath="M0 0 L522 0 L522 152.713 L0 152.713 L0 0 Z" gXpos="136.0008" gYpos="32148.9701363057" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Except that a certain Widokindus fled from there, having feared the king."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="For the same one (Widokindus) conscious of his audacious deed and many criminal charges, sought (refuge in the court of) Sifridus, reigning over the Danes. sibimet"/>
                <ITEXT CH=" functions as an intensifier, emphasizing that the audacious deed was his own. We are not told what the deed was."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="That all having been freed from the weight of their prior crimes."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Of those, then, a great crowd, having professed themselves to want to believe in Christ, undertook the health-bringing bath (i.e. baptism)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="But a feigned faith sprung forth from crafty mouth, which (their) subsequent acts made known to many."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="31672.1232" OwnPage="76" ItemID="1037553930" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="31672.1232" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="abinde: from that place, thence, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aliī: others; plural nominative from alius, alia, aliud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="audācis: bold, daring; singular genitive from audāx, audācis (gen.), audācior -or -us, audācissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="audērent: they had dared; 3rd person plural imperfect active subjunctive from audeō, audēre, ausus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aufūgit: he fled; 3rd person singular perfect active from aufugio, aufugere, aufugi, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="carērent: they would lack; 3rd person plural imperfect active subjunctive from careō, carēre, caruī, caritus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolus: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Chrīstō: Christ"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="collēctōs: having been collected, assembled; plural masculine accusative perfect passive participle from colligō, colligere, collēgī, collēctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="condītiōne: condition; singular feminine ablative from condītiō, condītiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnscius: conscious, aware of; singular masculine nominative from cōnscius, cōnscia, cōnscium"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="crēdere: to believe; present active infinitive from credo, credere, credidi, creditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cūnctā: all, whole; plural neuter ablative from cūnctus, cūncta, cūnctum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cūnctī: all, whole; plural masculine nominative from cūnctus, cūncta, cūnctum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Dānōrum: of the Danes; plural masculine genitive from Dānus, Dānī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīmissa: having been forgiven, dismissed ; singular feminine nominative perfect passive participle from dīmittō, dīmittere, dīmīsī, dīmissus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ducēs: leaders; plural masculine accusative from dux, ducis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eius: his/her/its"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="factī: of the deed; singular neuter genitive from factum, factī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēcēre: they did, made; 3rd person plural perfect active from faciō, facere, fēcī, factus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fidēs: faith; singular feminine nominative from fidēs, fideī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gesta: deeds, acts"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gregātī: having been assembled; plural masculine nominative perfect passive participle from gregō, gregāre, gregāvī, gregātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīc: there"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="lavācrum: bath, baptism (in context); singular neuter accusative from lavācrum, lavācrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="lībertāte: liberty; singular feminine ablative from lībertās, lībertātis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="māgna: large; singular feminine nominative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mōle: weight; singular feminine ablative from mōles, mōlis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="multī: many; singular masculine genitive from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="multīs: many; plural dative from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nam: yes, truly"/>
                <para PARENT="Vocab"/>
