        <PAGEOBJECT XPOS="136.0008" YPOS="22222.5600929936" OwnPage="51" ItemID="984658650" PTYPE="4" WIDTH="522" HEIGHT="179.437359235719" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 179.437 L0 179.437 L0 0 Z" copath="M0 0 L522 0 L522 179.437 L0 179.437 L0 0 Z" gXpos="136.0008" gYpos="22222.5600929936" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The king, leading/spending the time of winter in Carisiacus."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And treating much of the things to be done."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And with various cares, which the state needed."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="That continuosly war with the Saxons might be waged."/>
                <ITEXT CH=" The subjunctive is used because this is a purpose clause; the imperfect tense of "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="ingererētur"/>
                <ITEXT CH=" doesn't really matter for translation. There must be a short "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="u"/>
                <ITEXT CH=" on "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="iūgiter"/>
                <ITEXT CH=" to fit the meter."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="(Charlegmagne) had experienced them (the Saxons) (to be) unmindful of faith or every treaty."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="That no rest be given to them."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Until, heathen ritual and cult having been left, they might have become Christian, or have been destroyed forever."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="8"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Who knew the chests/hearts of this people (the Saxons) could not otherwise be softened, that (their) stiff neck might learn to turn back their innate stiffness, and subdue itself to the gentle yoke of Christ."/>
                <ITEXT CH=" Note the Saxon Poet's expressed thankfulness to the forced conversion of his people."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="21688.0848" OwnPage="52" ItemID="985127530" PTYPE="4" WIDTH="522" HEIGHT="720.000000000002" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="21688.0848" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
