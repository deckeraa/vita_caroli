                <para PARENT="Vocab"/>
                <ITEXT CH="magistrum: teacher; singular masculine accusative from magister, magistrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mūnīvit: he fortified; 3rd person singular perfect active from mūniō, mūnīre, mūnīvī, mūnītus"/>
                <para PARENT="Vocab"/>
