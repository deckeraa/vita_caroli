        <PAGEOBJECT XPOS="136.0008" YPOS="27512.1072" OwnPage="65" ItemID="1014978170" PTYPE="4" WIDTH="522" HEIGHT="440.186777070059" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 440.187 L0 440.187 L0 0 Z" copath="M0 0 L522 0 L522 440.187 L0 440.187 L0 0 Z" gXpos="136.0008" gYpos="27512.1072" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Huic nimis ingrātus"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" dōnō male sollicitābat"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Urbibus ex multīs populōs, ac fēcit ut ad sē"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dēficerent, iūstō Carolī sprētō dominātū."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hōs ut comprimeret"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" mōtūs, nīl ipse morātus,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Strēnua quam celerī raptim vocat agmina iussū."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cum quibus Ītaliam properāns, meritōque"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" tyrannum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Interitū plēctēns, urbēs servāre"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" receptās"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Francōrum comitēs, quōs ipse locābat in illīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Iussit, et ut vēnit, vēlōx sīc"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" inde recessit."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Vix Alpīnārum nivium iuga proxima caelō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Illī trānsgressō trīstis fuit obvia fāma"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=","/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ērēsburg referēns urbem, quam coeperat ōlim"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Mīlitibusque suīs mandāverat ipse tuendam,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Saxonēs expugnātam coepisse"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT CH=", suumque"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Expulsum fore praesidium violenter ab illīs."/>
                <trail PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="27960.090155414" OwnPage="65" ItemID="1015438378" PTYPE="4" WIDTH="522" HEIGHT="272.017044585991" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 272.017 L0 272.017 L0 0 Z" copath="M0 0 L522 0 L522 272.017 L0 272.017 L0 0 Z" gXpos="136.0008" gYpos="27960.090155414" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="(Hrodgaud), overly ungrateful to this gift, was wickedly stirring up the peoples out of many cities, and made them defect (from Charlemagne) to him, spurning the just dominion of Charlemagne."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="So that he might squash this rebellion, he (Charlemagne) himself delayed not at all, (and) very speedily called strong armies with quick command."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And punishing the tyrant (Hrodgaud) with merited death."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="He ordered the counts of the Franks to guard the recovered cities."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="servāre"/>
                <ITEXT CH=" goes with "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="iussit"/>
                <ITEXT CH=" two lines down."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And in the manner he came, thus he quickly returned from there."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Sad news was in the way to (meet) him."/>
                <ITEXT CH=" As soon as Charlemagne had crossed the Alps, a messenger met him with the bad news about the Saxon rebellion."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="(The messenger related) the Saxons to have begun fighting and their garrison to be expelled violently by them."/>
                <para PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="27512.1072" OwnPage="66" ItemID="1017411274" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="27512.1072" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ab: from, out of, by, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ac: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agmina: marching armies; plural neuter accusative from agmen, agminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Alpīnārum: of the Alps; plural feminine genitive from Alpīnus, Alpīna, Alpīnum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="caelō: heaven, sky; singular masculine ablative from caelus, caelī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolī: of Charlemagne (genitive case), AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="celerī: quick; singular ablative from celer, celeris -e, celerior -or -us, celerrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="coeperat: he had started; 3rd person singular pluperfect active from coepī, coepisse, coepī, coeptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="coepisse: to have started; perfect active infinitive from coepī, coepisse, coepī, coeptus"/>
