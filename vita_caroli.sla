                <para PARENT="Vocab"/>
                <ITEXT CH="novī: new; singular neuter genitive from novus -i -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Nōviomāgum: a city of the Treveri, now Nijmegen, city in Holland; singular feminine accusative from Nōviomāgus, Nōviomāgī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Paschae: Pascha, Easter; singular feminine genitive from Pascha, Paschae"/>
                <para PARENT="Vocab"/>
