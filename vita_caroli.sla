                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sīc: thus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Sigiburg: A Saxon hillfort in Western Germany"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simul: at the same time as"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="strēnua: brisk, vigorous; plural neuter nominative from strēnuus, strēnua, strēnuum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suās: their; plural accusative feminine of suus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tālem: such; singular common accusative from tālis, tālis, tāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trānsmissō: having been sent; singular masculine ablative perfect passive participle from trānsmittō, trānsmittere, trānsmīsī, trānsmissus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbem: city; singular feminine accusative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ūtile: usefully; adverb from ūtilis, ūtilis, ūtile"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vel: or"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vicum: village; singular masculine accusative from vīcus, vīcī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Wisuram: the River Weser, the second longest river in Germany"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="23352.0912" OwnPage="55" ItemID="994115242" PTYPE="4" WIDTH="522" HEIGHT="559.029802547768" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 559.03 L0 559.03 L0 0 Z" copath="M0 0 L522 0 L522 559.03 L0 559.03 L0 0 Z" gXpos="136.0008" gYpos="23352.0912" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Cui iuxtā montem quī Brūnesberg vocitātur,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Obvia"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" magna fuit cupiēns obsistere turba,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nē fluvium trānsīret, et hōc cōnāmine cassō."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Fugit enim prīmō statim certāmine pulsā,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Innumerōsque diē ferrum prōstrāverat illō."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Inde movēns Carolus regiōnēs vēnit ad illās,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quās Osterliudī retinent, sēditque locātīs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad fluvium castrīs, quī nunc Ōvaccra vocātur."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tunc illī quīdam"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=", quī dē prīmōribus eius"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Gentis erat, supplex occurrit nōmine Hessī;"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Partis et illīus pariter plēbs obvia tōta"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Vēnerat, obsidibusque datīs quōs"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" iusserat ipse,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sē servāre fidem rēgī per maxima spondent"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Iūrāmenta. Quibus"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" cūnctīs hōc ōrdine gestīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="In pāgum rediit, quem dīcunt nōmine Bukkī."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Illīc occurrēre ducēs simul Angariōrum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cum populō, similīque modō rēgālibus omnēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dum pārent"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" iussīs, iūrāmentīsque fidēlēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sē fore cōnfirmant, reditum parat īlico victor."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="23352.0912" OwnPage="56" ItemID="994401514" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="23352.0912" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Angariōrum: of the Angarians, a Saxon tribe"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Brunesberg: the name of a mountain or hill in Saxony"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Bukki: possibly Breisgau, a region in Germany"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolus: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cassō: hollow, vain, useless; singular masculine ablative from cassus, cassa, cassum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castrīs: forts; plural neuter ablative from castrum, castrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="certāmine: contest, struggle; singular neuter ablative from certāmen, certāminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnāmine: effort, struggle; singular neuter ablative from cōnāmen, cōnāminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnfirmant: they confirmed, affirmed; 3rd person plural present active from cōnfirmō, cōnfirmāre, cōnfirmāvī, cōnfirmātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cui: to whom; singular dative from quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cūnctīs: all, whole; plural ablative from cūnctus, cūncta, cūnctum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cupiēns: desiring; singular nominative present participle from cupiō, cupere, cupīvī, cupītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="datīs: having been giving; plural ablative past passive participle from dō, dare, dedī, datus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dē: of, from, away from, down from"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīcunt: they say; 3rd person plural present active from dīcō, dīcere, dīxī, dictus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="diē: day; singular common ablative from diēs, diēī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ducēs: leaders; plural masculine nominative from dux, ducis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dum: while, as long as, until"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eius: his/her/its"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="enim: for, truly, really, indeed"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="erat: he was; 3rd person singular imperfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ferrum: sword; singular neuter nominative from ferrum, ferrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fidēlēs: faithful persons, confidants; plural common nominative from fidelis, fidele, fidelior -or -us, fidelissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fidem: faith; singular feminine accusative from fidēs, fideī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fluvium: river; singular masculine accusative from fluvius, fluviī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fore: to be; future active infinitive from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fugit: it (the crowd) fled; 3rd person singular perfect active from fugiō, fugere, fūgī, fugitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fuit: he was; 3rd person singular perfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gentis: of the people, clan, nation; singular feminine genitive from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gestīs: having been carried out; plural ablative perfect passive participle from gerō, gerere, gessī, gestus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Hessi: the name of a man sent to Charlemagne to negotiate peace"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hōc: this; singular neuter ablative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īlico: immediately (adverb). Usually spelled īlicō; however the o must be short here to fit the meter."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illās: those; plural feminine accusative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illī: to that one (Charlemagne); from ille, illa, illud. Alternatively: there, belonging to that party (adverb)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīc: there"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīus: of that; singular genitive from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illō: that; singular masculine or neuter ablative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="inde: from there, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="innumerōs: countless; plural masculine accusative from innumerus, innumera, innumerum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipse: himself; singular masculine nominative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iūrāmenta: oaths; plural neuter accusative from iūrāmentum, iūrāmentī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iūrāmentīs: oaths; plural neuter ablative from iūrāmentum, iūrāmentī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iusserat: he had ordered; 3rd person singular pluperfect from iubeō, iubēre, iussī, iussus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iussīs: commands, orders; plural dative perfect passive participle from iubeō, iubēre, iussī, iussus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iuxtā: near, nearly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="locātīs: having been stationed; plural ablative from locō, locāre, locāvī, locātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="māgna: large; singular feminine nominative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="maxima: very big; plural neuter accusative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="modō: manner, way; singular masculine ablative from modus, modī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="montem: mountain; singular masculine accusative from mōns, montis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="movēns: moving; singular nominative present participle from moveō, movēre, mōvī, mōtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nē: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōmine: name; singular neuter ablative from nōmen, nōminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nunc: now"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obsidibus: hostages; plural common ablativefrom obses, obsidis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obsistere: to oppose, resist, withstand; present active infinitive from obsistō, obsistere, obstitī, obstitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obvia: in the way; hostile; singular feminine nominative from obvius, obvia, obvium"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="occurrēre: they ran; 3rd person plural perfect alternative to occurrērunt from occurrō, occurrere, occurrī / occucurrī, occursus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="occurrit: he ran; 3rd person singular perfect from occurrō, occurrere, occurrī / occucurrī, occursum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="omnēs: all, every; plural common nominative from omnis, omnis, omne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ōrdine: order; singular masculine ablative from ōrdō, ōrdinis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Osterliudī: Another name of the Eastphalians"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ovaccra: probably the Oker River, a tributary of the River Aller, in Lower Saxony"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pāgum: district, region; singular masculine accusative from pāgus, pāgī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="parat: he prepares; 3rd person singular present active from parō, parāre, parāvī, parātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pārent: they obey; 3rd person plural present active from pāreō, pārēre, pāruī, pāritūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pariter: together, likewise"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="partis: region, faction; singular feminine genitive from pars, partis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="per: through"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plēbs: common people; singular feminine nominative from plēbs, plēbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populō: peoples, populaces; singular masculine ablative from populus, populī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prīmō: first; singular masculine ablative from prīmus, prīma, prīmum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prīmōribus: chiefs, nobles; plural ablative from primoris, primoris, primore"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prostrāverat: it had struck down; 3rd person singular pluperfect active from prosternō, prosternere, prostrāvī, prostrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pulsā: having been hit; singular feminine ablative perfect passive participle from pello, pellere, pepuli, pulsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quās: which; plural female accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quem: which, singular masculine accusative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: which; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quibus: with which; plural ablative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quōs: which; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="reditum: return; singular masculine accusative from reditus, reditūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="redīvit: he returned; 3rd person singular perfect active from redeō, redīre, redivī(iī), reditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgālibus: regal, royal; plural dative from rēgālis, rēgālis, rēgāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgī: king; singular masculine dative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="regiōnēs: regions; plural feminine accusative from regiō, regiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="retinent: they retain; 3rd person plural present active from retineō, retinēre, retinuī, retentus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sē: himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēdit: he encamped; 3rd person singular perfect active from sedeō, sedēre, sēdī, sessus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="servāre: to maintain, preserve; present active infinitive from servō, servāre, servāvī, servātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="similī: similar; singular ablative from similis, simile, similior -or -us, simillimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simul: at the same time as"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="spondent: they promise; 3rd person plural present active from spondeo, spondere, spepondi, sponsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="statim: immediately"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="supplex: suppliant; singular masculine nominative from supplex, supplicis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tōta: whole, total; singular feminine nominative from tōtus, tōta, tōtum (gen -ius)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trānsīret: he crossed over; 3rd person singular imperfect active subjunctive from trānseō, trānsīre, trānsivi(iī), trānsitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tunc: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="turba: crowd; singular feminine nominative from turba, turbae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēnerat: he had come; 3rd person singular pluperfect active from veniō, venīre, vēnī, ventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēnit: he came; 3rd person singular present active from veniō, venīre, vēnī, ventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="victor: victor; singular masculine nominative from victor, victōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vocātur: it is called; 3rd person singular present passive from vocō, vocāre, vocāvī, vocātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vocitātur: it is called; 3rd person singular present passive from vocitō, vocitāre, vocitāvī, vocitātus"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="23919.1210025478" OwnPage="55" ItemID="998221706" PTYPE="4" WIDTH="522" HEIGHT="149.96178343949" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 149.962 L0 149.962 L0 0 Z" copath="M0 0 L522 0 L522 149.962 L0 149.962 L0 0 Z" gXpos="136.0008" gYpos="23919.1210025478" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="In the way was a large crowd desirous of resisting, that he might not cross over the river, and, in vain battle, it fled having immediatey with the first blow of battle, and countless on that day the sword had laid low in that (place)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Then there a certain (man) named Hessi, who was of the prominent men of his people, ran (up to Charlemagne as a) supplicant."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And the hostages having been given which he (Charlemagne) himself had ordered."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="With all these things having been set in this order."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And in a similar way while all obeyed the royal commands, and with oaths confirmed to him to be faithful, the victor (Charlemagne) immediately prepared to return (to his homeland)."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="parent"/>
                <ITEXT CH=" takes the dative instead of the accusative, which is why "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="iussīs rēgālibus"/>
                <ITEXT CH=" is in the dative."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="24184.0944" OwnPage="57" ItemID="998745418" PTYPE="4" WIDTH="522" HEIGHT="307.612789808918" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 307.613 L0 307.613 L0 0 Z" copath="M0 0 L522 0 L522 307.613 L0 307.613 L0 0 Z" gXpos="136.0008" gYpos="24184.0944" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Intereā iuxtā Wisuram dīmissa"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" manēbat"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Pars exercituum rēgis, locus ipse vocātur"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hlidbeki, quō castrīs īdem sēdēre locātīs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sed male"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" sēcūrōs rēs prōspera fēcerat illōs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quā rēx ūsus erat, cum cūnctīs hostibus esset"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Terrōrī, iam tunc audente resistere nūllō."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hinc"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" erat in castrīs cautēla remissior illīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ut possent nimiā Saxonum fraude nocērī."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sōl summō coelī prōnus vergēbat"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" ab axe,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et vespertīnās iam tendere coepit ad hōrās;"/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="24491.7071898089" OwnPage="57" ItemID="1003266282" PTYPE="4" WIDTH="522" HEIGHT="243.974522292994" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 243.975 L0 243.975 L0 0 Z" copath="M0 0 L522 0 L522 243.975 L0 243.975 L0 0 Z" gXpos="136.0008" gYpos="24491.7071898089" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Meanwhile, a part of the king's armies, having been left, remained by the Weser River."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="But badly careless the prosperous time had made them, from which the king had experienced, with all the enemies being terrified, now then no one dared to resist. "/>
                <ITEXT CH="Because of Charlemagne's military success, some of his soldiers became careless."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Because of this caution was more relaxed in their camp, so that they could be harmed by the excessive fraud of the Saxons."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The sun lay prone from the axis of the highest sky."/>
                <ITEXT CH=" This means that it was past noon."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="24184.0944" OwnPage="58" ItemID="1003686266" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="24184.0944" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
