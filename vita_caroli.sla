                <para PARENT="Vocab"/>
                <ITEXT CH="cui: to whom; singular dative from quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīmissus: he was sent away (est omitted for metrical reasons); singular masculine nominative perfect passive participle from dīmittō, dīmittere, dīmīsī, dīmissus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dux: leader; singular masculine nominative from dux, ducis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eī: to him, her, or it; singular dative from is, ea, id"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ferēns: bringing, bearing; singular nominative present participle from ferō, ferre, tulī, lātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Gallōrum: of the Gauls; plural masculine genitive from Gallus, Galli"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gēns: people, clan, nation; singular feminine nominative from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Hildībrandus: Hildeprand, Duke of Spoleto from 774 to 789"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="honore: honor; singular masculine ablative from honor, honōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnsignī: distinguished; singular dative from īnsignis, īnsignis, īnsigne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="intentē: intently, attentively"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="invādere: to invade; present active infinitive from invādō, invādere, invāsī, invāsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipsa: itself; singular feminine nominative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="locō: place; singular masculine ablative from locus, locī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="māgnō: large; singular masculine ablative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="meditāns: thinking about; singular masculine nominative present participle from meditor, meditārī, meditātum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mūnera: gifts; plural neuter accusative from mūnus, mūneris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="novō: new; singular masculine ablative from novus, nova -um, novior -or -us, novissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="occurrerat: he had run; 3rd person singular pluperfect active from occurrō, occurrere, occurrī, occursus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="occurrit: he met, ran; 3rd person singular perfect from occurrō, occurrere, occurrī, occursus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pariter: likewise, together"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="peragrāns: traveling over; singular nominative present participle from peragrō, peragrāre, peragrāvī, peragrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pōscente: demanding; singular ablative present participle from pōscō, pōscere, popōscī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="posse: to be able; present active infinitive from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pretiōsa: precious; plural neuter accusative from pretiōsus, pretiōsa -um, pretiōsior -or -us, pretiōsissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; singular masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quōdam: in a certain; singular ablative of quīdam"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quondam: formerly, at one time"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgī: king; singular masculine dative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="resistere: to resist; present active infinitive from resistō, resistere, restitī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Rhēnum: the Rhine; singular masculine accusative from Rhēnus, Rhēnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="satis: enough"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnum: of the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sē: themselves"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="spē: hope; singular feminine ablative from spēs, speī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Spōlētānus: of the Duchy of Spoleto, located in the region of Umbria, Italy"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sua: his; plural neuter accusative from suus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sūmptīs: having been taken up; plural ablative perfect passive participle from sūmō, sūmere, sūmpsī, sūmptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="terrās: lands; plural feminine accusative from terra, terrae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trāiēcerat: they had transferred, transported; 3rd person singular pluperfect active from trāiciō, trāicere, trāiēcī, trāiectus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tunc: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vānā: empty, vain; singular feminine ablative from vānus, vāna, vānum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēre: spring; singular neuter ablative from vēr, vēris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vicum: village; singular masculine accusative from vīcus, vīcī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vocitātō: having been called; singular masculine ablative perfect passive participle from vocitō, vocitāre, vocitāvī, vocitātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vocitātus: having been called; singular masculine nominative perfect passive participle from vocitō, vocitāre, vocitāvī, vocitātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Wirciniacum: Verzenay, a town in north-eastern France"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="39160.152" OwnPage="93" ItemID="1065585402" PTYPE="4" WIDTH="522" HEIGHT="293.800828025465" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 293.801 L0 293.801 L0 0 Z" copath="M0 0 L522 0 L522 293.801 L0 293.801 L0 0 Z" gXpos="136.0008" gYpos="39160.152" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Sed cum coepissent"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" aciē cōnflīgere, statim"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Terga dedit, numerō Francōrum territa grandī."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Accēpit tunc Westfālōs in dēditiōnem."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Prōgressusque dehinc, Wisuram pervēnit ad amnem,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Atque diēs aliquot mānsit statiōne"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" locāta."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Angariōs sed et Ostfālhōs ad sē venientēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Prōmissam firmāre fidem, quā sēmet eīdem"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Subiectōs"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" fore spondēbant, animōque fidēlēs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Obsidibusque datīs sacrāmentīsque coēgit."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hīs gestīs rēx Wormaciam remeāvit ad urbem."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="39458.9528280255" OwnPage="93" ItemID="1066160218" PTYPE="4" WIDTH="522" HEIGHT="64.6624203821484" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 64.6624 L0 64.6624 L0 0 Z" copath="M0 0 L522 0 L522 64.6624 L0 64.6624 L0 0 Z" gXpos="136.0008" gYpos="39458.9528280255" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="But, having had started to fight in a battle line, suddenly they (the Saxon people, refers to gens on the previous page) turned their backs, having been terrified by the great number of Franks."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH="Spelled "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="stacione"/>
                <ITEXT CH=" in the critical text."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Subiectōs"/>
                <ITEXT CH=" has a consonantal "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="i"/>
                <ITEXT CH=" and consists of three long syllables."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="39160.152" OwnPage="94" ItemID="1068839818" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="39160.152" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="accēpit: he received; 3rd person singular perfect active from accipiō, accipere, accēpī, acceptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aciē: battle line; singular feminine ablative from aciēs, aciēī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aliquot: quite a lot"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="amnem: river; singular masculine accusative from amnis, amnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Angariōs: the Angarians, a Saxon tribe"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="animō: soul, mind, live; singular masculine ablative from animus, animi"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="atque: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="coēgit: he collected, he forced; 3rd person singular perfect active from cōgō, cōgere, coēgī, coāctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="coepissent: they (might) have had started; 3rd person plural pluperfect active subjunctive from coepio, coepere, coepi, coeptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnflīgere: to fight; present active infinitive from cōnflīgō, cōnflīgere, cōnflīxī, cōnflīctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="datīs: having been given; plural ablative past passive participle from dō, dare, dedī, datus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dedit: he gave; 3rd person singular perfect active from dō, dare, dedī, datus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēditiōnem: surrender, capitulation; singular feminine accusative from dēditiō, dēditiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dehinc: from now on, from this place"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="diēs: day; singular common accusative from diēs, diēī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eī: to him, her, or it; singular dative from is, ea, id"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fidēlēs: faithful persons, confidants; plural common accusative from fidelis, fidele, fidelior -or -us, fidelissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fidem: faith; singular feminine accusative from fidēs, fideī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fīrmāre: to harden, confirm; present active infinitive from fīrmō, fīrmāre, fīrmāvī, fīrmātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fore: to be; future active infinitive from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gestīs: having been carried out; plural ablative perfect passive participle from gerō, gerere, gessī, gestus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="grandī: great, grand, imposing; singular ablative from grandis, grandis, grande"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hīs: to these; plural masculine ablative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="locātā: having been stationed; singular feminine ablative perfect passive participle from locō, locāre, locāvī, locātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mānsit: he remained; 3rd person singular perfect active from maneō, manēre, mānsī, mānsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="numerō: number, division, troop; singular masculine ablative from numerus, numerī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obsidibus: hostages; plural common ablative from obses, obsidis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ostfalhōs: Eastphalians, members of a Saxon tribe"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pervēnit: he arrived; 3rd person singular perfect active from perveniō, pervenīre, pervēnī, perventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prōgressus: having advanced; singular masculine nominative perfect participle from prōgredior, prōgredī, prōgressus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prōmissam: having been promised; singular feminine accusative perfect passive participle from prōmittō, prōmittere, prōmīsī, prōmissus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quā: what; singular female ablative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="remeāvit: he returned; 3rd person singular perfect active from remeō, remeāre, remeāvī, remeātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sacrāmentīs: sacraments; plural neuter ablative from sacrāmentum, sacrāmentī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēmet: themselves (-met is an intensifier)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="spondēbant: they were promising; 3rd person plural imperfect active from  spondeō, spondēre, spopondī, spōnsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="statim: immediately"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="statiōne: outpost, station; singular feminine ablative from statiō, statiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subiectōs: having been subjected; plural masculine accusative perfect passive participle from subicio, subicere, subjeci, subjectus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="terga: backs; plural neuter accusative from tergum, tergī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="territa: having been frightened; singular feminine nominative perfect passive participle from terreō, terrēre, terruī, territus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tunc: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbem: city; singular feminine accusative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="venientēs: coming; plural common nominative present participle from veniō, venīre, vēnī, ventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Westfalōs: Westphalians, members of a Saxon tribe"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Wisuram: the River Weser, the second longest river in Germany"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Wormacia: Worms, a city in Germany; singular feminine nominative from Wormacia, Wormaciae"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="39992.1552" OwnPage="95" ItemID="1069114746" PTYPE="4" WIDTH="522" HEIGHT="295.530312101899" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 295.53 L0 295.53 L0 0 Z" copath="M0 0 L522 0 L522 295.53 L0 295.53 L0 0 Z" gXpos="136.0008" gYpos="39992.1552" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Annō 780"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Inde movēns ōportūnō"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" sua tempore castra,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Saxōnum rūrsus properāverat in regiōnem."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ēresburg prīmō petiit, post haec ubi fontēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Lyppia flūmen habet, perplūrima"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" dispositūrus"/>
                <para PARENT="Latin"/>
                <ITEXT CH="In castrīs aliquot fertur"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" mānsisse diēbus."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hinc orientis"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" iter sūmēns, ad flūmen Ovaccrum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Vēnit, et eiusdem gentis quam maxima turba"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Illūc praeceptō pārēns occurrerat, atque"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Crēdere sē Chrīstō simulāns baptisma recēpit."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="40287.6855121019" OwnPage="95" ItemID="1069391434" PTYPE="4" WIDTH="522" HEIGHT="94.9299363057326" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 94.9299 L0 94.9299 L0 0 Z" copath="M0 0 L522 0 L522 94.9299 L0 94.9299 L0 0 Z" gXpos="136.0008" gYpos="40287.6855121019" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="From there moving his camp at an opportune time."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Planning to arrange many things."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="It is said he remained in the camp for many days."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="From here taking a trip eastward."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="39992.1552" OwnPage="96" ItemID="1071683114" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="39992.1552" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aliquot: quite a lot"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="annō: year; singular masculine ablative from annus, annī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="atque: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="baptisma: baptism; plural neuter accusative from baptismum, baptismi"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castra: forts; plural neuter accusative from castrum, castrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castrīs: forts; plural neuter ablative from castrum, castrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Chrīstō: Christ"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="crēdere: to believe; present active infinitive from credo, credere, credidi, creditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="diēbus: days; plural common ablative from diēs, diēī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dispositūrus: for arranging; singular masculine nominative future participle from dispōnō, dispōnere, disposuī, dispositus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eius: his/her/its"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ērēsburg: a Saxon refuge castle near modern-day Obermarsberg"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fertur: it is said; 3rd person singular present passive from ferō, ferre, tulī, lātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="flūmen: river; singular neuter nominative from flūmen, flūminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fontēs: headwaters, fountains; plural masculine accusative from fōns, fontis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gentis: of the people, clan, nation; singular feminine genitive from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="habet: he has; 3rd person singular present active from habeō, habēre, habuī, habitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="haec: these; plural neuter accusative from hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hinc: from here"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illūc: over there"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="inde: from there, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iter: journey, trip; singular neuter accusative from iter, itineris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Lyppia: the Lippe, a river in modern-day Rhine-Westphalia, Germany"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mānsisse: to have remained; perfect active infinitive from maneō, manēre, mānsī, mānsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="maxima: very big, biggest; singular feminine nominative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="movēns: moving; singular nominative present participle from moveō, movēre, mōvī, mōtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="occurrerat: he had run; 3rd person singular pluperfect active from occurrō, occurrere, occurrī, occursus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="oportunō: opportune; singular masculine ablative from oportūnus, oportūna -um, oportunior -or -us, oportunissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="orientis: East; singular masculine genitive from oriēns, orientis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ovaccrum: probably the Oker River, a tributary of the River Aller, in Lower Saxony"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pārēns: obeying; singular nominative present participle from pāreō, pārēre, pāruī, pārēns"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="petīvīt: he asked for; 3rd person singular perfect active from petō, petere, petīvī, petītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plūrima: very many; singular feminine nominative from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="post: behind, after, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praeceptō: having been ordered; singular masculine ablative perfect passive participle from praecipiō, praecipere, praecēpī, praeceptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prīmō: first; singular masculine ablative from prīmus, prīma, prīmum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="properāverat: he hurried; 3rd person singular pluperfect active from properō, properāre, properāvī, properātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quam: how? how much?"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="recēpit: he received; 3rd person singular perfect active from recipiō, recipere, recēpī, receptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="regiōnem: region; singular feminine accusative from regiō, regiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rūrsus: backwards, on the flipside"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnum: of the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sē: themselves"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simulāns: feigning, simulating; singular nominative present participle from simulō, simulāre, simulāvī, simulātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sua: his; plural neuter accusative from suus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sūmēns: taking up; singular nominative present participle from sūmō, sūmere, sūmpsī, sūmptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tempore: time, period; singular neuter ablative from tempus, temporis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="turba: crowd; singular feminine nominative from turba, turbae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ubī: where, when if"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēnit: he came; 3rd person singular present active from veniō, venīre, vēnī, ventus"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="40824.1584" OwnPage="97" ItemID="1071945354" PTYPE="4" WIDTH="522" HEIGHT="239.934955413999" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 239.935 L0 239.935 L0 0 Z" copath="M0 0 L522 0 L522 239.935 L0 239.935 L0 0 Z" gXpos="136.0008" gYpos="40824.1584" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Indeque"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" festīnus pergēns, ibi castra locāvit,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Albia quā grandis fluvius miscētur et Ōra."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nam rēs Saxōnum voluit compōnere, nec nōn"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sclāvōrum, medius quōs Albia dīvidit amnis."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Citrā"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" Saxonēs dēgunt, in lītore vērō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sclāvōrum pāgāna manet gēns ulteriōrī."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dispositīs sānē rēbus prō tempore cūnctīs"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=","/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad sēdēs tandem studuit remeāre paternās."/>
                <trail PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="41064.093355414" OwnPage="97" ItemID="1072080090" PTYPE="4" WIDTH="522" HEIGHT="162.802547770701" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 162.803 L0 162.803 L0 0 Z" copath="M0 0 L522 0 L522 162.803 L0 162.803 L0 0 Z" gXpos="136.0008" gYpos="41064.093355414" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And from there continuing on quickly, he stationed a camp there, in the place where the grand river Elbe is mixed with the "/>
                <ITEXT CH="Ohre river (alternatively, the shore)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="For he wanted to arrange the things of the Saxons, and also of the Slavs, whom divides in the middle with the River Elbe."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="On this side the Saxons live, and on beyond the shore dwell the pagan Slavs."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Having arranged everything well for (that) time."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="40824.1584" OwnPage="98" ItemID="1074089962" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="40824.1584" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Albia: of the River Elbe; variant spelling from Albis, Albis"/>
