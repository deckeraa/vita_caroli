                <ITEXT CH="suppliciter: humbly, suppliantly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suscēpit: in undertook; 3rd person singular perfect active from suscipiō, suscipere, suscēpī, susceptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tālī: such"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tōtum: whole, total; singular neuter accusative from tōtus, tōta, tōtum (gen -ius)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tum: then"/>
                <para PARENT="Vocab"/>
