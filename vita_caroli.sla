                <para PARENT="Vocab"/>
                <ITEXT CH="castra: forts; plural neuter accusative from castrum, castrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="citrā: on this side"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="compōnere: to put together; present active infinitive from compōnō, compōnere, composuī, compositus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cūnctīs: all, whole; plural ablative from cūnctus, cūncta, cūnctum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēgunt: they live; 3rd person plural present active from dēgō, dēgere, dēgī, -"/>
                <para PARENT="Vocab"/>
