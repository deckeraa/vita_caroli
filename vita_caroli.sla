        <PAGEOBJECT XPOS="136.0008" YPOS="37496.1456" OwnPage="89" ItemID="1060191482" PTYPE="4" WIDTH="522" HEIGHT="291.259057324831" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 291.259 L0 291.259 L0 0 Z" copath="M0 0 L522 0 L522 291.259 L0 291.259 L0 0 Z" gXpos="136.0008" gYpos="37496.1456" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Hoc rēx Hispānīs didicit"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" regressus ab hōrīs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tunc orientālēs"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" Francōs nec nōn Alamannōs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Obvia ferre iubet statim Saxonibus arma."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quōs cum iam patriam redeuntēs īnsequerentur,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="In Baddanfeldun—sīc est locus ille vocātus—"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ādernam iuxtā fluvium cōnstanter in ipsōs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Irruerant, nūtūque"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" Deī quem crīmina tanta"/>
                <para PARENT="Latin"/>
                <ITEXT CH="In populō commissa suō dampnāre decēbat,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Saxonēs tantā cecidērunt strāge perēmptī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ut dē praegrandī superessent agmine paucī."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="37787.863256051" OwnPage="89" ItemID="1060507242" PTYPE="4" WIDTH="522" HEIGHT="138.038216560468" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 138.038 L0 138.038 L0 0 Z" copath="M0 0 L522 0 L522 138.038 L0 138.038 L0 0 Z" gXpos="136.0008" gYpos="37787.863256051" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The king learned this, having returned from the time with the Spaniards."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Then he ordered the eastern Franks, and also the Alamanni, to immediately bear the available weapons against the Saxons."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And by the will of God it was fitting for such crimes, having been committed amongst his people, to be punished."/>
                <para PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="37496.1456" OwnPage="90" ItemID="1062775706" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="37496.1456" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ab: from, out of, by, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ādernam: the Eder river, which flows in North Rhine-Westphalia"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agmine: marching army; singular neuter ablative from agmen, agminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Alamannos: the Alamanni, a confederation of Germanic tribes incorporated into the Frankish kingdom by Clovis I in 496 AD."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="arma: weapons; plural neuter accusative from armum, armī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Baddanfeldun: Battenfeld, Germany"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cecidērunt: they fell; 3rd person plural perfect active from cadō, cadere, cecidī, cāsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="commissa: having been committed; singular feminine nominative perfect passive participle from committō, committere, commīsī, commissus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnstanter: constantly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="crīmina: judicial decisions, verdicts; plural neuter accusative from crīmen, crīminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
