                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quia: because"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="requiēs: rest, repose; singular feminine nominative from requiēs, requiētis"/>
                <para PARENT="Vocab"/>
