                <para PARENT="Vocab"/>
                <ITEXT CH="subdere: to place under; present active infinitive from subdō, subdere, subdidī, subditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="summōs: highest, greatest; plural masculine accusative from summus, summa, summum"/>
                <para PARENT="Vocab"/>
