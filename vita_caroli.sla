                <para PARENT="Vocab"/>
                <ITEXT CH="quot: quot ... tot ... = as many as"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="recessit: it withdrew; 3rd person singular perfect active from recēdō, recēdere, recessī, recessus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēge: king; singular masculine ablative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="remanent: they remain; 3rd person plural present active from remaneō, remanēre, remānsī, remānsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="revulsī: having been torn away; plural masculine nominative perfect passive participle from revellō, revellere, revellī, revulsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rīte: duly, according to religious usage, with due observance; solemnly; well; (adverb)"/>
