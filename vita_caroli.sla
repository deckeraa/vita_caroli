        <PAGEOBJECT XPOS="136.0008" YPOS="10040.04" OwnPage="23" ItemID="934483674" PTYPE="4" WIDTH="522" HEIGHT="326.232515923568" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 326.233 L0 326.233 L0 0 Z" copath="M0 0 L522 0 L522 326.233 L0 326.233 L0 0 Z" gXpos="136.0008" gYpos="10040.04" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <para PARENT="Chapter Heading"/>
                <ITEXT CH="Versiō Orīginālis"/>
                <para PARENT="Chapter Heading"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Salvātor mundī, postquam dē Virgine nāscī"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dignātus, nostrī sē corporis induit artūs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ēvolvit septingentōs rota temporis annōs "/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et deciēs septem, sed et ūnus pēne"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" perāctus"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Īnsuper annus erat, cum iūre monarchia rēgnī"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Francōrum Carolō dīvīnitus"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" est data Magnō."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nam Carolōmannus frāter dēcesserat"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" eius"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Prēsentis iam suprēmīs prope partibus annī. "/>
                <para PARENT="Latin"/>
            </StoryText>
            <PageItemAttributes>
                <ItemAttribute Name="TOC" Type="none" Value="Versiō Orīginālis" Parameter="" Relationship="none" RelationshipTo="" AutoAddTo="none"/>
            </PageItemAttributes>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="10366.2725159236" OwnPage="23" ItemID="934548602" PTYPE="4" WIDTH="522" HEIGHT="220.28525477707" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 220.285 L0 220.285 L0 0 Z" copath="M0 0 L522 0 L522 220.285 L0 220.285 L0 0 Z" gXpos="136.0008" gYpos="10366.2725159236" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The Savior of the world, after having deigned to be born of the Virgin, dressed himself in the bodily nature of our flesh; the wheel of time turned 700 years."/>
                <ITEXT CH=" This refers to Jesus Christ being born of the Virgin Mary. "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Dignātus"/>
                <ITEXT CH=" is an active participle because it comes from the deponent verb "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="dīgnor"/>
                <ITEXT CH=". This first phrase acts as a nominative absolute, a construction found in Medieval Latin that is similar to an ablative absolute. The wheel of time is a poetic construction used to convey the passing of time since the Incarnation; see next footnote."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And ten time seven, and one year almost carried out."/>
                <ITEXT CH=" The date thus given is, using a date of 1 AD for the birth of Christ, late 771 AD."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit" CH="Furthermore, it was the year when, by divine right, the monarchy of the kingdom of the Franks was given to Charles the Great."/>
                <ITEXT CH=" An English-like order might be "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="cum, dīvīnitus iūre, monarchia rēgnī Francōrum data est Carolō Magnō"/>
                <ITEXT CH=". "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="dīvīnitus"/>
                <ITEXT CH=" is an adverb, so it would be literally "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="by right divinely"/>
                <ITEXT CH=". I chose to capitalize "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Magnō"/>
                <ITEXT CH=" since it is a common epithet for Charlemagne."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="For Carloman his brother had died now, near the late parts of the present year."/>
                <ITEXT CH=" Carloman died on December 4, 771."/>
                <para PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="10040.04" OwnPage="24" ItemID="934574922" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="10040.04" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="annī: year; singular masculine genitive from annus, annī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="annōs: years; plural masculine accusative from annus, annī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="annus: year; singular masculine nominative from annus, annī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="artūs: bodily nature (in context), sinews, limbs, strengths; plural masculine accusative from artus, artūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolō: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty (dative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolōmannus: Carloman, son of Pepin the Short and co-ruler of the Frankish kingdom with Charlemagne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="corporis: body, flesh; singular neuter genitive from corpus, corporis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: when"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="data: data est = was given; singular feminine nominative perfect passive participle from dō, dare, dedī, datus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dē: of, from, away from, down from"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēcesserat: he had died; 3rd person singular pluperfect active from dēcēdō, dēcēdere, dēcessī, dēcessus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="deciēs: ten times"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dignātus: dignātus est = he had deemed worthy, deigned, the est is omitted for metrical reasons; singular masculine nominative active perfect active (though it looks passive) participle from dignor, dignārī, dignātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīvīnitus: divinely, of heaven (adverb)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eius: his/her/its"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="erat: he was; 3rd person singular imperfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="est: he is; 3rd person singular present active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ēvolvit: it rolled out, unrolled; 3rd person singular present active from ēvolvō, ēvolvere, ēvolvī, ēvolūtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="frāter: brother; singular masculine nominative from frāter, frātris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iam: already, now, soon"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="induit: he dressed; 3rd person singular perfect active from induō, induere, induī, indūtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnsuper: besides, furthermore"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iūre: by right; singular neuter ablative from iūs, iūris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Māgnō: great; singular masculine dative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="monarchia: monarchy; singular feminine nominative from monarchia, monarchiae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mundī: world; singular masculine genitive from mundus, mundī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nam: yes, truly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nāscī: to be born; present passive infinitive"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nostrī: our; singular neuter genitive of noster"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="partibus: parts; plural feminine ablative from pars, partis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pēne: almost; alternate spelling of paene"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="perāctus: perāctus erat = had been carried out; singular masculine nominative perfect passive participle from peragō, peragere, perēgī, perāctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="postquam: after"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prēsentis: present, at-hand, currently-mentioned; singular masculine genitive variant spelling from praesēns"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prope: near, close"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgnī: of the kingdom; singular neuter genitive from rēgnum, rēgnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rota: wheel; singular feminine nominative from rota, rotae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="salvātor: savior; singular masculine nominative from salvātor, salvātōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sē: himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="septem: seven"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="septingentōs: 700"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suprēmīs: furthest, latest; plural ablative from superus, supera -um, superior -or -us, suprēmus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="temporis: of time, of periods; singular neuter genitive from tempus, temporis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ūnus: one"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Virgine: Virgin (Mary); singular feminine ablative from virgō, virginis"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="11704.0464" OwnPage="27" ItemID="934823642" PTYPE="4" WIDTH="522" HEIGHT="500.527031847134" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 500.527 L0 500.527 L0 0 Z" copath="M0 0 L522 0 L522 500.527 L0 500.527 L0 0 Z" gXpos="136.0008" gYpos="11704.0464" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Rēx autem Carolus celebrāvit in Attiniācō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nātālem Dominī, nec nōn Paschālia fēsta. "/>
                <para PARENT="Latin"/>
                <ITEXT CH="Paulō"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" Rōmānē dēfūnctō praesule sēdis,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Suscēpit post hunc Adriānus pontificātum."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et rēx Wormatiam Carolus collēgit in urbem"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Francōrum procerēs ad concilium generāle;"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cum quibus ut bellō Saxonēs aggrederētur"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dēcrēvit; quoniam Saxōnum proxima Francīs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Adiacet ad boream tellūs, vix līmite certō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dīvīsī gentis fīnēs"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" utriusque cohaerent."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Que"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" tum vīcīnae quō plūs regiōne fuēre,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tantō sēiūnctās animīs discordia fēcit."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Fīnitimōs sed enim per agrōs utrimque solēbant"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Assiduē fierī cēdēs, incendia, praede."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Saxonum nātūra ferōx et pectora dūra,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ferre iugum Chrīstī necdum dīgnāta"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" suāve,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dēmonicō nimium fuerant errōre subācta."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="12204.5734318471" OwnPage="27" ItemID="935607850" PTYPE="4" WIDTH="522" HEIGHT="219.47296815287" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 219.473 L0 219.473 L0 0 Z" copath="M0 0 L522 0 L522 219.473 L0 219.473 L0 0 Z" gXpos="136.0008" gYpos="12204.5734318471" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Paul the Roman president of the seat (i.e. the Pope) having died, Adrian after him undertook the pontificate."/>
                <ITEXT CH=" Pope Paul I was Pope from May 29th 757 to June 28th 767, then Pope Stephen III (who isn't mentioned in this line) was Pope from August 7th 768 to January 24th 772, then Pope Adrian I was Pope from February 1st 772 to December 25th 795. Mommsen includes the following footnote on "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Paulō"/>
                <ITEXT CH=": "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="immo Stephano IV"/>
                <ITEXT CH="; by this Mommsen is referring to Pope Stephen III, since when Mommsen wrote his work Pope-elect Stephen (died March 25th 752 before taking Papal office) was considered an official Pope, but after 1961 was no longer deemed to have been a Pope, leading to a disparity in the numbering of Stephens."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="With whom he decided they would attack the Saxons in war."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="With barely a certain border the divided boundaries of either people stood closely together."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And thereupon when the neighbors went further out of the region, discord made their souls to be so separated."/>
                <ITEXT CH=" The proximity of the peoples led to conflict."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And both sides were accustomed to slaughter, fire, and prey to constantly occur through the neighboring fields."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Nor had they (the Saxons) deigned to bear the gentle yoke of Christ, but had been subjugated too much in demonic error. "/>
                <ITEXT CH="This is reminiscent of Matthew 11:30 &quot;My yoke is easy and my burden is light&quot;."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="11704.0464" OwnPage="28" ItemID="937471594" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="11704.0464" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Adriānus: Pope Adrian I, who was Pope from February 1st 772 to December 25th 795"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="adiacet: it lies next to; 3rd person singular present active from adiaceō, adiacēre, adiacuī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aggrederētur: they were attacking; 3rd person singular imperfect passive subjunctive from aggredior, aggredī, aggressus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agrōs: fields; plural masculine accusative from ager, agrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="animīs: souls, minds, lives; plural feminine ablative from anima, animae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="assiduē: permanently"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Attiniācō: likely Attigny in the Ardennes department of modern-day France"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="autem: but, however, moreover"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="bellō: battle, war; singular neuter ablative from bellum, bellī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="boream: the north; singular masculine accusative from Boreās, Boreae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolus: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cēdēs: slaughter; plural masculine accusative alternative spelling from caedēs, caedis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="celebrāvit: he celebrated; 3rd person singular perfect active from celebrō, celebrāre, celebrāvī, celebrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="certō: certain; singular masculine ablative from certus, certa, certum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Chrīstī: Christ; singular masculine genitive from Chrīstus, Chrīstī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cohaerent: they stand together; 3rd person plural present active from cohaereō, cohaerēre, cohaesī, cohaesus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="collēgit: he assembled, he collected; 3rd person singular perfect active from colligō, colligere, collēgī, collēctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="concilium: council, assembly; singular neuter accusative from concilium, conciliī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēcrēvit: he decided; 3rd person singular perfect active from dēcernō, dēcernere, dēcrēvī, dēcrētus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēfūnctō: dead; singular masculine ablative perfect participle from defungor, defungi, defunctus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Dēmonicō: with the demonic; singular masculine ablative variant spellinig from daemonicus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīgnāta: having deemed worthy; plural neuter nominative perfect passive participle from dīgnor, dīgnārī, dīgnātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="discordia: discord, disagreement; singular feminine nominative from discordia, discordiae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīvīsī: having been divided; plural masculine nominative from dīvidō, dīvidere, dīvīsī, dīvīsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dominī: of the lord; singular masculine genitive from dominus, dominī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dum: while, as long as, until"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dūra: hard; plural neuter nominative from dūrus, dūra -um, dūrior -or -us, dūrissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="enim: for, truly, really, indeed"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="errōre: error, wandering, deception; singular masculine ablative from error, errōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēcit: it made; 3rd person singular perfect active from faciō, facere, fēcī, factus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ferōx: wild, bold, defiant; singular feminine nominative from ferōx, (gen.), ferōcis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ferre: to bear; present active infinitive from ferō, ferre, tulī, lātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēsta: festivals; plural neuter accusative from fēstum, fēstī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fierī: to happen, to occur; present infinitive from fīō, fierī, factus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fīnēs: boundaries, ends, limits; plural masculine nominative from fīnis, fīnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fīnitimōs: neighbors; plural masculine accusative from fīnitimus, fīnitimī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francīs: the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fuerant: they had been; 3rd person plural pluperfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fuēre: they were, alternative spelling of fuērunt; 3rd person plural perfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="generāle: general; singular neuter accusative from generālis, generālis, generāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gentis: of the people, clan, nation; singular feminine genitive from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hunc: this; singular masculine accusative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="incendia: fires; plural neuter nominative from incendium, incendiī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iugum: yoke; singular neuter nominative from iugum, iugī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="līmite: limit; singular masculine ablative from līmes, līmitis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nātālem: birthday, Nātālem Dominī = Christmas; singular common accusative from natalis, natalis, natale"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nātūra: nature; singular feminine nominative from nātūra, nātūrae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="necdum: but not yet"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nimium: too much, superabundance; singular neuter nominative from nimius, nimia, nimium"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Paschālia: Paschal, Paschālia fēsta = Paschal (Easter) feasts; plural neuter nominative from paschālis, paschālis, paschāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Paulō: Pope Paul I; Pope from May 29th 757 to June 28th 767 (ablative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pectora: chests; plural neuter nominative from pectus, pectoris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="per: through"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plūs: more, from mūltus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pontificātum: pontificate; singular masculine accusative from pontificātus, pontificātūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="post: behind, after, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praede: plunder, prey; plural feminine nominative variant spelling from praeda, praedae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praesule: president; singular common ablative from praesul, praesulis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="procerēs: noblemen; plural masculine accusative from procer, proceris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="proxima: next, nearest; singular feminine nominative from proximus, proxima, proximum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="que: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quibus: what; plural dative or ablative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quō: what; singular ablative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quoniam: since, inasmuch now"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="regiōne: region; singular feminine after from regiō, regiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Rōmānē: of the Romans; singular feminine genitive variant spelling of Rōmānae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxonēs: the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnum: of the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēdis: seat, in context the Papal Seat; singular feminine genitive from sēdēs, sēdis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēiūnctās: having been separated, excluded; plural feminine accusative perfect passive participle from sēiungō, sēiungere, sēiūnxī, sēiūnctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="solēbant: they were accustomed to; 3rd person plural imperfect active from soleō, solēre, solitus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suāve: sweet; singular neuter accusative from suāvis, suāve, suāvior -or -us, suāvissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subācta: having been subjugated, conquered; singular feminine nominative perfect passive participle from subigō, subigere, subēgī, subāctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suscēpit: he undertook, he received; 3rd person singular perfect active from suscipiō, suscipere, suscēpī, susceptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tantō: so much, so great, this many; singular masculine dative from tantus, tanta, tantum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tellūs: earth, territory; singular feminine nominative from tellūs, tellūris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tum: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbem: city; singular feminine accusative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ut: so that"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="utrimque: both sides"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="utrius: either; singular genitive from uter, utra, utrum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vīcīnae: neighbors; plural feminine nominataive from vicinus, vicina, vicinum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vix: barely"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Wormatiam: Worms, Germany"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="12536.0496" OwnPage="29" ItemID="937850394" PTYPE="4" WIDTH="522" HEIGHT="383.479445859873" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 383.479 L0 383.479 L0 0 Z" copath="M0 0 L522 0 L522 383.479 L0 383.479 L0 0 Z" gXpos="136.0008" gYpos="12536.0496" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Chrīsticolae"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" vērō iam longō tempore Francī"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Catholicam tenuēre fidem, multīsque per orbem"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Iam dominābantur populīs, quibus undique fultī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Precipuē virtūte Deī, quem rīte colēbant,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hanc ūnam poterant nīmīrum vincere gentem."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Que nec rēge fuit saltem"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" sociāta sub ūnō,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ut sē mīlitiae pariter dēfenderet ūsū,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sed variīs dīvīsa modīs plēbs omnis, habēbat"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quot"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" pāgōs tot paene ducēs, velut ūnius artūs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Corporis in dīversa forent hinc inde revulsī."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sed generālis habet populōs dīvīsio ternōs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Īnsignīta"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" quibus Saxōnia flōruit ōlim."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nōmina nunc remanent"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=", virtūs antīqua recessit:"/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="12918.6118484076" OwnPage="29" ItemID="938698938" PTYPE="4" WIDTH="522" HEIGHT="205.452229299363" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 205.452 L0 205.452 L0 0 Z" copath="M0 0 L522 0 L522 205.452 L0 205.452 L0 0 Z" gXpos="136.0008" gYpos="12918.6118484076" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The Frankish Christ-worshippers, now for a long time, held the Catholic faith, and now were dominating many peoples throughout the world, whom (i.e. the Christians) were upheld on all sides, especially by the power of God, whom they worshipped with due observances, certainly was able to conquer this one people (the Saxons)."/>
                <ITEXT CH=" Note that the Poet here expresses a positive view of the relationship between rightly worshipping God and gaining political power."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And they were not, anyhow, associated under one king, that their militaries might defend themselves together in time of need."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="They had almost as many districts as dukes, as if the limbs of one body were wrenched away from here and from there."/>
                <ITEXT CH=" Here the Poet remarks that the Saxons lack of political unification left them weak. forent is in the subjunctive to express the hypothetical or illustrative nature of this clause."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="But generally the division has three peoples, by which the distinguished Saxons flourished once upon a time."/>
                <ITEXT CH=" The three divisions of the Saxons mentioned are Westphalia, Engria, and Eastphalia, see the next page."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit" CH="The names now remain, but the ancient virtue departed."/>
                <ITEXT CH=" This is an excellent line."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="12536.0496" OwnPage="30" ItemID="942842874" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="12536.0496" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="antīqua: ancient; singular feminine nominative from antīquus, antīqua -um, antīquior -or -us, antīquissimus -a -um"/>
