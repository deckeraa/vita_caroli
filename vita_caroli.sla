        <PAGEOBJECT XPOS="136.0008" YPOS="41656.1616" OwnPage="99" ItemID="1074371642" PTYPE="4" WIDTH="522" HEIGHT="320.084821656037" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 320.085 L0 320.085 L0 0 Z" copath="M0 0 L522 0 L522 320.085 L0 320.085 L0 0 Z" gXpos="136.0008" gYpos="41656.1616" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Tum quia praecipuō semper flagrābat amōre"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Petrī"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=", quī summe praeclārus apostolus exstat,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ipsīus Rōmae dēcrēvit līmina sāncta"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quaerere"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=", vōta precēsque Deō persolvere"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" cūrāns."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Atque citus properāns, assūmptā coniuge"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" sēcum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et nātīs, urbem pervēnerat ad Ticinēnsem,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="In quā nātālis Dominī fēstum celebrāvit."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hīc igitur statuī prīmae cum fīne decādis"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Annōrum Carolī, postquam rēx coeperat esse"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Francōrum sōlus, prīmum fīnīre libellum,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Vīribus"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" ut parvīs requiēs sōlātia praestet."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="41982.2464216561" OwnPage="99" ItemID="1074644458" PTYPE="4" WIDTH="522" HEIGHT="109.566878980848" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 109.567 L0 109.567 L0 0 Z" copath="M0 0 L522 0 L522 109.567 L0 109.567 L0 0 Z" gXpos="136.0008" gYpos="41982.2464216561" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Then because he always burned with special love for Peter, the famous apostle who was most prominent."/>
                <ITEXT CH=" The spelling of "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="exstat"/>
                <ITEXT CH=" is "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="extat"/>
                <ITEXT CH=" in the critical edition."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH="The critical text spells this "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="querere"/>
                <ITEXT CH=". However, "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="querere"/>
                <ITEXT CH=" is the singular imperative of "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="querī"/>
                <ITEXT CH=" (to complain or grumble) which fits neither grammatically nor contextually. Therefore I have corrected it to "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="quaerere"/>
                <ITEXT CH="."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Taking care to perform vows and prayers to God."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Coniuge"/>
                <ITEXT CH=" has a consonantal "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="i"/>
                <ITEXT CH=" and its syllables are long-short-short."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="So that rest might lend solace to my little strength."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="41656.1616" OwnPage="100" ItemID="1076366826" PTYPE="4" WIDTH="522" HEIGHT="720.000000000004" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="41656.1616" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
