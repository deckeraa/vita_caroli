                <ITEXT CH="nec nōn: and also"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: see nec nōn"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ōra: likely means the Ohre river, a left tributary to Elbe; singular feminine nominative"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pāgāna: pagan; singular feminine nominative from paganus, pagana, paganum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="paternās: paternal (fatherland); plural feminine accusative from paternus, paterna, paternum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pergēns: continuing on; singular nominative present participle from pergō, pergere, perrēxī, perrēctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prō: for, in favor of, before, in place of"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quā: in which; singular female ablative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quōs: whom; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēbus: things; plural feminine ablative from rēs, reī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="remeāre: to come back, return; present active infinitive from remeō, remeāre, remeāvī, remeātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēs: things; singular feminine accusative from rēs, reī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sānē: healthfully, soundly; adverb from sānus, sāna, sānum"/>
                <para PARENT="Vocab"/>
