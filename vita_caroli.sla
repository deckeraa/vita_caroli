                <ITEXT CH="quā: with which; singular female ablative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quō: in which; singular ablative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgis: of the king; singular masculine genitive from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="remissior: more relaxed, slack; singular common nominative from remissus, remissa -um, remissior -or -us, remississimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēs: thing, fortune; singular feminine nominative from rēs, reī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="resistere: to resist; active infinitive from resistō, resistere, restitī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnum: of the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēcūrōs: untroubled, carefree; plural masculine accusative from sēcūrus, sēcūra, sēcūrum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sedēre: to encamp, to sit; infinitive from sedeō, sedēre, sēdī, sessus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sōl: sun; singular masculine nominative from sōl, sōlis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="summō: highest, greatest; singular masculine ablative from summus, summa, summum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tendere: to draw (near); active infinitive from tendō, tendere, tetendī, tentus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="terrōrī: terror; singular masculine ablative from terror, terrōris"/>
