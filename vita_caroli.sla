                <ITEXT CH="lītore: beach, shore; singular neuter ablative from lītus, lītoris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="locāvit: he stationed; 3rd person singular perfect active from locō, locāre, locāvī, locātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="manet: it (the Slavic people) remains; 3rd person singular present active from maneō, manēre, mānsī, mānsus"/>
                <para PARENT="Vocab"/>
