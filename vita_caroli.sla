                <ITEXT CH="comperit: he discovered; 3rd person singular present active from comperiō, comperīre, comperī, compertus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnstituit: he appointed; 3rd person singular present active from cōnstituō, cōnstituere, cōnstituī, cōnstitūtus"/>
