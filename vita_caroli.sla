        <PAGEOBJECT XPOS="136.0008" YPOS="38328.1488" OwnPage="91" ItemID="1062781098" PTYPE="4" WIDTH="522" HEIGHT="352.606375796167" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 352.606 L0 352.606 L0 0 Z" copath="M0 0 L522 0 L522 352.606 L0 352.606 L0 0 Z" gXpos="136.0008" gYpos="38328.1488" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Annō 779"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Vēre"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" novō Carolus causā poscente peragrāns"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Gallōrum quondam terrās, ad Wirciniācum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Accessit vīcum. Quō tunc occurrit eīdem"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dux Spōlētānus"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=", Hildībrandus vocitātus."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quī pretiōsa"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" ferēns īnsignī mūnera rēgī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad sua"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" cum magnō satis est dīmissus honōre."/>
                <para PARENT="Latin"/>
                <ITEXT CH="At rēx intentē meditāns invādere terrās"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Saxōnum, citius Rhēnum trāiēcerat"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" amnem."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cui"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" sē spē vānā gēns ipsa resistere posse"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cōnfīdēns, pariter sūmptīs occurrerat armīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="In quōdam collēcta locō Bōcholt vocitātō."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="38684.7551757962" OwnPage="91" ItemID="1062954634" PTYPE="4" WIDTH="522" HEIGHT="187.108280254757" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 187.108 L0 187.108 L0 0 Z" copath="M0 0 L522 0 L522 187.108 L0 187.108 L0 0 Z" gXpos="136.0008" gYpos="38684.7551757962" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="With the new spring, Charlemagne, as circumstances demanded, traveling the lands, formerly of the Gauls, came to the town of Verzenay."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH="Hildeprand was the Duke of Spoleto from 774 to 789. The Duchy of Spoleto is located in Italy. There had been a dispute between Pope Hadrian I and Charlemagne over who had suzerainty over that duchy; this was likely the motivating factor for Hildeprand to go to France with treasure to meet with Charlemagne."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH="Spelled "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="preciōsa"/>
                <ITEXT CH=" in the critical text."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="To his (lands, places) he was dismissed with great honor."/>
                <ITEXT CH=" Here "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="sua"/>
                <ITEXT CH=" must be plural neuter accusative: it cannot be ablative based on the meter, and must be accusative since it is the object of "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="ad"/>
                <ITEXT CH=". What it refers to is implied; "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="loca"/>
                <ITEXT CH=" (places) a reasonable option."/>
                <para PARENT="footnotes"/>
                <ITEXT CH="5The "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="i"/>
                <ITEXT CH=" in "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="trāiēcerat"/>
                <ITEXT CH=" is consonantal, so its syllables are long-long-short-short."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="To whom, confident in themselves with vain hope to be able to resist, the people themselves, likewise having taken up arms, had run, collected into a certain place called Bocholt."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="38328.1488" OwnPage="92" ItemID="1065234170" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="38328.1488" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="accessit: he approached; 3rd person singular perfect active from accēdō, accēdere, accessī, accessus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="amnem: river; singular masculine accusative from amnis, amnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="annō: year; singular masculine ablative from annus, annī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="armīs: weapons; plural neuter ablative from armum, armī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="at: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Bocholt: Bocholt, a city in North Rhine-Westphalia"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolus: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="causā: cause, reason; singular feminine ablative from causa, causae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="citius: swifter; singular neuter accusative from citus, cita -um, citior -or -us, citissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="collēcta: having gathered; singular feminine nominative perfect passive participle from colligō, colligere, collēgī, collēctus"/>
                <para PARENT="Vocab"/>
