                <ITEXT CH="parvī: small; singular neuter genitive from parvus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="positīs: having been placed; plural ablative perfect passive participle from pōnō, pōnere, posuī, positus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pulvere: dust; singular masculine ablative from pulvis, pulveris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quō: what; singular ablative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quod: that; singular neuter accusative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rīvī: small streams; plural masculine nominative from rīvus, rīvī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rōbore: strength, stronghold; singular neuter ablative from rōbur, rōboris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="serēnō: serene; singular masculine ablative from serēnus, serēna, serēnum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sībī: to himself; singular dative of sē"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="similis: similar; singular common genitive from similis, simile, similior -or -us, simillimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simulācrum: image, likeness; singular neuter nominative from simulācrum, simulācrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="squālēbant: they were dry, rough, barren; 3rd person plural imperfect active from squāleō, squālēre, squāluī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="statuit: he decided; 3rd person singular present active from statuō, statuere, statuī, statūtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subdere: to place under, subdue; present active infinitive from subdō, subdere, subdidī, subditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tōtīs: whole, total; plural ablative from tōtus, tōta, tōtum (gen -ius)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tribus: three; plural ablative from trēs -es -ia, tertius -a -um, terni -ae -a, ter"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tum: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ūllus: any; singular masculine nominative from ūllus, ūlla, ūllum (gen -ius)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="valdē: very"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="validō: strong, healthy; singular masculine ablative from validus, valida, validum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vāstāvit: he ravaged, devastated; 3rd person singular perfect active from vāstō, vāstāre, vāstāvī, vāstātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vīribus: strength; plural feminine ablative from vis, viris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vocitābant: they called; 3rd person plural imperfect active from vocitō, vocitāre, vocitāvī, vocitātus"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="15032.0592" OwnPage="35" ItemID="952622554" PTYPE="4" WIDTH="522" HEIGHT="263.824133757963" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 263.824 L0 263.824 L0 0 Z" copath="M0 0 L522 0 L522 263.824 L0 263.824 L0 0 Z" gXpos="136.0008" gYpos="15032.0592" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Iamque fatīgābat graviter rēgālia castra"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Aucta"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" calōre sitis, sed vīs dedit omnipotentis,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cui placuit fānī subversiō"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" iūsta profānī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ut mediante diē subitō per concava siccī"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cuiusdam torrentis, erat quī proximus illīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sufficiēns exercituī prōrumperet unda."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hīs gestīs cum rēx Wisuram"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" vēnisset ad amnem,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Obsidibus bis sex ipsā dē gente receptīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad patriam rediit magnā cum prōsperitāte."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="15298.6349261147" OwnPage="35" ItemID="953400986" PTYPE="4" WIDTH="522" HEIGHT="135.745222929936" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 135.745 L0 135.745 L0 0 Z" copath="M0 0 L522 0 L522 135.745 L0 135.745 L0 0 Z" gXpos="136.0008" gYpos="15298.6349261147" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And now the increased thirst from the heat was fatiguing the royal encampment (Charlemagne's troops), but (God) gave of his omnipotent strength."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Whom the just subversion of the profane temple pleased."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="With these things having been done, the king came to the river Weser."/>
                <ITEXT CH=" The subjunctive "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="vēnisset"/>
                <ITEXT CH=" is used as part of a circumstantial clause. It appears that the story relates how Charlemagne's campaign was threatened by a drought, but that his troops miraculously received water, allowing them to prevail."/>
                <para PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="15032.0592" OwnPage="36" ItemID="956745658" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="15032.0592" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="amnem: river; singular masculine accusative from amnis, amnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aucta: increased; singular feminine nominative from auctus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="bis: twice"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="calōre: warmth, heat; singular masculine ablative from calor, calōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castra: forts; plural neuter accusative from castrum, castrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="concava: hollow, concave (likely a dry riverbed); singular feminine accusative from concavus, concava, concavum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cui: who; singular dative from quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cuiusdam: of a certain; genitive from quidam"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dē: of, from, away from, down from"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dedit: he gave; 3rd person singular perfect active from dō, dare, dedī, datus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="diē: day; singular common ablative from diēs, diēī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="erat: he was; 3rd person singular imperfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="exercituī: army; singular masculine dative from exercitus, exercitūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fānī: temple; singular neuter genitive from fānum, fānī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fatīgābat: it was wearying; 3rd person singular imperfect active from fatigo, fatigare, fatigavi, fatigatus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gente: people, clan, nation; singular feminine ablative from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gestīs: having been carried out; plural ablative perfect passive participle from gerō, gerere, gessī, gestus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="graviter: gravely, adverb from gravis, grave"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hīs: to these; plural masculine ablative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iamque: and already, and now"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīs: them; plural dative or ablative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipsā: itself; singular feminine ablative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iūsta: just, righteous; singular feminine nominative from jūstus, jūsta -um, jūstior -or -us, jūstissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="māgnā: large; singular feminine ablative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mediante: mid-day (in context), to be in the middle; singular ablative present participle from mediō, mediāre, mediāvī, mediātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obsidibus: hostages; plural common ablative from obses, obsidis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="omnipotentis: all-powerful; singular genitive from omnipotēns, (gen.), omnipotentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="patriam: father; singular feminine accusative from patria, patriae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="per: through"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="placuit: he pleased; 3rd person singular perfect active from placeō, placēre, placuī, placitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="profānī: profane; singular masculine genitive from profānus, profāna, profānum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prōrumperet: it was rushing forth; 3rd person singular imperfect active subjunctive from prōrumpō, prōrumpere, prōrūpī, prōruptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prosperitāte: success, prosperity; singular feminine ablative from prosperitās, prosperitātis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="proximus: neighbor; singular masculine nominative from proximus, proxima, proximum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="receptīs: having been received; plural ablative perfect passive participle from recipiō, recipere, recēpī, receptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rediit: he returned; 3rd person singular perfect active from redeō, redīre, redivī(iī), reditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgālia: regal, royal; plural neuter accusative from rēgālis, rēgālis, rēgāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sex: six"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="siccī: of a dry place; singular masculine genitive from siccus, sicca, siccum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sitis: thirst; singular feminine nominative from sitis, sitis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subitō: suddenly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subversiō: overthrow, destruction; singular feminine nominative from subversiō, subversiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sufficiēns: sufficing; singular nominative present participle from sufficiō, sufficere, suffēcī, suffectus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="torrentis: torrent, rushing stream; singular feminine genitive from torrēns, torrentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="unda: wave; singular feminine nominative from unda, undae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ut: so that"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēnisset: he had come; 3rd person singular pluperfect active subjunctive from veniō, venīre, vēnī, ventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vīs: strength; singular feminine genitive from vīs, vīs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Wisuram: the River Weser (accusative case)"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="15864.0624" OwnPage="37" ItemID="956996506" PTYPE="4" WIDTH="522" HEIGHT="468.254254777072" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 468.254 L0 468.254 L0 0 Z" copath="M0 0 L522 0 L522 468.254 L0 468.254 L0 0 Z" gXpos="136.0008" gYpos="15864.0624" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Annō 773"/>
                <para/>
                <ITEXT CH="Missīs lēgātīs, Adriānus pāpa sacrātus"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Auxilium Carolī studuit dēposcere magnī"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Adversus Langōbardōs, quōrum"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" fuit illō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tempore rēx Dēsīderius; nam valde premēbat"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Improba"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" Rōmānōs huius violentia gentis."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et quia tunc illī pars maxima subdita"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" rēgnō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ītaliae tōtīus erat, terrāsque per illās,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Scīlicet"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" hostīlēs, nōn quemquam mittere tūtē"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Rōmānus praesul potuit, quī trāmite rēctō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Francōrum terrās peteret, cōnscendere nāvem"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Fēcit apud Rōmam lēgātum nōmine Petrum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ut mare circuitū longō flūctūsque pererrāns"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Suspectum vītāret iter: sīc sēpe"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" vidētur"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tutior ōceanī fervor pelagīque procella,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quam mentēs hominum, quās turbida commovet īra."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="16340.3166547771" OwnPage="37" ItemID="957287802" PTYPE="4" WIDTH="522" HEIGHT="125.369426751592" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 125.369 L0 125.369 L0 0 Z" copath="M0 0 L522 0 L522 125.369 L0 125.369 L0 0 Z" gXpos="136.0008" gYpos="16340.3166547771" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Whose king at that time was Desidarius."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="For the evil violence of this people (the Lombards) greatly oppressed the Romans (the Papal states)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And becausue the greatest part of all Italy was controlled by that kingdom."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Really enemies, the Roman president (the Pope) couldn't safely send anyone who sought Frankish lands through a straight path."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Thus often the fervor of the ocean and the storms of the sea appear safer than the minds of men, which turbid anger moves."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="15864.0624" OwnPage="38" ItemID="959453578" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="15864.0624" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Adriānus: Pope Adrian I, who was Pope from February 1st 772 to December 25th 795"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="adversus: against; preposition that takes the accusative"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="annō: year; singular masculine ablative from annus, annī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="apud: at, by, near"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="auxilium: help, aid; singular neuter accusative from auxilium, auxiliī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolī: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="circuitū: circuit, outer shore; singular masculine ablative from circuitus, circuitūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="commovet: it agitates; 3rd person singular present active from commoveō, commovēre, commōvī, commōtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnscendere: to climb up, mount; present active infinitive from cōnscendō, cōnscendere, cōnscendī, cōnscēnsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēpōscere: to demand, require, challenge; present active infinitive from dēpōscō, dēpōscere, dēpopōscī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Dēsīderius: King Desiderius, final King of the Lombards (720-786)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="erat: he was; 3rd person singular imperfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēcit: he made; 3rd person singular perfect active from faciō, facere, fēcī, factus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fervor: boiling heat, passion; singular masculine nominative from fervor, fervōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="flūctūs: waves, billows, turbulences; plural masculine accusative from flūctus, flūctūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fuit: he was; 3rd person singular perfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gentis: of the people, clan, nation; singular feminine genitive from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hominum: of persons, of men; plural masculine genitive from homō, hominis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hostīlēs: enemies; plural common accusative from hostīlis, hostīlis, hostīle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="huius: of this; singular genitive of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illās: them; plural feminine accusative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illī: that; singular neuter dative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
