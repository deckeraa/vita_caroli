                <ITEXT CH="catholicam: Catholic; singular feminine accusative from catholicus, catholica, catholicum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Christicolae: Christian, worshiper of Christ; plural masculine nominative from Christicola, Christicolae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="colēbant: they were worshiping; 3rd person plural imperfect active from colō, colere, coluī, cultus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="corporis: body, flesh; singular neuter genitive from corpus, corporis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēfenderet: they might defend; 3rd person singular imperfect active subjunctive from dēfendō, dēfendere, dēfendī, dēfēnsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Deī: god, diety; singular masculine genitive from Deus, Dei"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīversa: diverse; singular feminine nominative from dīversus, dīversa, dīversum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīvīsa: having been divided; singular feminine nominative perfect passive participle from dīvidō, dīvidere, dīvīsī, dīvīsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīvīsio: division; singular feminine nominative from dīvīsiō, dīvīsiōnis. Typically there is a macron over the o but here it has to be a short syllable for metrical reasons."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dominābantur: they ruled; 3rd person plural imperfect active from dominor, dominārī, dominātus. The verb being the deponent dominārī and not domināre is clear from context. dominārī uses the dative instead of the accusative."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ducēs: leaders; plural masculine accusative from dux, ducis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fidem: faith; singular feminine accusative from fidēs, fideī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="flōruit: it blossomed, flourished; 3rd person singular perfect active from flōreō, flōrēre, flōruī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="forent: they were; 3rd person plural imperfect active subjunctive from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francī: the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fuit: he was; 3rd person singular perfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fultī: having been supported; singular masculine genitive perfect passive participle from fulciō, fulcīre, fulsī, fultus"/>
