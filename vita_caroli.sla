                <para PARENT="Vocab"/>
                <ITEXT CH="gēns: people, clan, nation; singular feminine nominative from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="grandis: great, grand, imposing; singular common nominative from grandis, grandis, grande"/>
                <para PARENT="Vocab"/>
