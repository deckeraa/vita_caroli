                <para PARENT="Vocab"/>
                <ITEXT CH="quōs: who; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="regiōne: region; singular feminine ablative from regiō, regiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="regiōnem: region; singular feminine accusative from regiō, regiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Rhēnō: the Rhine; singular masculine ablative from Rhēnus, Rhēnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnum: of the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Sclavī: Slavs, plural masculine nominative from Sclavus, Sclavī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sōlis: sun; singular masculine genitive from sōl, sōlis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sotiātur: it is joined; 3rd person singular present passive from a variant spelling of sociāre"/>
                <para PARENT="Vocab"/>
