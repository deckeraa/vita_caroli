        <PAGEOBJECT XPOS="136.0008" YPOS="32504.1264" OwnPage="77" ItemID="1038002250" PTYPE="4" WIDTH="522" HEIGHT="263.455401273877" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 263.455 L0 263.455 L0 0 Z" copath="M0 0 L522 0 L522 263.455 L0 263.455 L0 0 Z" gXpos="136.0008" gYpos="32504.1264" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Tunc Sarrācēnūs"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" quīdam pervēnerat illūc,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nōmine quī patriō dictus fuit Ībinalarbī"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH="."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hic cum nōn paucīs sociīs ac cīvibus, ipsum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quī comitābantur"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=", fīnēs regiōnis Hibērae"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Linquentem, Carolō sē dēdidit, ac simul urbēs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Rēx Sarrācēnūs quibus hunc praefēcerat ōlim."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ob hōc Saxonum tandem regiōne relictā,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Gallica rēgna petit"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH="; post haec Aquitānia"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" rēgem"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Īnsignem Carolum tenet ad paschālia fēsta."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="32767.5818012739" OwnPage="77" ItemID="1038355674" PTYPE="4" WIDTH="522" HEIGHT="188.484076433109" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 188.484 L0 188.484 L0 0 Z" copath="M0 0 L522 0 L522 188.484 L0 188.484 L0 0 Z" gXpos="136.0008" gYpos="32767.5818012739" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Then a certain Saracen arrived there."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Saracen"/>
                <ITEXT CH=" here means "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="muslim"/>
                <ITEXT CH="."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Who was called with his ancestral name Ībinalarbī."/>
                <ITEXT CH=" This is Sulayman ibn Yaqzan al-Kalbi al-Arabi, a muslim governor of Barcelona and Girona. Sulayman felt threatened by the Umayyad's and sought an alliance with Charlemagne, wich led to Charlegmagne's march across the Pyrenees the following year."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="This (man, the Saracene governor), with not a few of his allies and cities, who (plural) were allying with him, leaving the borders of the region of Spain, gave up to Charlemagne, and together the cities, which the Saracene king had formerly given to this one (the Saracene governor)."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="On account of this finally having left the Saxon region, he sought for the Gallic land. After this Aquintania holds the distinguished King Charlemange for the Paschal (Easter) Feast."/>
                <ITEXT CH=" Charlemagne needed to head west out of Saxony into Gallia in order to prepare for a march into Hispania."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH="Typically spelled "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Aquītānia"/>
                <ITEXT CH=" (with a macron over the first "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="i"/>
                <ITEXT CH="); I've omitted that macron so that it can fit the meter by being short-short-long-short-short."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="32504.1264" OwnPage="78" ItemID="1042001642" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="32504.1264" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ac: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Aquītānia: Aquitaniae, a province in western France; singular feminine nominative from Aquītānia, Aquītāniae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolō: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty (dative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolum: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty (accusative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cīvibus: citizens; plural common ablative from cīvis, cīvis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="comitābantur: they had allied; 3rd person plural imperfect from comitor, comitārī, comitātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēdidit: he surrendured, gave up; 3rd person singular perfect active from dedo, dedere, dedidi, deditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dictus: having been said; singular masculine nominative perfect passive participle from "/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēsta: festivals; plural neuter acccusative from fēstus, fēsta, fēstum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fīnēs: boundaries, limits; plural common accusative from fīnis, fīnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Gallica: Gallic; plural neuter acccusative from Gallicus, Gallica, Gallicum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="haec: these; plural neuter accusative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Hiberae: of Spain"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hic: this; singular masculine nominative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hōc: this; sing. masc. or neut. abl. of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hunc: this; singular masculine accusative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ībinalarbī: Sulayman ibn Yaqzan al-Kalbi al-Arabi, a muslim governor of Barcelona and Girona"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illūc: over there"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnsignem: distinguished; singular common accusative from īnsignis, īnsignis, īnsigne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipsum: himself; singular masculine acc. or neuter nom. or acc. from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="linquentem: leaving, abandoning; singular common accusative present participle from linquō, linquere, līquī, lictus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōmine: name; singular neuter ablative from nōmen, nōminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ob: for, because of, towards"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ōlim: one day, once upon a time"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Paschālia: Paschal (related to Easter); plural neuter nominative from paschālis, paschālis, paschāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="patriō: fatherly, ancestral; singular masculine ablative from patrius, patria, patrium"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="paucīs: few; plural masculine ablative from paucus, pauci"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pervēnerat: he had arrived; 3rd person singular pluperfect active from perveniō, pervenīre, pervēnī, perventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="petit: he sought; 3rd person singular present active from petō, petere, petīvī, petītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="post: behind, after, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praefēcerat: he had put in command; 3rd person singular pluperfect active from praeficiō, praeficere, praefēcī, praefectus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quibus: which; plural dative or ablative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgem: king; singular masculine accusative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="regiōne: region; singular feminine ablative from regiō, regiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="regiōnis: regions; singular feminine genitive from regiō, regiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgna: kingdoms; plural neuter accusative from rēgnum, rēgnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="relictā: having been left behind; singular feminine ablative perfect passive participle from relinquo, relinquere, reliqui, relictus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Sarrācēnūs: a muslim"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnum: of the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="se: himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simul: at the same time as"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sociīs: associates, companions; plural masculine ablative from socius, sociī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tandem: finally"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tenet: it holds; 3rd person singular present active from teneō, tenēre, tenuī, tentus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tunc: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbēs: cities; plural feminine accusative from urbs, urbis"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="33336.1296" OwnPage="79" ItemID="1042179818" PTYPE="4" WIDTH="522" HEIGHT="441.286796178338" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 441.287 L0 441.287 L0 0 Z" copath="M0 0 L522 0 L522 441.287 L0 441.287 L0 0 Z" gXpos="136.0008" gYpos="33336.1296" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Hortātū Sarrācēnī cum sē memorātī"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hispānās urbēs quāsdam sibi subdere posse"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Haud frūstrā spērāret, eō sua maxima coepit"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Agmina per celsōs Wascōnum dūcere montēs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quī cum prīmā Pyreneī iuga iam superāsset,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad Pompēlōnem, quod fertur nōbile castrum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Esse Navarrōrum, veniēns id coeperat armīs;"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Trāiciēnsque vadō fāmōsum flūmen Hibērum,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Caesāris"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" Augustī quandam dē nōmine dictam"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Urbem praecipuam terrīs penetrāvit in illīs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Acceptīs tamen obsidibus, quōs Ībinalarbī"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Iam dictus pariterque"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" suā dē gente fidēlēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Illūstrēsque virī dederant, sīc inde recessit."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ac Pompēlōnem rediēns, dēiēcerat"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" eius"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad terram mūrōs, fieret nē forte rebellis."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="33777.4163961783" OwnPage="79" ItemID="1042882346" PTYPE="4" WIDTH="522" HEIGHT="176.560509554187" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 176.561 L0 176.561 L0 0 Z" copath="M0 0 L522 0 L522 176.561 L0 176.561 L0 0 Z" gXpos="136.0008" gYpos="33777.4163961783" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="With the exhortation of the aforesaid Saracen, he hoped not in vain to be able to subdue to himself certain Spanish cities."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit" CH="He entered in those lands a certain city named after Caesar Augustus."/>
                <ITEXT CH=" The city is modern-day Zaragoza, which was called Caesaraugusta prior to the muslim invasion. The name Zaragoza derives from the second and following syllabes of Caesaraugusta. In the critical text the word is spelled "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Cesaris"/>
                <ITEXT CH=". Zaragoza lies by the Ebro river. The scansion on this line is difficult; my best solution is that "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Caesāris"/>
                <ITEXT CH=" be scanned as a dactyl, which makes everything else fall into place."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="However having received hostages, which the already mentioned Sulayman, together with faithful and illustrious (men) from his own people, had given."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And returning to Pamplona, he had thrown to the ground its walls, that there might not be rebellion."/>
                <ITEXT FONT="DejaVu Serif Book" CH=" The "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="i"/>
                <ITEXT FONT="DejaVu Serif Book" CH=" in "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="dēiēcerat"/>
                <ITEXT FONT="DejaVu Serif Book" CH=" is consonantal, so its syllables are long-long-short-short."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="33336.1296" OwnPage="80" ItemID="1044841994" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="33336.1296" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ac: and"/>
                <para PARENT="Vocab"/>
