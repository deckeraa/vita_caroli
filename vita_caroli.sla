                <para PARENT="Vocab"/>
                <ITEXT CH="veniam: indulgence, kindness; singular feminine accusative from venia, veniae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="veniēns: coming; singular nominative present participle from veniō, venīre, vēnī, ventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="veritus: having feared; singular masculine nominative perfect participle from vereor, verērī, veritus sum"/>
                <para PARENT="Vocab"/>
