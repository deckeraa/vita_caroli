                <ITEXT CH="quōs: whom; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="redeuntēs: returning; plural common nominative present participle from redeō, redīre, redivī(iī), reditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="regressus: having returned; singular masculine nominative perfect participle from regredior, regredī, regressus sum"/>
