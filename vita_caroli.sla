                <para PARENT="Vocab"/>
                <ITEXT CH="violāre: to violate; present active infinitive from violō, violāre, violāvī, violātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Widokindus: a Saxon, likely a senator, who fled from Charlemagne, seeking refuge in the court of Sifrīdus"/>
