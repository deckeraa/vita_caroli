                <ITEXT CH="īnfēstant: they make dangerous, infest; 3rd person plural present active from īnfēstō, īnfēstāre, īnfēstāvī, īnfēstātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="inhabitābant: they inhabited; 3rd person plural imperfect active from inhabitō, inhabitāre, inhabitāvī, inhabitātus"/>
                <para PARENT="Vocab"/>
