        <PAGEOBJECT XPOS="136.0008" YPOS="30008.1168" OwnPage="71" ItemID="1026831466" PTYPE="4" WIDTH="522" HEIGHT="349.528095541395" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 349.528 L0 349.528 L0 0 Z" copath="M0 0 L522 0 L522 349.528 L0 349.528 L0 0 Z" gXpos="136.0008" gYpos="30008.1168" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Annō 777"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Aspīrante"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" novī placidō cum tempore vēris"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Horrida iam trānsīsset hiems, rēx Nōviomāgum"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Adveniēns, celebrāvit ibī sollempnia Paschae."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tum quia Saxonēs suspectōs semper habēbat,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Haud dubitāns, illōs prō lībertāte tenenda"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Artibus āctūrōs variīs quodcumque valērent,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et nisi continuī premerentur"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" pondere bellī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Foedera ruptūrōs"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=", sēcum condicta frequenter,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Rūrsus in illōrum patriam fortissima dūcit"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Agmina: conventum placitī generālis habēre"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cum ducibus sē velle suīs dēnunciat illīc."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="30364.1862968153" OwnPage="71" ItemID="1027721450" PTYPE="4" WIDTH="522" HEIGHT="217.337579617837" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 217.338 L0 217.338 L0 0 Z" copath="M0 0 L522 0 L522 217.338 L0 217.338 L0 0 Z" gXpos="136.0008" gYpos="30364.1862968153" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="When the calm season of new spring breathing."/>
                <ITEXT CH=" A more idiomatic, though less strict, English translation might be: "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="With the new season breathing the pleasant springtime breezes."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The king (Charlemagne) arriving at Nōviomāgus."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Not doubting, them for the holding of liberty to act with various arts, whatever they could."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And unless pressed down by the weight of continuous war."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Would break treaties."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="30008.1168" OwnPage="72" ItemID="1031980154" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="30008.1168" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="āctūrōs: to be conducted/done; plural masculine accusative future participle from agō, agere, ēgī, āctus"/>
