                <ITEXT CH="Hiberum: the Ebro River, which flows through Zaragoza (accusative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Hispānās: Spanish, of Spain; plural feminine accusative from Hispanus, Hispana, Hispanum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hortātū: encouragement, exhortation; singular neuter ablative from hortor, hortārī, hortātus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iam: already, now, soon"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ībinalarbī: Sulayman ibn Yaqzan al-Kalbi al-Arabi, a muslim governor of Barcelona and Girona"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="id: it (the castle in Pamplona)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīs: those; plural ablative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illūstrēs: illustrious; plural masculine nominative from illūstris, illūstre"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="inde: from there, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iuga: peaks, mountain ridges; plural neuter nominative from iugum, iugī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="maxima: very large; plural neuter accusative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="memorātī: aforementioned, having been remembered; singular masculine genitive perfect passive participle from memorō, memorāre, memorāvī, memorātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="montēs: mountains; plural masculine accusative from mōns, montis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mūrōs: city wall; plural masculine accusative from mūrus, mūrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Navarrōrum: of the Kingdom of Navarre, a Basque kingdom"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nē: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōbile: noble, famous; singular neuter nominative from nobilis, nobile, nobilior -or -us, nobilissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōmine: name; singular neuter ablative from nōmen, nōminis"/>
                <para PARENT="Vocab"/>
