                <para PARENT="Vocab"/>
                <ITEXT CH="quās: who; plural female accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sexūs: sex (male or female); singular masculine genitive from sexus, sexūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="studiō: eagerness; singular neuter ablative from studium, studiī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trādiderant: they had handed over; 3rd person plural pluperfect active from trādō, trādere, trādidī, trāditus"/>
                <para PARENT="Vocab"/>
