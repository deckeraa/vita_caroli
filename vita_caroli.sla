                <para PARENT="Vocab"/>
                <ITEXT CH="decōris: elegance, beauty; singular masculine genitive from decus, decōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="diēbus: days; plural common ablative from diēs, diēī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="diū: for a long time (adverb)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eadem: the same, singular feminine nominative"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="erat: he was; 3rd person singular imperfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ērēsburg: a Saxon refuge castle near modern-day Obermarsberg"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="evertens: overthrowing, destroying; singular nominative present participle from ēvertō, ēvertere, ēvertī, ēversus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="factūra: making, manufacture, creation; singular feminine nominative from factūra, factūrae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ferrō: iron; singular neuter ablative from ferrum, ferrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fervōre: boiling heat; singular masculine ablative from fervor, fervōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fīrmātum: having been hardened, confirmed; singular neuter nominative perfect passive participle from fīrmō, fīrmāre, fīrmāvī, fīrmātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fontibus: fountains; plural masculine ablative from fōns, fontis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="forte: strong; singular neuter accusative from fortis, fortis, forte"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fuerat: he had been; 3rd person singular pluperfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gēns: people, clan, nation; singular feminine nominative from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gentem: people, clan, nation; singular feminine accusative from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hanc: this; singular feminine accusative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hoc: this; singular neuter accusative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hūmor: liquid, fluid; singular masculine nominative from hūmor, hūmōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="igitur: therefore"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īgnī: fire; singular masculine ablative from īgnis, īgnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipsam: itself; singular feminine accusative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipse: itself; singular masculine nominative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipsīs: itself; plural dative or ablative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Irminsul: the name of an idol, or type of idol that the Saxons worshipped"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iuxtā: near, nearly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="lātē: widely; adverb from lātus, -a, -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="lingua: tongue, language; singular feminine nominative from lingua, linguae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mānsit: he remained; 3rd person singular perfect active from maneō, manēre, mānsī, mānsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="manū: hand; singular feminine ablative from manus, manūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mora: delay; singular feminine nominative from mora, morae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="multō: many; singular masculine ablative from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mūnīmine: defence, fortification, rampart; singular neuter ablative from mūnīmen, mūnīminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nātūrālī: natural; singular neuter ablative from nātūrālis, nātūrālis, nātūrāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nec: nor, not either"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōminat: it names; 3rd person singular present active from nōminō, nōmināre, nōmināvī, nōminātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="operis: of work; singular neuter genitive from opus, operis"/>
                <para PARENT="Vocab"/>
