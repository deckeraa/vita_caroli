        <PAGEOBJECT XPOS="136.0008" YPOS="16696.0656" OwnPage="39" ItemID="959861450" PTYPE="4" WIDTH="522" HEIGHT="441" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 441 L0 441 L0 0 Z" copath="M0 0 L522 0 L522 441 L0 441 L0 0 Z" gXpos="136.0008" gYpos="16696.0656" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Hīc igitur Petrus Rōmā dīrēctus"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" ab urbe,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Per mare Massiliam petiit, longumque deinde"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Per terrēnum"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" iter, in vīllā Theodōne vocātā"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Īnsignis Carolī pietātem rēgis adīvit,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ōrāns dēvōtē satis, ut dēfendere vellet"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ecclesiam Petrī, summus quī clāviger"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" aulae"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Illī celēstis dare praemia maxima posset;"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nec nōn pontificis succurreret ānxietātī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Rōmānīque simul populī mala plūrima passī"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=","/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cui lībertātis iam spēs, vītaeque tenendae"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ūnica"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" post Dominum, tantum restāret in illō."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tālibus audītis, causam rēx prōtinus omnem"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sollicitō volvēns animō, satis affore iūstum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Perpendit, grātumque Deō, dēfēnsor ut ipse"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sēdis apostolicae tōtīs prō vīribus esset."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="17137.0656" OwnPage="39" ItemID="960193242" PTYPE="4" WIDTH="522" HEIGHT="156.840764331209" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 156.841 L0 156.841 L0 0 Z" copath="M0 0 L522 0 L522 156.841 L0 156.841 L0 0 Z" gXpos="136.0008" gYpos="17137.0656" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Here, therefore, Peter having been directed from the city of Rome, sought Marseille through the sea."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And thereafter a long trip over land."/>
                <ITEXT CH=" The -um in terrēnum elides for scansion."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Pleading devoutly enough that he (Charlemagne) might defend the Church of Peter."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Who, highest key-bearer in the caelestial court, could give to him (Charlemagne) the greatest reward."/>
                <ITEXT CH=" Here Peter, the Papal legate, promises Charlemagne spiritual rewards for his military support of the Papal States against the Lombards."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And also that he might aid the anxiety of the Pope and the many evils suffered by the Roman people."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="To whom now liberty, hope, and the keeping of (their) lives, alone after the Lord (God), lay only in him."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="16696.0656" OwnPage="40" ItemID="963800106" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="16696.0656" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ab: from, out of, by, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="adīvit: he besought, approached, visited; 3rd person singular perfect active from adeō, adīre, adivī, aditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="affore: to be (in the future) future infinitive from adsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="animō: soul, mind, live; singular masculine ablative from animus, animi"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ānxietātī: anxiety; singular feminine dative ānxietās, ānxietātis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="apostolicae: of the apostolic; singular feminine genitive from apostolicus, apostolica, apostolicum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="audītīs: having been heard; plural ablative from audiō, audīre, audīvī, audītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aulae: court; singular feminine genitive from aula, aulae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolī: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="causam: cause; singular feminine accusative from causa, causae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="celestis: heavenly; singular common genitive from celestis, celeste, celestior -or -us, celestissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="clāviger: key-bearer; singular masculine nominative from clāviger, clāvigerī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cui: who; singular dative from quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dare: to give; present active infinitive from dō, dare, dedī, datus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēfendere: to defend; present infinitive from dēfendō, dēfendere, dēfendī, dēfēnsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēfēnsor: defender, protector; singular masculine nominative from dēfēnsor, dēfēnsōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="deinde: thereafter"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Deō: to God; singular masculine dative from Deus, Dei"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēvōtē: devotedly; adverb from dēvōtus, dēvōta, dēvōtum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīrēctus: having been directed; singular masculine nominative perfect passive participle from dīrigō, dīrigere, dīrēxī, dīrēctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Dominum: the Lord; singular masculine accusative from dominus, dominī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ecclēsiam: church; singular feminine accusative from ecclēsia, ecclēsiae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="esset: he (might) have been; 3rd person singular imperfect active subjunctive from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fore: to be (in the future); future infinitive of sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="grātum: agreeable; singular neuter accusative from grātus, grāta -um, grātior -or -us, grātissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hīc: here. Hic (meaning 'this') would fit better in context but wouldn't fit the meter."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iam: already, now"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="igitur: therefore"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illī: to that one (Charlemagne); singular dative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illō: in that one (Charlemagne); singular masculine ablative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnsignis: distinguished; singular common genitive from īnsignis, īnsignis, īnsigne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipse: himself; singular masculine nominative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iter: journey, trip; singular neuter accusative from iter, itineris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iūstum: just, righteous; singular neuter accusative from iūstus, iūsta -um, iūstior -or -us, iūstissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="lībertātis: of liberty; singular feminine genitive from lībertās, lībertātis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="longum: long, far; singular neuter accusative from longus, longa -um, longior -or -us, longissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mala: evil, bad"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mare: sea; singular neuter accusative from mare, maris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Massiliam: Marseille, a city in southern France (accusative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="maxima: very big; plural neuter accusative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nec: nec non = and also"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="omnem: all, every; singular common accusative from omnis, omnis, omne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ōrāns: requesting, praying; singular nominative present participle from ōrō, ōrāre, ōrāvī, ōrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="passī: passī + est = they suffered. Est is omitted for metrical reasons."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="per: through"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="perpendit: he decided, he weighed carefully; 3rd person singular present active from perpendō, perpendere, perpendī, perpēnsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="petiit: he sought for; 3rd person singular perfect active from petō, petere, petīvī, petītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Petri: Peter; singular masculine genitive from Petrus, Petri"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Petrus: Peter; singular masculine nominative from Petrus, Petri"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pietātem: dutiful conduct, piety; singular feminine accusative from pietās, pietātis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plūrima: very many; plural neuter accusative from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pontificis: of the Pope; singular masculine genitive from pontifex, pontificis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populī: the (Roman) people; plural masculine nominative from populus, populī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="posset: that he could; 3rd person singular imperfect active subjunctive from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="post: behind, after, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praemia: rewards; plural neuter accusative from praemium, praemi(i)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prō: for, in favor of, before, in place of"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prōtinus: forthwith, immediately"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; singular masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgis: of the king; singular masculine genitive from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="restāret: it remained; 3rd person singular imperfect active subjunctive from restō, restāre, restitī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Rōmā: Rome; singular feminine ablative from Rōma, Rōmae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Rōmānīque: and the Romans"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="satis: enough (adverb)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēdis: seat; singular feminine genitive from sēdēs, sēdis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simul: at the same time as"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sollicitō: agitated, restless, anxious; singular masculine ablative from sollicitus, sollicita, sollicitum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="spēs: hope; singular feminine nominative from spēs, speī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="succurreret: he might bring aid; 3rd person singular imperfect active subjunctive from succurro, succurrere, succucurri, succursus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="summus: highest, greatest; singular masculine nominative from summus, summa, summum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tālibus: such (things); plural ablative from tālis, tālis, tāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tantum: so much, so great, this many; singular neuter nominative from tantus, tanta, tantum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tenendae: holding; singular feminine genitive gerund from teneō, tenēre, tenuī, tentus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="terrēnum: land, ground; singular neuter accusative from terrenus, terrena, terrenum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tōtīs: whole, total; plural ablative from tōtus, tōta, tōtum (gen -ius)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="unica: only, sole; singular feminine nominative from ūnicus, ūnica, ūnicum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Theodōne: the name of a villa that Charlemagne was in"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbe: city; singular feminine ablative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ut: so that"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vellet: that he would want; 3rd person singular future active from vello, vellere, velli, vulsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vīllā: villa; singular feminine ablative from vīlla, vīllae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vīribus: strength; plural feminine ablative from vis, viris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vītae: life; singular feminine genitive from vīta, vītae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vocātā: having been called; singular feminine ablative perfect passive participle from vocō, vocāre, vocāvī, vocātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="volvēns: rolling, mulling; singular nominative present participle from volvo, volvere, volvi, volutus"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="17528.0688" OwnPage="41" ItemID="964186602" PTYPE="4" WIDTH="522" HEIGHT="359.356535031849" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 359.357 L0 359.357 L0 0 Z" copath="M0 0 L522 0 L522 359.357 L0 359.357 L0 0 Z" gXpos="136.0008" gYpos="17528.0688" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Atque suō statim rēgnō collēgit ab omnī"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Rōboris inmēnsī variīs ex gentibus agmen."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quod sēcum dūcēns, Genuam pervēnit in urbem,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quam"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" rapidō cursū Rhodanus praeterfluit amnis;"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tum geminō"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" Langōbardōs invādere bellō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dēcrēvit, populumque suum dīvīsit, et ūnam"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cum duce Bernhardō partem praecēperat īre"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Per montem Iovis—id nōmen vetus indidit"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" error—"/>
                <para PARENT="Latin"/>
                <ITEXT CH="At reliquam per Cīnisium rēx dūxerat ipse."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Trānscēnsīs igitur horrendīs Alpibus, īnstar"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Turbinis Ausoniae duplex exercitus arva"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Irruerat, lātē rēgnum vastāns opulentum."/>
                <trail PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="17887.4253350319" OwnPage="41" ItemID="964642506" PTYPE="4" WIDTH="522" HEIGHT="127.490445859872" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 127.49 L0 127.49 L0 0 Z" copath="M0 0 L522 0 L522 127.49 L0 127.49 L0 0 Z" gXpos="136.0008" gYpos="17887.4253350319" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Which the Rhone river flows past with rapid course."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Then he decided to invade the Lombards with two-fold war."/>
                <ITEXT CH=" Charlemagne split his troops into two parts."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="With Bernard (son of Charles Martel and uncle of Charlemagne) he had commanded (one) party to go through Mount Jove -- an ancient error bestowed that name."/>
                <ITEXT CH=" Bernard likely went through the Great St. Bernard Pass in the Alps. Perhaps the &quot;ancient error&quot; mentioned was the pagan belief in Jupiter/Jove. The Bernard mentioned is not the same Bernard as Saint Bernard of Clairvaux, who lived 1090-1153."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Like a whirlwind of Ausonia the double army had rushed into the fields, widely ravaging the opulent kingdom."/>
                <ITEXT CH=" Ausonia is a poetic name for Italy."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="17528.0688" OwnPage="42" ItemID="968459898" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="17528.0688" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ab: from, out of, by, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agmen: marching army; singular neuter accusative from agmen, agminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Alpibus: Alps (usually pl.), mountains to the north of Italy; plural feminine ablative from Alpis, Alpis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="amnis: river; singular masculine nominative from amnis, amnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="arva: fields; plural neuter accusative from arvum, arvī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="at: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="atque: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ausoniae: of Ausonia, a poetic name for Italy"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="bellō: battle, war; singular neuter ablative from bellum, bellī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Bernhardō: Bernard, son of Charles Martel and uncle of Charlemagne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Cīnisium: probably a city or region in the Lombard Kingdom, perhaps the city of Cassino"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="collēgit: he assembled, he collected; 3rd person singular perfect active from colligō, colligere, collēgī, collēctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cursū: course; singular neuter ablative from currō, currere, cucurrī, cursus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēcrēvit: he decided; 3rd person singular perfect active from dēcernō, dēcernere, dēcrēvī, dēcrētus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīvīsit: he divided; 3rd person singular perfect active from dīvidō, dīvidere, dīvīsī, dīvīsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="duce: leader; singular masculine ablative from dux, ducis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dūcēns: leading; singular nominative present participle from dūcō, dūcere, dūxī, ductus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="duplex: double; singular  nominative from duplex, (gen.), duplicis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dūxerat: he had read: 3rd person singular pluperfect from dūcō, dūcere, dūxī, ductus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="error: error, wandering, deception; 1st person singular present passive from errō, errāre, errāvī, errātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ex: out of, from"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="exercitus: army; singular masculine nominative from exercitus, exercitūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="geminō: double; singular masculine ablative from geminus, gemina, geminum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gentibus: peoples, clans, nations; plural feminine ablative from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Genuam: Genua, modern-day Genoa, Italy"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="horrendīs: horrendous; plural ablative from horrendus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="id: it"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="igitur: therefore"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="indidit: it named after; 3rd person singular perfect active from  indō, indere, indidī, inditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="inmēnsī: of immense; singular masculine genitive from inmēnsus, inmēnsa, inmēnsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnstar: as big as"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="invādere: to invade; present infinitive from invādō, invādere, invāsī, invāsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Iovis: Jovis, Jupiter"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipse: himself; singular masculine nominative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īre: to go; present infinitive from eō, īre, iī, itus (irregular)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="irruerat: it had forced its way in; 3rd person singular pluperfect active from irruō, irruere, irruī, irrutus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Langōbardōs: the Lombards (plural accusative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="lātē: widely; adverb from lātus, -a, -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="montem: mountain; singular masculine accusative from mōns, montis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōmen: name; singular neuter accusative from nōmen, nōminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="omnī: all, every; singular ablative from omnis, omnis, omne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="opulentum: rich; singular masculine accusative from opulentus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="partem: party, part; singular feminine accusative from pars, partis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="per: through"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pervēnit: he arrived; 3rd person singular present active from perveniō, pervenīre, pervēnī, perventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populum: people, populace; singular masculine accusative from populus, populī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praeceperat: he had ordered; 3rd person singular pluperfect active from praecipiō, praecipere, praecēpī, praeceptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praeterfluit: it flows past; 3rd person singular present active from praeterfluo, praeterfluere, -, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quam: how? how much?"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quod: what; singular neuter nom. or acc. of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rapidō: quick, rapid; singular masculine ablative from rapidus, rapida -um, rapidior -or -us, rapidissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgnō: kingdom; singular neuter ablative from rēgnum, rēgnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgnum: kingdom; singular neuter nominative from rēgnum, rēgnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="reliquam: remaining; singular feminine accusative from reliquus, reliqua, reliquum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Rhodanus: the Rhone; singular masculine nominative from Rhodanus, Rhodanī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rōboris: strength; singular neuter genitive from rōbur, rōboris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēcum: with oneself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="statim: immediately"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suō: his; singular ablative of suus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suum: his; singular masculine accusative from suus, sui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trānscēnsīs: having been passed over; plural ablative perfect passive participle from trānscendō, trānscendere, trānscendī, trānscēnsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tum: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="turbinis: whirlwind; singular masculine genitive from turbō, turbinis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ūnam: one; singular feminine accusative from ūnus -a -um, prīmus -a -um, singulī -ae -a, semel"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbem: city; singular feminine accusative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="variīs: various, diverse; plural ablative from varius, varia, varium"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vāstāns: ravaging, devastating; singular nominative present participle from vāstō, vāstāre, vāstāvī, vāstātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vetus: old; singular nominative from vetus, veteris (gen.), veterior -or -us, veterrimus -a -um"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="18360.072" OwnPage="43" ItemID="968788074" PTYPE="4" WIDTH="522" HEIGHT="262.945891719746" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 262.946 L0 262.946 L0 0 Z" copath="M0 0 L522 0 L522 262.946 L0 262.946 L0 0 Z" gXpos="136.0008" gYpos="18360.072" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Iamque metus cūnctōs Francōrum perculit ingēns."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nam Dēsīderium, prīmō quī bella parābat,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sē frūstrā Carolō spērāns"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" obsistere posse,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Congressū necdum factō, terrōre fugāvit,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et clausum Ticinō, cui nunc est Pāpia nōmen,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Rēgius admōtīs exercitus"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" undique castrīs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Obsēdit, variīsque modīs per plūrima temptāns"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Temporis hībernī spatiō mōlīmina tōtō,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nōn urbis poterat mūrōs irrumpere ferrō."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="18360.072" OwnPage="44" ItemID="969268378" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="18360.072" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="admōtīs: having been moved up, brought near; plural ablative perfect passive participle from admoveō, admovēre, admōvī, admōtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="bella: battles, wars; plural neuter accusative from bellum, bellī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolō: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castrīs: camps; plural neuter ablative from castrum, castrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="clausum: having been enclosed, shut up; singular neuter accusative perfect passive participle from claudō, claudere, clausī, clausus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="congressū: meeting; singular masculine ablative from congressus, congressūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cui: who; singular dative from quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cūnctōs: all, whole; plural masculine accusative from cūnctus, cūncta, cūnctum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Dēsīderium: Desiderius, final King of the Lombards (720-786)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="est: he is; 3rd person singular present active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="exercitus: army; singular masculine nominative from exercitus, exercitūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="factō: having been made; singular masculine ablative perfect passive participle from faciō, facere, fēcī, factus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ferrō: iron; singular neuter ablative from ferrum, ferrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="frūstrā: futile (adverb)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fugāvit: he routed, chased away; 3rd person singular perfect active from fugō, fugāre, fugāvī, fugātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hībernī: winter, winter camp; singular masculine genitive from hibernus, hiberna, hibernum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iam: already, now, soon"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ingēns: huge, enormous; singular nominative from ingēns, ingentis (gen.), ingentior -or -us, ingentissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="irrumpere: to invade, penetrate; present infinitive from irrumpō, irrumpere, irrūpī, irruptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="metus: fear; singular masculine nominative from metus, metūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="modīs: ways; plural masculine ablative from modus, modī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mōlīmina: exertions, efforts; plural neuter accusative from mōlīmen, mōlīminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mūrōs: city walls; plural masculine accusative from mūrus, mūrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nam: yes, truly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="necdum: not yet"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōmen: name; singular neuter nominative from nōmen, nōminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nunc: now"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obsēdit: he besieged; 3rd person singular perfect active from obsideō, obsidēre, obsēdī, obsessus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obsistere: to oppose, resist, withstand; present infinitive from obsistō, obsistere, obstitī, obstitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Papia: Pavia a.k.a. Ticinum, capital of the Kingdom of the Lombards from 572 to 774."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="parābat: he was preparing; 3rd person singular imperfect active from parō, parāre, parāvī, parātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="per: through"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="perculit: it struck down, overpowered; 3rd person singular perfect active from percellō, percellere, perculī, perculsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plūrima: very many; plural neuter accusative from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="posse: to be able; present infinitive from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="poterat: he was able to; 3rd person singular imperfect active from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prīmō: first; singular masculine ablative from prīmus, prīma, prīmum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgius: royal, regal; singular masculine nominative from rēgius, rēgia, rēgium"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="se: himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="spatiō: space; singular neuter ablative from spatium, spati(i)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="spērāns: hoping; singular nominative present participle from spērō, spērāre, spērāvī, spērātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="temporis: of the time; singular neuter genitive from tempus, temporis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="temptāns: trying; singular nominative present participle from temptō, temptāre, temptāvī, temptātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="terrōre: terror; singular masculine ablative from terror, terrōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tōtō: whole, total; singular ablative from tōtus, tōta, tōtum (gen -ius)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="undique: from all sides"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ticinō: Pavia a.k.a. Ticinum, capital of the Kingdom of the Lombards from 572 to 774."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbis: city; singular feminine genitive from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="variīs: various, diverse; plural ablative from varius, varia, varium"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="19192.0752" OwnPage="45" ItemID="971995290" PTYPE="4" WIDTH="522" HEIGHT="469.210407643313" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 469.21 L0 469.21 L0 0 Z" copath="M0 0 L522 0 L522 469.21 L0 469.21 L0 0 Z" gXpos="136.0008" gYpos="19192.0752" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Annō 774"/>
                <ITEXT CH="."/>
                <para/>
                <ITEXT CH="Tālēs Ītalicīs dum rēs agerentur in hōrīs"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=","/>
                <para PARENT="Latin"/>
                <ITEXT CH="Saxonēs sibi contiguōs invādere fīnēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ausī"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" Francōrum, pāgum quī dīcitur Hassī"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Praedantur, flammīsque simul populantur et armīs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quōs animāvit ad hoc longinqua profectio"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" rēgis,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Crēdentēs ulciscendī sībī tunc fore"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" tempus"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Damna, prius per eum que maxima sustinuēre."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quī tamen usque locum quī Frīdēshlar vocitātur"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Prōgressī, quandam cupiērunt trādere flammīs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ecclesiam, quam sacrāvit Bonifācius"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" illīc"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Martir et antistes Chrīstō dīlēctus in aevum."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hoc frūstrā nīsōs"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" facinus complēre nefandum,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Invāsit subitō terror dīvīnitus ingēns,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Atque fugā turpī trepidōs repedāre coēgit"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad patriam, quōs nōn hostēs, nōn arma fugārunt."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="20024.0784" OwnPage="47" ItemID="972241578" PTYPE="4" WIDTH="522" HEIGHT="470.939891719745" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 470.94 L0 470.94 L0 0 Z" copath="M0 0 L522 0 L522 470.94 L0 470.94 L0 0 Z" gXpos="136.0008" gYpos="20024.0784" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="At rēx, dispositīs legiōnibus ad Ticinēnsum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Obsidiōne"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" iūgī populum bellōque premendum,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ōrandī"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" causā Rōmae loca sāncta petīvit."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Illīc supplicibus vōtīs ex corde perāctīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad Ticinum rediit, que iam certāmine longō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Fessa"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" repugnandī vīrēs āmīserat omnēs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dēdita"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" tum Francīs haec urbs clārissima, cūnctīs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Exemplō fuerat reliquīs; nam prōtinus"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" omnēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Trādiderant Carolō sēsē concorditer urbēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Eiusdem rēgnī, quod iam"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" sībī iūre subāctum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Disposuit, quantum"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT CH=" potuit prō tempore tālī"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad sēdēs etenim"/>
                <ITEXT FEATURES="inherit superscript" CH="8"/>
                <ITEXT CH=" cupiēns remeāre paternās,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Accelerābat iter, sēcum dūcēns memorātum"/>
                <ITEXT FEATURES="inherit superscript" CH="9"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ītaliae rēgem, noviter quem coeperat"/>
                <ITEXT FEATURES="inherit superscript" CH="10"/>
                <ITEXT CH=" armīs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hīc hūmānārum"/>
                <ITEXT FEATURES="inherit superscript" CH="11"/>
                <ITEXT CH=" videās lūdībria rērum,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quam variō cursū vītae rota volvitur huius."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="19668.6231872611" OwnPage="45" ItemID="974492586" PTYPE="4" WIDTH="522" HEIGHT="197.1974522293" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 197.197 L0 197.197 L0 0 Z" copath="M0 0 L522 0 L522 197.197 L0 197.197 L0 0 Z" gXpos="136.0008" gYpos="19668.6231872611" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="While such things were being done in Italy in those times."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The Saxons dared to invade the boundaries of the Franks neighboring themselves."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Ausī"/>
                <ITEXT CH=" would usually be "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="ausī sunt"/>
                <ITEXT CH=" for "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="they dared"/>
                <ITEXT CH="; in a poetic context it is permitted to omit the "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="sunt"/>
                <ITEXT CH=" for metrical purposes."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Whom the long departure of the king inspired to this. Profectiō"/>
                <ITEXT CH=" typically has a macron over the "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="o"/>
                <ITEXT CH=", but it must be short here to fit the meter."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Then believing the time to be of avenging themselves the very great damages, previously that they had sustained through him (Charlemagne)."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Maxima"/>
                <ITEXT CH=" modifies "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="damna"/>
                <ITEXT CH=", "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="fore"/>
                <ITEXT CH=" is the future infinitive of "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="esse"/>
                <ITEXT CH=", and "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="sustinuēre"/>
                <ITEXT CH=" is not an infinitive but rather an alternate way to spell "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="sustinuērunt"/>
                <ITEXT CH="."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Which Boniface, martyr and overseer ever-beloved by Christ, consecrated there"/>
                <ITEXT CH=". Saint Boniface (AD 675-754) famously chopped down Donar's Oak in Fritzlar."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="They vainly advanced to complete this wicked act, suddenly a massive terror from heaven assailed (them) and forced the trembling ones (the Saxons) to retreat in turpid flight to their fatherland, whom were routed not by enemies, nor by weapons (but by the supernatural intervention of God)."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="19192.0752" OwnPage="46" ItemID="974878602" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="19192.0752" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aevum: eternity; singular neuter accusative from aevum, aevī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agerentur: they were being done; 3rd person plural imperfect passive subjunctive from agō, agere, ēgī, āctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="animāvit: it animated, inspired; 3rd person singular perfect active from animō, animāre, animāvī, animātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="annō: year; singular masculine ablative from annus, annī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="antistes: overseer; singular common nominative from antistes, antistitis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="arma: weapons; plural neuter nominative from armum, armī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="armīs: weapons; plural neuter ablative from armum, armī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="atque: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ausī: ausī sunt = they dared, sunt is omitted for metrical reasons; plural masculine nominative perfect passive participle from audeō, audēre, ausus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Bonifācius: Saint Boniface, AD 675-754"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Chrīstō: Christ (ablative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="coēgit: it forced; 3rd person singular perfect active from cōgō, cōgere, coēgī, coāctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="complēre: to complete, to fill up; present infinitive from compleō, complēre, complēvī, complētus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="contiguōs: bordering, neighboring, contiguous; plural masculine accusative from contiguus, contigua, contiguum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="crēdentēs: believing; plural common nominative present participle from crēdō, crēdere, crēdidī, crēditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cupiērunt: they desired, alternative spelling of cupīvērunt; 3rd person plural perfect active from cupiō, cupere, cupīvī, cupītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="damna: damages, injuries; plural neuter accusative from damnum, damnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīcitur: it is said; 3rd person singular present passive from dīcō, dīcere, dīxī, dictus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīlēctus: having been loved, beloved; singular masculine nominative from dilectus, dilectus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīvīnitus: divinely, of heaven (adverb)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dum: while, as long as, until"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ecclēsiam: church; singular feminine accusative from ecclēsia, ecclēsiae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eum: to him; singular masculine accusative from is, ea, id"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="facinus: crime, outrage; singular neuter accusative from facinus, facinoris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fīnēs: boundaries, ends, limits; plural common accusative from fīnis, fīnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="flammīs: flames; plural feminine ablative from flamma, flammae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fore: to be (in the future); future infinitive from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Frīdēshlar: Fritzlar, Germany"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="frūstrā: futile"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fugā: flight, escape; singular feminine ablative from fuga, fugae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fugārunt: they routed, chased away, variant spelling of fugāvērunt; 3rd person plural perfect active from fugō, fugāre, fugāvī, fugātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Hassī: Hesse, a region in Germany"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hoc: this; singular neuter accusative from hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hōrīs: times; plural feminine ablative from hōra, hōrae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hostēs: enemies; plural common nominative from hostis, hostis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīc: there"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ingēns: huge, enormous; singular  nominative from ingēns, ingentis (gen.), ingentior -or -us, ingentissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="invādere: to invade; present infinitive from invādō, invādere, invāsī, invāsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="invāsit: it invaded; 3rd person singular perfect active from invādō, invādere, invāsī, invāsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Italicis: in Italy; plural masculine ablative from Italicus, Italici"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="locum: place; singular masculine accusative from locus, locī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="longinqua: long, prolonged; singular feminine nominative from longinquus, longinqua -um, longinquior -or -us, longinquissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="martir: martyr, one who dies for their faith"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="maxima: biggest; plural neuter accusative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nefandum: impious, wicked; singular neuter accusative from nefandus, nefanda, nefandum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nīsōs: having advanced, pressed upon; plural masculine accusative perfect participle from nītor, nītī, nīsus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pāgum: district, region; singular masculine accusative from pāgus, pāgī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="patriam: fatherland; singular feminine accusative from patria, patriae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="per: through"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populantur: they are ravaged, devastated; 3rd person plural present passive from populō, populāre, populāvī, populātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praedantur: they are despoiled; 3rd person plural present passive from praedor, praedārī, praedātus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prius: before"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="profectiō: departure, source; singular feminine nominative from profectiō, profectiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prōgressī: prōgressī sunt = they advanced, the sunt is omitted for metrical reasons; plural masculine nominative perfect participle from prōgredior, prōgredī, prōgressus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quam: how? how much?"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quandam: a certain; singular feminine accusative form quidam"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="que: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quōs: who; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgis: of the king; singular masculine genitive from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="repedāre: to return, retreat; present infinitive from repedō, repedāre, repedāvī, repedātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēs: things; plural feminine nominative from rēs, reī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sacrāvit: he consecrated; 3rd person singular perfect active from sacrō, sacrāre, sacrāvī, sacrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxonēs: the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sībī: to himself; singular dative of sē"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simul: at the same time as"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subitō: suddenly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sustinuēre: they sustained; 3rd person plural perfect active from sustineō, sustinēre, sustinuī, sustentus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tālēs: such; plural common nominative from tālis, tālis, tāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tamen: however"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tempus: time, period; singular neuter nominative from tempus, temporis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="terror: terror; singular masculine nominative from terror, terrōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trādere: to hand over; present active infinitive from trādō, trādere, trādidī, trāditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trepidōs: agitated, nervous; plural masculine accusative from trepidus, trepida, trepidum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tunc: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="turpī: ugly, filthy; singular feminine ablative from turpis, turpe, turpior -or -us, turpissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ulcīscendī: avenging, punishing; singular masculine genitive future participle from ulcīscor, ulcīscī, ultus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ūsque: until, all the way, up until"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vocitātur: it is called; 3rd person singular present passive from vocitō, vocitāre, vocitāvī, vocitātus"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="20501.4386738854" OwnPage="47" ItemID="975338522" PTYPE="4" WIDTH="522" HEIGHT="232.050955413964" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 232.051 L0 232.051 L0 0 Z" copath="M0 0 L522 0 L522 232.051 L0 232.051 L0 0 Z" gXpos="136.0008" gYpos="20501.4386738854" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And to press the people (of Pavia/Ticinum) with constant seige and war."/>
                <ITEXT CH=" An English-like word order would be "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="(ad) premendum populum (cum) iūgī obsidiōne (et) bellō"/>
                <ITEXT CH="."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="For the reason of prayer he sought the holy places of Rome."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Ōrandī"/>
                <ITEXT CH=" is a genitive gerund."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="He returned to Pavia/Ticinium, which, now tired by long battle, had lost all strength of fighting."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Repugnandī"/>
                <ITEXT CH=" is a genitive gerund."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="This most famous (city) having then been given to the Franks, it was an example to all the rest (of the cities of Lombardy)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Because immediately all cities of the same kingdom (Lombardy) gave themselves over to Charlemagne amicably."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Which he now arranged having subjected them rightly to himself."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="As much as he could in such time."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="8"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Because, desiring to return to his paternal habitations (the land of the Franks)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="9"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Leading with him the aforementioned king of Italy (Desiderius)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="10"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Whom recently he had seized with weapons."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="11"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Here you see the mockeries of human affairs, how by various courses the wheel of this life is turned."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="20024.0784" OwnPage="48" ItemID="976093722" PTYPE="4" WIDTH="522" HEIGHT="720.000000000002" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="20024.0784" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="accelerābat: he was speeding up; 3rd person singular imperfect active from accelerō, accelerāre, accelerāvī, accelerātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="āmīserat: it had lost; 3rd person singular pluperfect active from āmittō, āmittere, āmīsī, āmissus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="armīs: weapons; plural neuter ablative from armum, armī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="at: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="bellō: battle, war; singular neuter ablative from bellum, bellī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolō: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="causā: reason, cause; singular feminine ablative from causa, causae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="certāmine: struggle, fight; singular neuter ablative from certāmen, certāminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="clārissima: very clear, very famous; singular feminine nominative from clārus, clāra -um, clārior -or -us, clārissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="coeperat: he had seized (based on context and etymology), he had started; 3rd person singular pluperfect active from coepio, coepere, coepi, coeptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="concorditer: harmoniously, amicably (adverb)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="corde: heart; singular neuter ablative from cor, cordis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cūnctīs: all, whole; plural ablative from cūnctus, cūncta, cūnctum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cupiēns: desiring; singular nominative present participle from cupiō, cupere, cupīvī, cupītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cursū: course; singular neuter ablative from currō, currere, cucurrī, cursus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēdita: having been surrendered; singular feminine nominative perfect passive participle from dēdō, dēdere, dēdidī, dēditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dispositīs: having been arranged, distributed; plural ablative perfect passive participle from dispōnō, dispōnere, disposuī, dispositus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="disposuit: he arranged, distributed; 3rd person singular perfect active from dispōnō, dispōnere, disposuī, dispositus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dūcēns: leading; singular nominative present participle from dūcō, dūcere, dūxī, ductus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eius: his/her/its"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="etenim: because"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ex: out of, from"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="exemplō: sample, model, copy; singular neuter ablative from exemplum, exemplī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fessa: tired; singular feminine nominative from fessus, fessa, fessum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francīs: the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fuerat: he had been; 3rd person singular pluperfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="haec: this; singular feminine nominative from hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hīc: here;"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="huius: of this; singular genitive of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hūmānārum: human; plural feminine genitive from hūmānus, hūmāna -um, hūmānior -or -us, hūmānissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iam: already, now, soon"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīc: there"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ītaliae: Italy (genitive or locative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iter: journey, trip; singular neuter accusative from iter, itineris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iūgī: continuous; singular feminine ablative from iūgis, iūge"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iūre: rightly (adverb), according to law"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="legiōnibus: legions; plural feminine ablative from legiō, legiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="loca: places; plural neuter accusative from locum, locī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="longō: long, far; singular masculine ablative from longus, longa -um, longior -or -us, longissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="lūdībria: mockeries, wantonness; plural neuter accusative from lūdībrium, lūdībriī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="memorātum: the aforementioned (from context), having been remembered; singular neuter nominative perfect passive participle from memorō, memorāre, memorāvī, memorātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nam: for"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="noviter: recently"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obsidiōne: seige; singular feminine ablative from obsidiō, obsidiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="omnēs: all, every; plural common accusative from omnis, omnis, omne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ōrandī: praying; singular masculine genitive gerund from ōrō, ōrāre, ōrāvī, ōrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="paternās: paternal; plural feminine accusative from paternus, paterna, paternum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="perāctīs: having been carried through; plural ablative perfect passive participle from peragō, peragere, perēgī, perāctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="petīvīt: he sought for; 3rd person singular perfect active from petō, petere, petīvī, petītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populum: people, populace; singular masculine accusative from populus, populī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="potuit: he was able; 3rd person singular perfect active from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="premendum: pressing, overwhelming, oppressing; singular neuter nominative gerund from premō, premere, pressī, pressus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prō: for, in favor of, before, in place of"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prōtinus: immediately"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quam: how"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quantum: how much?"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="que: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quem: what, singular masculine accusative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quod: what; singular neuter nom. or acc. of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="redīvit: he returned; 3rd person singular perfect active from redeō, redīre, redivī(iī), reditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgem: king; singular masculine accusative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgnī: of the kingdom; singular neuter genitive from rēgnum, rēgnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="reliquīs: remaining; plural neuter ablative from reliquum, reliqui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="remeāre: to come back, return; present infinitive from remeō, remeāre, remeāvī, remeātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="repūgnandī: fighting back; singular masculine genitive gerund from repūgnō, repūgnāre, repūgnāvī, repūgnātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rērum: of things; plural feminine genitive from rēs, reī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Rōmae: of Rome; singular feminine genitive from Rōma, Rōmae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rota: wheel; singular feminine nominative from rota, rotae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sāncta: holy"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēcum: with oneself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēdēs: lands; plural feminine accusative from sēdēs, sēdis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēsē: himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sībī: to himself; singular dative of se"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subāctum: having been subjugated, conquered; singular neuter nominative perfect passive participle from subigō, subigere, subēgī, subāctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="supplicibus: suppliant; plural masculine ablative adjective from supplex, supplicis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tālī: such"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tempore: time, period; singular neuter ablative from tempus, temporis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ticinēnsum: residents of Pavia a.k.a. Ticinum, capital of the Kingdom of the Lombards from 572 to 774."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ticinum: Pavia a.k.a. Ticinum, capital of the Kingdom of the Lombards from 572 to 774."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trādiderant: they had handed over; 3rd person plural pluperfect active from trādō, trādere, trādidī, trāditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tum: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbs: city; singular feminine nominative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbēs: cities; plural feminine nominative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="variō: various, diverse; singular masculine ablative from varius, varia, varium"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="videās: you may see; 2nd person singular present active subjunctive from videō, vidēre, vīdī, vīsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vīrēs: strength; plural feminine accusative from vis, viris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vītae: of life; singular feminine genitive from vīta, vītae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="volvitur: it is rolled; 3rd person singular present passive from volvo, volvere, volvi, volutus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vōtīs: vows; plural neuter ablative from vōtum, vōtī"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="20856.0816" OwnPage="49" ItemID="979509306" PTYPE="4" WIDTH="522" HEIGHT="413.510140127388" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 413.51 L0 413.51 L0 0 Z" copath="M0 0 L522 0 L522 413.51 L0 413.51 L0 0 Z" gXpos="136.0008" gYpos="20856.0816" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Hesternō Dēsīderiūs diadēmate rēgnī"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Flōruit, ēn hodiē"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" est pauper, captīvus et exul."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Fīlius illīus, cognōmine dictus Adalgīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cum Langōbardīs in eō spēs ampla manēret,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Diffīdēns rēbus patriae, sē contulit inde"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad Cōnstantīnum, Grēcōrum scēptra regentem"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=";"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ā quō patricius"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" praeclārō mūnere factus,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hoc in honōre suae permānsit ad ultima vītae."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Rēx autem Carolus veniēns, dum"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" cognitus eius"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Vēlōx adventus nec dum Saxōnibus esset,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Fēcerat, ut triplex exercitus in regiōnēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Illōrum missus, multīs afflīgeret ipsōs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cēdibus ac praedīs, loca dēnique plūrima vastāns"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hinc est cum spoliīs victor regressus opīmīs."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="21269.5917401274" OwnPage="49" ItemID="980194330" PTYPE="4" WIDTH="522" HEIGHT="126.489859872601" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 126.49 L0 126.49 L0 0 Z" copath="M0 0 L522 0 L522 126.49 L0 126.49 L0 0 Z" gXpos="136.0008" gYpos="21269.5917401274" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit" CH="Yesterday Desiderius flourished in the crown of his kingdom, behold today he is a pauper, captive, and exile."/>
                <ITEXT CH=" The "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="ē"/>
                <ITEXT CH=" in "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="hodiē"/>
                <ITEXT CH=" elides, giving a scansion of DDSSDT."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="To Constantine, reigning the scepters of the Greeks."/>
                <ITEXT CH=" Constantine V was the Emporer of the Eastern Roman/Byzantine Empire from 741 to 775 and gave shelter to Adalgis, the son of Desiderius, who fled to Constantinople."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="By whom he (Adalgis) was made (a) patrician with remarkable employment/office."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="When his switft advance was not yet known to the Saxons."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="21688.0848" OwnPage="51" ItemID="983857914" PTYPE="4" WIDTH="522" HEIGHT="534.475292993629" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 534.475 L0 534.475 L0 0 Z" copath="M0 0 L522 0 L522 534.475 L0 534.475 L0 0 Z" gXpos="136.0008" gYpos="21688.0848" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Annō 775."/>
                <para/>
                <ITEXT CH="Rēx hiemis tempus dūcēns"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" in Cārisiācō,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nōmine quō quēdam rēgālis vīlla vocātur,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Illūc Francōrum procerēs tōtumque senātum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Convocat, ac multum tractāns"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" dē rēbus agendīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et variīs"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=", quibus indiguit rēs pūblica, cūrīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Inprīmīs hoc cōnsilium perhibētur inīsse,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ut iugiter bellum Saxonibus ingererētur"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=","/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quōs expertus"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" erat fideī vel foederis omnis"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Immemorēs, nunquam sub pāce quiēscere velle."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hinc statuit, requiēs"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" illīs ut nūlla darētur,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dōnec gentīlī"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT CH=" rītū cultūque relictō,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Christicolae fierent, aut dēlērentur in aevum."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ō pietās benedicta Deī, quae vult genus omne"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hūmānum fierī salvum, quia nōverat huius"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nōn aliter"/>
                <ITEXT FEATURES="inherit superscript" CH="8"/>
                <ITEXT CH=" gentīs mollīrī pectora posse,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Disceret ut cervīx reflectere dūra rigōrem"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ingenitum, mītīque iugō sē subdere Chrīstī."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
