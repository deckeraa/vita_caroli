        <PAGEOBJECT XPOS="136.0008" YPOS="34168.1328" OwnPage="81" ItemID="1045265226" PTYPE="4" WIDTH="522" HEIGHT="380.188254777062" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 380.188 L0 380.188 L0 0 Z" copath="M0 0 L522 0 L522 380.188 L0 380.188 L0 0 Z" gXpos="136.0008" gYpos="34168.1328" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Cumque"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" Pyreneī regressus ad intima saltūs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Mīlite cum lassō"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" callēs trānscenderet artōs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Īnsidiās eius summō sub vertice montis"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tendere Wascōnēs ausī, nova praelia temptant."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dēnique postrēmōs populī rēgālis adortī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Missilibus prīmō sternunt ex collibus altīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et Francōs, quamvīs"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" armīs animīsque priōrēs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Impār fēcit et angustus locus īnferiōrēs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Rēx iam praecessit, tardumque remānserat agmen,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cūra vehendārum"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" quod rērum praepediēbat."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Fit"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" pavor hinc exercitibus, subitōque tumultū"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Turbantur, victrīx latrōnum turba nefanda"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ingentem rapuit praedam, plūrēsque necāvit."/>
                <trail PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="34553.3210547771" OwnPage="81" ItemID="1045828906" PTYPE="4" WIDTH="522" HEIGHT="198.831811464937" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 198.832 L0 198.832 L0 0 Z" copath="M0 0 L522 0 L522 198.832 L0 198.832 L0 0 Z" gXpos="136.0008" gYpos="34553.3210547771" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH="It appears that the scansion of this line is SDSDDS."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="(When) with his weary soldier(s) he (Charlemagne) crossed the narrow path, the Basques dared to stage an ambush under the highest peak of the mountain, trying to wage new battles. "/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="mīlites"/>
                <ITEXT CH=" is best translated as a collective singular: witih weary soldiers."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And the Franks who were below, although they were better (than the Basques) in arms and spirit, the narrow place made unequal (to the Basques)."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Already the king had proceeded (through the mountain pass) and the slow army had remained, which the care of carrying the things had delayed."/>
                <ITEXT CH=" The Basques attacked the baggage train at the rear of Charlemagne's army. This attack occurred at the Roncevaux Pass. A famous song, the Song of Roland, was later composed about the event."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="From here there was a fear amongst the army, and they were thrown into confusion by the sudden tumult, and the victorious nefarious band of robbers seized great plunder and killed many."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="34168.1328" OwnPage="82" ItemID="1049224954" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="34168.1328" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="adortī: having been attacked; singular masculine genitive perfect participle from adorior, adorīrī, adortus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agmen: marching army; singular neuter nominative from agmen, agminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="altīs: high; plural masculinei ablative from altus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="angustus: small space, narrow passage, being boxed in; singular masculine nominative from angustus, angusta -um, angustior -or -us, angustissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="animīs: souls, minds, lives; plural feminine ablative from anima, animae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="armīs: weapons; plural neuter ablative from armum, armī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="artōs: close, narrow; plural masculine accusative from artus, arta -um, artior -or -us, artissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ausī: having dared; plural masculine nominative perfect passive participle from audeō, audēre, ausus sum. audeō is semi-deponent, so we take the active meaning based on context."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="callēs: paths; plural feminine accusative from callis, callis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="collibus: hills; plural masculine ablative from collis, collis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cūra: care, concern, supervision; singular feminine nominative from cūra, cūrae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēnique: finally"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eius: his/her/its"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ex: out of, from"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="exercitibus: armies; plural masculine dative from exercitus, exercitūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēcit: he did; 3rd person singular perfect active from faciō, facere, fēcī, factus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fit: it happened, it occurred; 3rd person singular present active from fīō, fierī, factus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōs: the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hinc: from here"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iam: already, now, soon"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="impar: unequal; singular  nominative from impar, (gen.), imparis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnferiōrēs: lower; plural common accusative from īnferus, īnfera, īnferum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ingentem: huge, enormous; singular common accusative from ingēns, ingentis (gen.), ingentior -or -us, ingentissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnsidiās: ambushes, plots; plural feminine accusative from īnsidia, īnsidiae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="intima: inmost parts; plural neuter accusative from intimus, intima, intimum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="lassō: tired, weary; singular masculine ablative from lassus, lassa, lassum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="latrōnum: of plunderers, robbers, brigands; plural masculine genitive from latrō, latrōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="locus: place; singular masculine nominative from locus, locī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mīlite: soldier; singular masculine ablative from mīles, mīlitis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="missilibus: missiles, javelins; plural ablative from missilis, missilis, missile"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="montīs: of the mountain; singular masculine genitive from mōns, montis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="necāvit: it killed, destroyed; 3rd person singular perfect active from necō, necāre, necāvī, necātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nefanda: impious, wicked; singular feminine nominative from nefandus, nefanda, nefandum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nova: new, inexperienced; singular feminine nominative from novus, nova -um, novior -or -us, novissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pavor: fear, trembling; singular masculine nominative from pavor, pavōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plūrēs: more; plural common nominative from plus, (gen.), pluris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populī: people, populace; singular masculine genitive from populus, populī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="postrēmōs: very last; plural masculine accusative from postremus, postrema, postremum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praecessit: he proceeded, excelled; 3rd person singular perfect active from praecēdō, praecēdere, praecessī, praecessus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praedam: plunder; singular feminine accusative from praeda, praedae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praelia: battles; plural neuter accusative from praelium, praeliī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praepediēbat: it was hindering, shackling, fettering; 3rd person singular imperfect active from praepediō, praepedīre, praepedīvī, praepedītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prīmō: first; singular masculine dative from prīmus, prīma, prīmum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="priōrēs: prior, ahead, previous; plural common nominative from prior, prior, prius"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Pyrēnēī: of the Pyrenees Mountains"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quamvīs: as much, as much as one wants, however"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quod: what; singular neuter nom. or acc. of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rapuit: he seized, pillaged; 3rd person singular perfect active from rapiō, rapere, rapuī, raptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgālis: regal, royal; singular common nominative from rēgālis, rēgālis, rēgāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="regressus: return; singular masculine nominative perfect participle from regredior, regredī, regressus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="remānserat: he had remained; 3rd person singular pluperfect active from remaneō, remanēre, remānsī, remānsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rērum: of things; plural feminine genitive from rēs, reī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="saltūs: of the narrow pass, mountain defile; singular masculine genitive from saltus, saltūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sternunt: they cast down, scattered, covered; 3rd person plural present active from sternō, sternere, strāvī, strātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sub: below, under"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subitō: suddenly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="summō: highest, greatest; singular masculine ablative from summus, summa, summum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tardum: slow; singular neuter nominative from tardus, tarda -um, tardior -or -us, tardissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="temptant: they tried; 3rd person plural present active from temptō, temptāre, temptāvī, temptātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tendere: to aim, plan, stretch, extend; present active infinitive from tendō, tendere, tetendī, tentus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trānscenderet: he was crossing over; 3rd person singular imperfect active subjunctive from trānscendō, trānscendere, trānscendī, trānscēnsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tumultū: uproar; singular masculine ablative from tumultus, tumultūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="turba: troop, band; singular feminine nominative from turba, turbae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="turbantur: they are disturbed, confused; 3rd person plural present passive from turbō, turbāre, turbāvī, turbātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vehendārum: of carrying; plural feminine genitive future passive participle from vehō, vehere, vēxī, vectus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vertice: peak; singular masculine ablative from vertex, verticis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="victrīx: conquering; singular feminine nominative from victrīx, which is a defective adjective that is only available in the feminine"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Wascōnēs: the Basques, a group that lived just west of the Pyrenees"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="35000.136" OwnPage="83" ItemID="1049513082" PTYPE="4" WIDTH="522" HEIGHT="325.006910828" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 325.007 L0 325.007 L0 0 Z" copath="M0 0 L522 0 L522 325.007 L0 325.007 L0 0 Z" gXpos="136.0008" gYpos="35000.136" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Namque palātīnī quīdam"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" cecidēre ministrī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Commendāta quibus rēgālis cōpia gāzae,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Praedōnēs"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" illōs spoliīs dītāvit opīmīs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hīs gestīs, hostēs vastī per dēvia saltūs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Fūgērunt, celeranter; erant quibus ardua montis"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Abdita"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" silvārum vallis loca nōta profundē"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quōs fuga dīlāpsōs"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" investīgābilis et nox"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Īnstāns ēripuit, sequerētur ut ultio"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" nūlla."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ac facinus tantum quoniam permānsit inultum,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Trīstia"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" rēgālī subdūxit nūbila mentī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Prōspera quam fēcēre prius complūra serēnam."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="35325.142910828" OwnPage="83" ItemID="1050159370" PTYPE="4" WIDTH="522" HEIGHT="178.993089172011" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 178.993 L0 178.993 L0 0 Z" copath="M0 0 L522 0 L522 178.993 L0 178.993 L0 0 Z" gXpos="136.0008" gYpos="35325.142910828" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And certain palace ministers fell (in death), to whom the supplies of the royal treasuries had been committed."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH="This is spelled "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="predones"/>
                <ITEXT CH=" in the critical text."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="These things being done, the vast host (army of the Basques) fled through devious (places) of the mountain pass quickly, to whom were deeply-known (nōta profundē) steep hidden places (ardua loca abdita) of the forests of the mountain valley."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Whom, having slipped away by fleeing, the oncoming unsearchable night snatched away (from the Franks being able to find and pursue them)."/>
                <ITEXT FONT="DejaVu Serif Book" CH=" It appears that fugā ought to be in the ablative, yet to fit the meter it must have two short syllables."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="So that no vengeance followed."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="ultiō"/>
                <ITEXT CH=" is often spelled with a macron, but cannot be here due to the meter. The line scans as SDDDDS."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="It drew sad clouds to the regal mind (of Charlemagne), which many properous (things) had previously made serene."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="35000.136" OwnPage="84" ItemID="1053537226" PTYPE="4" WIDTH="522" HEIGHT="720.000000000011" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="35000.136" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="abdita: hidden; plural masculine nominative from abditus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ac: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ardua: steep, high, lofty, difficult; plural neuter nominative from arduus, ardua -um, arduior -or -us, arduissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cecidēre: they fell (in death); 3rd person plural perfect active from cadō, cadere, cecidī, cāsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="celeranter: quickly;"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="commendāta: having been entrusted; singular feminine nominative perfect passive participle from commendō, commendāre, commendāvī, commendātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="complūra: many (things); plural neuter nominative from complus, compluris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōpia: supplies, wealth; singular feminine nominative from cōpia, cōpiae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēvia: devious, out-of-the-way (places); plural neuter accusative from dēvius -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dīlāpsōs: having slipped away; plural masculine accusative perfect participle from dīlābor, dīlābī, dīlāpsus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dītāvit: it enriched; 3rd person singular perfect active from dītō, dītāre, dītāvī, dītātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="erant: they were"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ēripuit: it snatched away; 3rd person singular perfect active from ēripiō, ēripere, ēripuī, ēreptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="facinus: crime, outrage; singular neuter nominative from facinus, facinoris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēcēre: they did, made; 3rd person plural perfect active from faciō, facere, fēcī, factus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fugā: by flight, escape; singular feminine ablative from fuga, fugae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fūgērunt: they fled; 3rd person plural perfect active from fugiō, fugere, fūgī, fugitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gazae: of the treasuries; singular feminine genitive from gaza, gazae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gestīs: having been carried out; plural ablative perfect passive participle from gerō, gerere, gessī, gestus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hīs: these; plural masculine ablative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hostēs: enemies; plural common nominative from hostis, hostis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illōs: those; plural masculine accusative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnstāns: oncoming; singular nominative present participle from īnstō, īnstāre, īnstitī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="inultum: unavenged; singular neuter nominative from inultus, inulta, inultum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="investīgābilis: unsearchable; singular common nominative from investīgābilis, investīgābilis, investigabile"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="loca: places; plural neuter nominative from locum, locī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mentī: to the mind; singular feminine dative from mēns, mentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ministrī: ministers; plural masculine nominative from minister, ministrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="montīs: of the mountain; singular masculine genitive from mōns, montis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="namque: for and in fact, on the other hand"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōta: known; plural neuter nominative perfect passive participle from nōscō, nōscere, nōvī, nōtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nox: night; singular feminine nominative from nox, noctis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nūbila: clouds; plural neuter accusative from nūbilus, nūbila, nūbilum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nūlla: no, not any; singular feminine nominative from nūllus, nūlla, nūllum (gen -ius)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="opīmīs: rich, well-fed, fat, fertile; plural ablative from opīmus, opīma, opīmum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="palātīnī: palace, imperial; plural masculine nominative from Palatinus, Palatina, Palatinum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="per: through"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="permansit: it remained; 3rd person singular perfect active from permaneō, permanēre, permansī, permansus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praedōnēs: robbers, thieves; plural masculine accusative from praedō, praedōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prius: before"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="profundē: profoundly; adverb from profundus, profunda, profundum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prospera: favorable, prosperous; plural neuter nominative from prosperus, prospera -um, prosperior -or -us, prosperrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quam: how? how much?"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quibus: to whom; plural ablative of quī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quoniam: after"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quōs: whom; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgālī: regal, royal; singular dative from rēgālis, rēgālis, rēgāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgālis: regal, royal; singular common genitive from rēgālis, rēgālis, rēgāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="saltūs: narrow passes, mountain defiles; plural masculine genitive from saltus, saltūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sequerētur: it followed; 3rd person singular subjunctive imperfect from sequor, sequī, sēcūtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="serēnam: serene; singular feminine accusative from serēnus, serēna, serēnum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="silvārum: of forests; plural feminine genitive from silva, silvae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="spoliīs: spoils, booty; plural neuter ablative from spolium, spoliī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subdūxit: it lead off; 3rd person singular perfect active from subdūcō, subdūcere, subdūxī, subductus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tantum: so much, so great, this many; singular neuter nominative from tantus, tanta, tantum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tristia: sad; plural neuter accusative from trīstis, trīstis, trīste"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ultiō: vengeance, revenge; singular feminine nominative from ultiō, ultiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ut: so that"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vallis: of the valley; singular feminine genitive from vallis, vallis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vāstī: immense; plural masculine nominative from vāstus, vāsta -um, vāstior -or -us, vāstissimus -a -um"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="35832.1392" OwnPage="85" ItemID="1053766666" PTYPE="4" WIDTH="522" HEIGHT="292.844675159227" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 292.845 L0 292.845 L0 0 Z" copath="M0 0 L522 0 L522 292.845 L0 292.845 L0 0 Z" gXpos="136.0008" gYpos="35832.1392" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Aptum praetereā sē tempus habēre putantēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Saxonēs ulcīscendī"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" quam plūrima dampna"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ā Francīs illāta sibī, quia rēx erat absēns,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Īnfēstō"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" Rhēnī petiērunt agmine lītus."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quem"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" trānsīre tamen nūllā ratiōne valentēs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Francōrum terrās in eādem parte iacentēs"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quā vēnēre nimis vastāre ferōciter ausī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ā mūrīs urbis, quae dicta Diūtia nunc est,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dōnec perveniās ubi Rhēnus cōnfluit īdem,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Lītoribusque ferēns fontēs Mūsella Liēī."/>
                <trail PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="36125.4424738854" OwnPage="85" ItemID="1054396058" PTYPE="4" WIDTH="522" HEIGHT="134.828025477709" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 134.828 L0 134.828 L0 0 Z" copath="M0 0 L522 0 L522 134.828 L0 134.828 L0 0 Z" gXpos="136.0008" gYpos="36125.4424738854" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And then the Saxons thinking to themselves (sē putantēs) the time to be apt to have revenge for the many damages brought to them by the Franks."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="With hostile army they sought the shore of the Rhine."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Which, however, they were not able to cross by any way."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="They dared to excessively and ferociously ravage the lands of the Franks lying on the same part (of the Rhine) to which they had come."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="35832.1392" OwnPage="86" ItemID="1057331146" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="35832.1392" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ā: from, out of, by, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="absēns: absent; singular masculine nominative from absēns, (gen.), absentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agmine: marching army; singular neuter ablative from agmen, agminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aptum: apt, suitable, ready; singular neuter accusative from aptus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ausī: having dared; plural masculine nominative perfect passive participle from audeō, audēre, ausus sum. audeō is semi-deponent, so we take the active meaning based on context."/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnfluit: it flows together; 3rd person singular present active from cōnfluō, cōnfluere, cōnflūxī, cōnfluxus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dampna: damages, injuries; plural neuter nominative from dampnum, dampnī"/>
                <para PARENT="Vocab"/>
