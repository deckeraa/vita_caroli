                <para PARENT="Vocab"/>
                <ITEXT CH="flūmine: river; singular neuter ablative from flūmen, flūminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fore: to be; future active infinitive from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francīs: the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="generālis: general; singular common genitive from generālis, generālis, generāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gradū: step; singular masculine ablative from gradus, gradūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="grandī: great, grand, imposing; singular ablative from grandis, grandis, grande"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="habētur: it is had; 3rd person singular present passive from habeō, habēre, habuī, habitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hanc: this; singular feminine accusative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hōc: this; sing. masc. or neut. abl. of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hostīliter: in a hostile manner (adverb)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīc: there"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="inde: from there, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="indigene: by the natives, denizens; adverbial form of indigenus, indigenī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnsignem: distinguished; singular common accusative from īnsignis, īnsignis, īnsigne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnspīrātum: having been inspired; singular neuter accusative perfect passive participle from īnspīrō, īnspīrāre, īnspīrāvī, īnspīrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="intrat: he entered; 3rd person singular present active from intrō, intrāre, intrāvī, intrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="invītōs: unwilling; plural masculine accusative from invītus, invīta, invītum"/>
                <para PARENT="Vocab"/>
