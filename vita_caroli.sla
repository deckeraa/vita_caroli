                <para PARENT="Vocab"/>
                <ITEXT CH="exercituum: of armies; plural masculine genitive from exercitus, exercitūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēcerat: it had made; 3rd person singular pluperfect active from faciō, facere, fēcī, factus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fraude: fraud; singular feminine ablative from fraus, fraudis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hinc: because, from here"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Hlidbeki: modern-day Lübbecke in North Rhine-Westphalia in Germany"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hōrās: hours, times; plural feminine accusative from hōra, hōrae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hostibus: enemies; plural common ablative from hostis, hostis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īdem: the same"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iam: already, now, soon"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīs: those; plural dative or ablative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illōs: that; plural masculine accusative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="intereā: during"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipse: itself; singular masculine nominative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iuxtā: near, nearly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="locātīs: having been stationed stationed; ablative past passive participle from locō, locāre, locāvī, locātus"/>
                <para PARENT="Vocab"/>
