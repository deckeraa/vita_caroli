        <PAGEOBJECT XPOS="136.0008" YPOS="14200.056" OwnPage="33" ItemID="949843770" PTYPE="4" WIDTH="522" HEIGHT="412.515031847134" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 412.515 L0 412.515 L0 0 Z" copath="M0 0 L522 0 L522 412.515 L0 412.515 L0 0 Z" gXpos="136.0008" gYpos="14200.056" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Hanc igitur Carolus statuit sibi subdere gentem."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nec mora, cum tōtīs Francōrum vīribus ipsam"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Aggressus"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=", lātē ferrō vastāvit et ignī."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Castellum nātūrālī mūnīmine forte"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Valde"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=", manū quoque firmātum, quod barbara lingua"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nōminat Ērēsburg, validō cum rōbore cēpit."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Gēns eadem coluit simulācrum"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=", quod vocitābant"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Irminsul, cuius similis factūra columne"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nōn operis parvī fuerat pariterque decōris."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hoc rēx ēvertēns, mānsit tribus ipse diēbus"/>
                <para PARENT="Latin"/>
                <ITEXT CH="In castrīs iuxtā positīs"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=", tum continuātō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Aestātis fervōre diū, caelōque serēnō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ārdēbant agrī, nec in ipsīs fontibus hūmor"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ūllus erat, multō squālēbant pulvere rīvī."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="14612.5710318471" OwnPage="33" ItemID="950029082" PTYPE="4" WIDTH="522" HEIGHT="186.191082802552" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 186.191 L0 186.191 L0 0 Z" copath="M0 0 L522 0 L522 186.191 L0 186.191 L0 0 Z" gXpos="136.0008" gYpos="14612.5710318471" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Without delay, with all the strength of the Franks he attacked it (the gentem, which refers to the Saxon people, see previous line), he destroyed widely with sword and fire."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Aggressus"/>
                <ITEXT CH=", being from a deponent verb, would normally be written "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="aggressus est"/>
                <ITEXT CH=" for "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="he attacked"/>
                <ITEXT CH=", but the "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="est"/>
                <ITEXT CH=" is omitted for metrical reasons."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="A very strong castle, with natural fortification, which the barbarian tongue names Eresburg, he seized strongly with strength and also with a firm hand."/>
                <ITEXT CH=" Alternatively, "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="validō cum rōbore"/>
                <ITEXT CH=" could mean "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="with a strong stronghold"/>
                <ITEXT CH=" or "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="with strong oakenworks"/>
                <ITEXT CH=", referring to the "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="castellum"/>
                <ITEXT CH="; "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="rōbore"/>
                <ITEXT CH=" is ambiguous in this way. For metrical reasons, the macron over the "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="e"/>
                <ITEXT CH=" in "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="valde"/>
                <ITEXT CH=" should be omitted during scansion."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The same people worships an idol, which they call the Irminsul, whose manufacture is similar to a column, it was not a small work and likewise (was) of beauty."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The king (Charlemagne) overturning this (the Irminsul), he himself remained three days in camp next to the posititon."/>
                <ITEXT CH=" In this part of the narrative, Charlemagne has not yet captured Eresburg but is camped out next to it, having torn down the idol that was located outside the fort, perhaps in a sacred grove."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="14200.056" OwnPage="34" ItemID="952183802" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="14200.056" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="aestātis: summer; singular feminine genitive from aestās, aestātis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aggressus: he attacked; singular masculine nominative perfect passive participle from aggredior, aggredī, aggressus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agrī: fields; plural masculine nominative from ager, agrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ārdēbant: they were burning; 3rd person plural imperfect active from ārdeō, ārdēre, ārsī, ārsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="barbara: barbarous; singular feminine nominative from barbarus, barbara -um, barbarior -or -us, barbarissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="caelō: heaven, sky; singular masculine ablative from caelus, caelī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolus: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castellum: castle, stronghold; singular neuter accusative from castellum, castellī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castrīs: forts; plural neuter ablative from castrum, castrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cēpit: he took; 3rd person singular perfect active from capiō, capere, cēpī, captus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="coluit: (the people) worshipped; 3rd person singular perfect active from colō, colere, coluī, cultus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="columne: column; singular feminine gentive variant spelling from columna, columnae"/>
