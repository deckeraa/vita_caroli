                <para PARENT="Vocab"/>
                <ITEXT CH="reātūs: accusation, charge; singular masculine genitive from reātus, reātūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgem: king; singular masculine accusative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="regentem: reigning; singular common accusative present participle from regō, regere, rēxī, rēctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgī: king; singular masculine dative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="repperit: 3rd person singular perfect from reperiō, reperīre, repperī, repertus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="salūtiferum: health-bringing; singular neuter accusative from salūtifer, salūtifera, salūtiferum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnum: of the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="scelerum: of crimes; plural neuter genitive from scelus, sceleris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="scēptra: scepters; plural neuter accusative from scēptrum, scēptrī"/>
                <para PARENT="Vocab"/>
