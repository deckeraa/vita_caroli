                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hīc: here"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="igitur: therefore"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipsīus: of itself; singular genitive from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="libellum: little book; singular masculine accusative from libellus, libellī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="līmina: thresholds, doorsteps, houses; plural neuter accusative from līmen, līminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nātālis: birthday; singular common nominative from natalis, natalis, natale"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nātīs: children; plural ablative perfect participle from nāscor, nāscī, nātus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="parvīs: small; plural feminine dative from parvus, parva -um, minor -or -us, minimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="persolvere: to pay, perform; present active infinitive from persolvō, persolvere, persolvī, persolūtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pervēnerat: he had arrived; 3rd person singular pluperfect active from perveniō, pervenīre, pervēnī, perventus"/>
                <para PARENT="Vocab"/>
