                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnia: Saxony"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sē: himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sociāta: sociāta fuit = had been allied; singular feminine nominative perfect passive participle from sociō, sociāre, sociāvī, sociātus"/>
                <para PARENT="Vocab"/>
