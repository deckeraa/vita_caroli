                <ITEXT CH="male: in an evil manner (adverb); adverb from malus, mala -um, peior -or -us, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="manēbat: it was remaining; 3rd person singular imperfect active from maneō, manēre, mānsī, mānsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nimiā: excessive, too much; singular feminine ablative from nimius -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nocērī: to be harmed; passive infinitive from noceō, nocēre, nocuī, nocitus"/>
                <para PARENT="Vocab"/>
