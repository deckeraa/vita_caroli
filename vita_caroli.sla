                <para PARENT="Vocab"/>
                <ITEXT CH="nē: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ob: for, because of, towards"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="omnis: all, every; singular common nominative from omnis, omnis, omne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pervēnit: he arrived; 3rd person singular present active from perveniō, pervenīre, pervēnī, perventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="petīvīt: he asked for; 3rd person singular perfect active from petō, petere, petīvī, petītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populī: people, populace; singular masculine genitive from populus, populī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="posset: it might have been able; 3rd person singular imperfect active subjunctive from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="posuit: he put; 3rd person singular perfect active from pōnō, pōnere, posuī, positus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praesidiō: defence; singular neuter ablative from praesidium, praesidiī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="premeret: he pressed, overwhelmed; 3rd person singular imperfect active subjunctive from premō, premere, pressī, pressus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prīmō: first; singular masculine ablative from prīmus, prīma, prīmum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="properant: they hurry; 3rd person plural present active from properō, properāre, properāvī, properātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quam: how? how much?"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quippe: indeed, surely, the thing is"/>
                <para PARENT="Vocab"/>
