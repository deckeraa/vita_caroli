        <PAGEOBJECT XPOS="136.0008" YPOS="10872.0432" OwnPage="25" ItemID="942854346" PTYPE="4" WIDTH="522" HEIGHT="261" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 261 L0 261 L0 0 Z" copath="M0 0 L522 0 L522 261 L0 261 L0 0 Z" gXpos="136.0008" gYpos="10872.0432" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Et Carolus vīllam, quae Carbōnāta vocātur,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Adveniēns, summōs procerēs omnēsque potentēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Frāternae quondam"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" partīs suscēperat illīc,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Haud retractantēs"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" dominō sē subdere tālī;"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Exceptīs tantum paucīs, quōs"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" forte priōris"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Magnus amor dominī cum coniuge fēcerat eius"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et nātīs remanēre, quibus comitāta petīvit"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ītaliam, spērāns sē dēgere posse quiētam"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sub rēgis Dēsīderiī mūnīmine vītam. "/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="11139.0432" OwnPage="25" ItemID="943543770" PTYPE="4" WIDTH="522" HEIGHT="125.335949044586" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 125.336 L0 125.336 L0 0 Z" copath="M0 0 L522 0 L522 125.336 L0 125.336 L0 0 Z" gXpos="136.0008" gYpos="11139.0432" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And Charlemagne, coming to the villa called Carbōnāta, had received there all the noblemen and powerful (men) formerly of his brother's party."/>
                <ITEXT CH=" After Carloman died, Charlemagne met with Carloman's nobles to bring them to his side; however, a few with Carloman's wife and daughters fled to Italy under King Desiderius, the final Lombard King."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH="For metrical reasons, the first syllable of "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="retractantēs"/>
                <ITEXT CH=" must be long."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Except only a few, to whom perchance a great love of their prior lord had made them to remain with his wife and children, she (Carloman's wife) accompanied with them sought Italy. comitāta"/>
                <ITEXT CH=" must be in the nominative; putting it in the ablative would result in the loss of the dactyl necessary for the meter."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="10872.0432" OwnPage="26" ItemID="946902074" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="10872.0432" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="adveniēns: arriving; singular nominative present participle from adveniō, advenīre, advēnī, adventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="amor: love; 1st person singular present passive from amō, amāre, amāvī, amātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="at: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carbōnāta: the name of a villa in which Charlemagne held a council"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolus: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="comitāta: accompanied, guarded, attended; singular feminine nominative from comitātus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="coniuge: spouse; singular common ablative from conjunx, conjugis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēgere: to spend, carry on; present active infinitive from dēgō, dēgere, dēgī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Dēsīderiī: Desiderius, final King of the Lombards (720-786)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dominī: of (their) lord; singular masculine genitive from dominus, dominī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dominō: (from their) lord; singular masculine ablative from dominus, dominī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eius: his/her/its"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="exceptīs: having been excepted; plural ablative perfect passive participle from excipiō, excipere, excēpī, exceptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēcerat: it had made; 3rd person singular pluperfect active from faciō, facere, fēcī, factus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="forte: by chance"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="frāternae: fraternal; singular feminine genitive from frāternus, frāterna, frāternum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="haud: not, not at all"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīc: there"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ītaliam: Italy (accusative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="māgnus: large; singular masculine nominative from māgnus, māgna -um, major -or -us, maximus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mūnīmine: defence, fortification, rampart; singular neuter ablative from mūnīmen, mūnīminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nātīs: children; plural ablative from nātus, nātī (son) or nāta, nātae (daughter)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="omnēs: all, every; plural common accusative from omnis, omnis, omne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="partis: party, faction, part; singular feminine genitive from pars, partis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="paucīs: few, little; plural masculine ablative from paucus, pauci"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="petīvīt: she sought; 3rd person singular perfect active from petō, petere, petīvī, petītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="posse: to be able; present active infinitive from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="potentēs: mighty (men); plural common accusative from potēns, potentis (gen.), potentior -or -us, potentissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="priōris: previous; singular masculine genitive from prior, prior, prius"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="procerēs: noblemen; plural masculine accusative from procer, proceris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quae: who; singular female nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quibus: with whome; plural ablative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quiētam: quiet; singular feminine accusative from quiētus -am -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quondam: formerly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quōs: whom; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgis: of the king; singular masculine genitive from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="remanēre: to remain; present active infinitive from remaneō, remanēre, remānsī, remānsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="retractantēs: withdrawing; plural common accusative present participle from retractō, retractāre, retractāvī, retractātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sē: themselves"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="spērāns: hoping; singular nominative present participle from spērō, spērāre, spērāvī, spērātus"/>
                <para PARENT="Vocab"/>
