        <PAGEOBJECT XPOS="136.0008" YPOS="18623.0178917198" OwnPage="43" ItemID="988436698" PTYPE="4" WIDTH="522" HEIGHT="138.496815286622" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 138.497 L0 138.497 L0 0 Z" copath="M0 0 L522 0 L522 138.497 L0 138.497 L0 0 Z" gXpos="136.0008" gYpos="18623.0178917198" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And now a great fear of the Franks struck everyone."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Vainly himself hoping to be able to oppose Charlemagne, before a meeting (in battle between Charlemagne and Desiderius) having occurred, he (Charlemagne) routed (Desidarius) in terror and (Desiderius) having been shut up in Ticinum."/>
                <ITEXT CH=" Here "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="clausum"/>
                <ITEXT CH=" is a past passive participle in the accusative which matches "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Dēsīderium"/>
                <ITEXT CH=", also in the accusative. "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Dēsīderium"/>
                <ITEXT CH=" is the object of fugāvit. "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Ticinō"/>
                <ITEXT CH=" is in the ablative of location."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The regal army (of the Franks) having moved up camps everywhere beseiged (Ticinum/Pavia) and with various methods through many exertions trying (to breach the city wall) through the total space of the time of winter, was not able to break the walls of the city with iron."/>
                <ITEXT CH=" However, in June 774 Desiderius succumbed to the seige and surrendered."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="22520.088" OwnPage="53" ItemID="989128330" PTYPE="4" WIDTH="522" HEIGHT="498.599681528662" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 498.6 L0 498.6 L0 0 Z" copath="M0 0 L522 0 L522 498.6 L0 498.6 L0 0 Z" gXpos="136.0008" gYpos="22520.088" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Ob"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" hōc doctōrem tālem fideīque magistrum,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Scīlicet īnsignem Carolum dōnāvit eīsdem,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quī bellō premeret"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=", quōs nōn ratiōne domāret,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sīcque vel invītōs salvārī"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" cōgeret ipsōs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hoc īnspīrātum cordī dīvīnitus eius"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ūtile"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" cōnsilium comitantur strēnua facta."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quippe ducēs omnisque simul dēlēcta iuventūs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ad Duriam vīcum properant: nam rēge iubente"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Illīc conventus populī generālis habētur."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Atque dehinc grandī trānsmissō flūmine Rhēnō,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Saxōnum Carolus fīnēs hostīliter intrat"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ac prīmō Sigiburg castellum coepit, et inde"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ērēsburg petiit, quam captam dīximus"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" urbem."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Sed nē"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" praesidiō Francīs fore posset, eandem"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Indigenē dēstrūxērunt: hanc dēnique rūrsus"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Mūnīvit, posuitque suās illīc legiōnēs;"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Inde gradū celerī Wisuram pervēnit ad amnem."/>
                <trail PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="23024.088" OwnPage="53" ItemID="993024442" PTYPE="4" WIDTH="522" HEIGHT="181.707961783439" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 181.708 L0 181.708 L0 0 Z" copath="M0 0 L522 0 L522 181.708 L0 181.708 L0 0 Z" gXpos="136.0008" gYpos="23024.088" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="From this (reason) (God) gave such a learned man and captain of the faith, indeed the distinguished Charlegmange, to the same (people, the Saxons)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Who would press by war those he (could) not subdue by reason."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And thus the unwilling he would force to be saved themselves."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="This beneficial plan, having been divinely inspired to his heart, strenuous deeds accompany (it)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Which we said was the captured city."/>
                <ITEXT CH=" See page 12 for the initial captue of Eresburg."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="But so that it might not be for the protection of the Franks, the indigenous (people, the Saxons), had destroyed (the fortifications of Eresburg)."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="22520.088" OwnPage="54" ItemID="993644378" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="22520.088" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ac: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="amnem: river; singular masculine accusative from amnis, amnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="atque: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="bellō: battle, war; singular neuter ablative from bellum, bellī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="captam: having been taken; singular feminine accusative perfect passive participle from capiō, capere, cēpī, captus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolum: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolus: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castellum: castle, stronghold; singular neuter nominative from castellum, castellī"/>
