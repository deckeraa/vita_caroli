                <para PARENT="Vocab"/>
                <ITEXT CH="vincere: to conquer; present active infinitive from vincō, vincere, vīcī, victus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="virtūs: virtue, manliness, power; singular feminine nominative from virtūs, virtūtis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="virtūtē: virtue, manliness, power; singular feminine ablative from virtūs, virtūtis"/>
