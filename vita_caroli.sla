                <para PARENT="Vocab"/>
                <ITEXT CH="dēnique: thereupon"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="distat: it stands apart, it is distant; 3rd person singular present active from distō, distāre, -, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eadem: the same, singular feminine nominative or plural neutern nominative or ablative"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ex: out of, from"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gēns: people, clan, nation; singular feminine nominative from gēns, gentis"/>
                <para PARENT="Vocab"/>
