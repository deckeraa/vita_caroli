                <para PARENT="Vocab"/>
                <ITEXT CH="Carolī: Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty (genitive case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="celebrāvit: he celebrated; 3rd person singular perfect active from celebrō, celebrāre, celebrāvī, celebrātus"/>
