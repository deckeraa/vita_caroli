        <PAGEOBJECT XPOS="136.0008" YPOS="25848.1008" OwnPage="61" ItemID="1003947306" PTYPE="4" WIDTH="522" HEIGHT="474.437815286623" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 474.438 L0 474.438 L0 0 Z" copath="M0 0 L522 0 L522 474.438 L0 474.438 L0 0 Z" gXpos="136.0008" gYpos="25848.1008" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Sīc introgressī Francōrum castra dolōsī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quod vī nōn poterant, ēgērunt arte; sed ōlim"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Est dictum 'Dolus an virtūs, quis in hoste requīrat?'"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dēpressōs somnō Francōs īnstanter adortī"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Saxonēs, caedem nimiam fēcēre ferōcēs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dōnec discussō"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" tandem torpōre sopōris,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quīdam"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" correptīs obstāre virīliter armīs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Coepērunt, pugnāque dehinc"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" utcunque remōtā,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Scīlicet ex pactō, quod tunc angustia tālis"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dictābat, hostēs celerī rediēre recursū."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hīs rēx audītīs illūc properāre satēgīt"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=","/>
                <para PARENT="Latin"/>
                <ITEXT CH="Atque satis vēlōx fugientum terga secūtus,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Prōstrāvit multōs auctōrēs crīminis huius."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hinc ad Westfalhōs vēnit, statimque receptīs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Obsidibus, quōs trādiderant, abscesserat inde."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ac suscēpit ovāns"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT CH=" redeuntem Francia rēgem."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="26322.5386152866" OwnPage="61" ItemID="1004296698" PTYPE="4" WIDTH="522" HEIGHT="228.277254777098" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 228.277 L0 228.277 L0 0 Z" copath="M0 0 L522 0 L522 228.277 L0 228.277 L0 0 Z" gXpos="136.0008" gYpos="26322.5386152866" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Trickery or virtue, who would ask (regarding these) in an enemy?"/>
                <ITEXT CH=" This is a quote for Virgil's Aeneid, Book 2, line 390. This question is asked rhetorically by Coroebus, a Trojan, during the sack of Troy when he suggests that he and a small band of other Trojans defending Troy (including Aeneas) disguise themselves as Greek soldiers."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The Saxons instantly attacked the Franks, suppressed with sleep and the ferocious (Saxons) made a very great slaughter."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Until the numbness of sleep was finally dissipated."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Certain (Frankish soldiers), having manfully taken hold of weapons, began to oppose (the Saxons)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit" CH="And with the battle somehow withdrawn, really by agreement, that then such a tight situation dictated, the (Saxon) enemies returned (to their villages) with rapid return."/>
                <ITEXT FONT="DejaVu Serif Book" FEATURES="inherit" CH=" It appears that after the Franks woke up and started fighting back that the Saxons had to flee."/>
                <ITEXT CH=" Perhaps the Franks and Saxons made a truce; however I think it likelier that "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="scīlicet ex pactō"/>
                <ITEXT CH=" refers to the Saxon attacker noticing their now-dire situation and deciding together to flee rather than continue fighting."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Having heard these (things), the king hastened to hurry and the sufficiently fast (king) followed the backs of the fleeing (Saxons), and struck down many perpetrators of this crime."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And the rejoicing Franks received their returning king."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="25848.1008" OwnPage="62" ItemID="1006765866" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="25848.1008" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="abscesserat: he had left; 3rd person singular pluperfect active from abscēdō, abscēdere, abscessī, abscessus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ac: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="adortī: adortī sunt = they attacked, sunt omitted for metrical reasons; singular masculine genitive perfect participle from adorior, adoriri, adortus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="an: or? rather?"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="angustia: 'tight situation', small space, narrow passage, being boxed in; singular feminine nominative from angustia, angustiae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="armīs: weapons; plural neuter ablative from armum, armī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="arte: art, skill; singular feminine ablative from ars, artis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="atque: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="auctōrēs: perpetrators, creators, authors; plural common accusative from auctor, auctōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="audītīs: having been heard; plural ablative past passive participle from audiō, audīre, audīvī, audītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="caedem: slaughter; singular feminine accusative from caedēs, caedis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castra: garrisons, forts, encampments; plural neuter accusative from castrum, castrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="celerī: quick; singular ablative from celer, celeris -e, celerior -or -us, celerrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="coepērunt: they started; 3rd person plural perfect from coepī, coepisse, coepī, coeptum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="correptīs: having been grasped; plural ablative perfect passive participle from corripiō, corripere, corripuī, correptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="crīminis: crimes; singular neuter genitive from crīmen, crīminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dehinc: from now on, from this place"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēpressōs: having been suppressed; plural masculine accusative perfect passive participle from dēprimō, dēprimere, dēpressī, dēpressus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dictābat: it dictated; 3rd person singular imperfect active from dictō, dictāre, dictāvī, dictātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dictum: dictum est = it was said; singular neuter nominative perfect passive participle from dīcō, dīcere, dīxī, dictus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="discussō: having been dissapated, shattered; singular masculine ablative perfect passive participle from discutiō, discutere, discussī, discussus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dolōsī: crafty, cunning; plural masculine nominative from dolōsus, dolōsa, dolōsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dolus: trickery, deception; singular masculine nominative from dolus, dolī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dōnec: while, as long as, until"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ēgērunt: they did, conducted, acted; 3rd person plural perfect active from agō, agere, ēgī, āctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="est: he is; 3rd person singular present active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ex: out of, from"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēcēre: they did, made; 3rd person plural perfect active from faciō, facere, fēcī, factus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ferōcēs: wild, bold, defiant; plural common nominative from ferōx, (gen.), ferōcis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francia: the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōs: the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fugientum: fleeing; plural genitive present participle from fugiō, fugere, fūgī, fugitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hinc: from here"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hīs: these; plural masculine ablative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hoste: enemy; singular common ablative from hostis, hostis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hostēs: enemies; plural common nominative from hostis, hostis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="huius: of this; singular genitive of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illūc: over there"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="inde: from there, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnstanter: instantly, violently (adverb)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="intrōgressī: intrōgressī sunt = they entered, sunt omitted for metrical reasons; plural masculine nominative perfect participle from intrōgredior, intrōgredī, intrōgressus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="multōs: many; plural masculine accusative from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nimiam: too much; singular feminine accusative from nimius, nimia, nimium"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obsidibus: hostages; plural common ablative from obses, obsidis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obstāre: to oppose; active infinitive from obstō, obstāre, obstitī, obstātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ōlim: one day, once upon a time"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ovāns: rejoicing; singular nominative present participle from ovō, ovāre, ovāvī, ovātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pāctō: agreement, bargain; singular neuter ablative from pactum, pactī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="poterant: they were able to; 3rd person plural imperfect active from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="properāre: to hurry; present active infinitive from properō, properāre, properāvī, properātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prostrāvit: he struck down; 3rd person singular perfect active from prosternō, prosternere, prostrāvī, prostrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pugnā: fight; singular feminine ablative from pugna, pugnae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quīdam: certain (men); plural masculine nominative from quīdam"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quis: who"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quod: what; singular neuter accusative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quōs: who; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="receptīs: having been received; plural ablative perfect passive participle from recipiō, recipere, recēpī, receptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="recursū: return, running back; singular neuter ablative from recurro, recurrere, recucurri, recursus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="redeuntem: returning; singular common accusative present participle from redeō, redīre, redivī(iī), reditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rediēre: they returned; 3rd person plural perfect from redeō, redīre, redivī(iī), reditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgem: king; singular masculine accusative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="remōtā: having been removed; singular feminine ablative perfect passive participle from removeō, removēre, remōvī, remōtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="requīrat: he requires, asks for; 3rd person singular present active subjunctive from requīrō, requīrere, requīsīvī, requīsītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="satēgit: he was busy, hard pressed; 3rd person singular perfect active from satagō, satagere, satēgī, satāctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="satis: enough"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxonēs: the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="scīlicet: namely, really"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="secūtus: secūtus + est = he followed, est omitted for metrical reasons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sīc: thus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="somnō: sleep; singular masculine ablative from somnus, somnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sopōrīs: of sleep; singular masculine genitive from sopor, sopōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="statim: immediately"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suscēpit: he undertook, he supported; 3rd person singular perfect active from suscipiō, suscipere, suscēpī, susceptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tālis: such; singular common nominative from tālis, tālis, tāle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tandem: finally"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="terga: backs; plural neuter accusative from tergum, tergī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="torpore: numbness, stupefaction; singular masculine ablative from torpor, torpōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trādiderant: they had handed over; 3rd person plural pluperfect active from trādō, trādere, trādidī, trāditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tunc: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="utcunque: as soon as, by any means"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēlōx: quick; singular nominative from vēlōx, vēlōcis (gen.), vēlōcior -or -us, vēlōcissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēnit: he came; 3rd person singular present active from veniō, venīre, vēnī, ventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vī: strength; singular feminine ablative from vīs, vīs,"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="virīliter: strongly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="virtūs: virtue, manliness, power; singular feminine nominative from virtūs, virtūtis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Westfalhōs: Westphalians, members of a Saxon tribe"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="25016.0976" OwnPage="59" ItemID="1007272298" PTYPE="4" WIDTH="522" HEIGHT="263.023802547767" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 263.024 L0 263.024 L0 0 Z" copath="M0 0 L522 0 L522 263.024 L0 263.024 L0 0 Z" gXpos="136.0008" gYpos="25016.0976" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Tunc ut equīs quīdam"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" dēferrent pābula longē,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dē castrīs prius"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" ēgressī pariter rediērunt."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hīs sē Saxonum quoddam"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" permiscuit agmen,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Fingentum"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" sēmet sociōs animōque fidēlēs."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Tum sē quisque"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" novō blandē sociābat amīcō,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hostis quō saevus latuit sub nōmine tēctus."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Adhibitumque fidem verbīs fallācibus auget"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Obsequium; cūnctī simul in commūne labōrant,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Pars"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" subvectat onus viridis simul utraque foenī."/>
                <trail PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="25286.1214025478" OwnPage="59" ItemID="1008126666" PTYPE="4" WIDTH="522" HEIGHT="149.840764331184" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 149.841 L0 149.841 L0 0 Z" copath="M0 0 L522 0 L522 149.841 L0 149.841 L0 0 Z" gXpos="136.0008" gYpos="25286.1214025478" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Then so that certain (men) might carry fodder from afar for the horses."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Having gone out previously from camp, they returned together."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="A certain Saxon band joined itself with these."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Feigning to be friends and faithful in spirit."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="While each one talked to his 'friend' with new flatteries, in which the savage enemy lay concealed under (a false) name."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And having been invited their obsequiousness increased (the) faith (that the Franks had in the Saxons) with lying words."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="7"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Everyone together labored in common, and together each part shouldered the green burden of hay."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="25016.0976" OwnPage="60" ItemID="1011816266" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="25016.0976" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="adhibitum: having been invited, summoned; singular neuter nominative perfect passive participle from adhibeō, adhibēre, adhibuī, adhibitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agmen: band, troop; singular neuter nominative from agmen, agminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="amīcō: friend; singular masculine ablative from amicus, amica -um, amicior -or -us, amicissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="animō: soul, mind, live; singular masculine ablative from animus, animi"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="auget: it increases; 3rd person singular present active from augeō, augēre, auxī, auctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="blandē: flatteringly; adverb from blandus, blanda -um, blandior -or -us, blandissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castrīs: forts; plural neuter ablative from castrum, castrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="commūne: jointly, together; singular neuter accusative from commūne, commūnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cūnctī: all, whole; plural masculine nominative from cūnctus, cūncta, cūnctum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dē: of, from, away from, down from"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēferrent: they transferred; 3rd person plural imperfect active subjunctive from dēferō, dēferre, dētulī, dēlātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ēgressī: having gone out; genitive singular perfect passive participle from ēgredior, ēgredī, ēgressum (deponent)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="equīs: horses; plural masculine ablative from equus, equī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fallācibus: deceitful, misleading; plural ablative from fallāx, fallācis (gen.), fallācior -or -us, fallācissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fidēlēs: faithful persons, confidants; plural common nominative from fidelis, fidele, fidelior -or -us, fidelissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fidem: faith; singular feminine accusative from fidēs, fideī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fingentum: feigning; alternative spelling of gerund from fingō, fingere, fīnxī, fictus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="foenī: of hay; singular neuter genitive from foenum, foenī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hīs: with these; plural masculine  ablative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hostis: enemy; singular common nominative from hostis, hostis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="labōrant: they labor; 3rd person plural present active from labōrō, labōrāre, labōrāvī, labōrātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="latuit: it lay hidden, it lurked; 3rd person singular perfect active from lateō, latēre, latuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="longē: long; adverb from longus, longa -um, longior -or -us, longissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōmine: name; singular neuter ablative from nōmen, nōminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="novō: new; singular masculine ablative from novus, nova -um, novior -or -us, novissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obsequium: allegiance, obedience; singular neuter nominative from obsequium, obsequiī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="onus: burden; singular neuter accusative from onus, oneris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pābula: food, nourishment; plural neuter accusative from pābulum, pābulī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pariter: equally, together"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pars: part; singular feminine nominative from pars, partis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="permiscuit: it mixed, joined, mingled; 3rd person singular perfect active from permisceo, permiscere, permiscui, permixtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prius: before"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quīdam: certain (men); plural masculine nominative from quīdam"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quis: who"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quō: what; singular ablative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quoddam: certain; singular neuter nominative of quīdam"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rediērunt: they returned; 3rd person plural perfect active from redeō, redīre, redivī(iī), reditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="saevus: furious; singular masculine nominative from saevus, saeva -um, saevior -or -us, saevissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnum: Saxon, neuter adjective that modifies agmen"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sē: himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simul: at the same time as"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sociābat: he was allying, socializing; 3rd person singular imperfect active from sociō, sociāre, sociāvī, sociātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sociōs: associates, companions; plural masculine accusative from socius, soci(ī)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sub: below, under"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subvectat: it conveys; 3rd person singular present active from subvectō, subvectāre, subvectāvī, subvectātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tēctus: concealed; singular masculine nominative perfect passive participle from tegō, tegere, tēxī, tēctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tum: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tunc: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ut: so that"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="utra: either; singular feminine nominative from uter, utra, utrum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="verbīs: words; plural neuter ablative from verbum, verbī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="viridis: green; singular common accusative from viridis, viridis, viride"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="26680.104" OwnPage="63" ItemID="1012074890" PTYPE="4" WIDTH="522" HEIGHT="262.813980891715" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 262.814 L0 262.814 L0 0 Z" copath="M0 0 L522 0 L522 262.814 L0 262.814 L0 0 Z" gXpos="136.0008" gYpos="26680.104" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Annō 776"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cumque domum rediēns prīnceps iter accelerāret,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Comperit"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" Ausoniīs in partibus esse tirannum,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nōmine Hrodgaudum, nova quī mōlīmina"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" temptāns,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nec, quem"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" rēx illī dederat, contentus honōre,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ītaliae lātum voluit sibi subdere rēgnum."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quippe"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" ducem comitemque Forōiulēnsibus ipsum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cōnstituit Carolus, prīmō cum clāra"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" triumphō"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Dē Langōbardīs victor vēxilla"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" revēxit."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="26948.9179808917" OwnPage="63" ItemID="1012519418" PTYPE="4" WIDTH="522" HEIGHT="134.828025477709" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 134.828 L0 134.828 L0 0 Z" copath="M0 0 L522 0 L522 134.828 L0 134.828 L0 0 Z" gXpos="136.0008" gYpos="26948.9179808917" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="He discovered, in parts of Ausonia/Italy, (there) to be a tyrant, named Hrodgaudum."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Who, trying new endeavours."/>
                <ITEXT CH=" The new endeavours were military operations Hrodgaudum undertook to try to conquer more of Italy."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Neither content with the honor which the king (Charlemagne) had given him."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Indeed, Charlemagne had made he himself (Hrodgaudum) duke and count of the Friulian."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH="At first glance, "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="clāra"/>
                <ITEXT CH=" appears to modify "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="triumphō"/>
                <ITEXT CH=". However, "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="clāra"/>
                <ITEXT CH=" cannot be in the ablative since its last syllable must be short to fit the meter. Also, "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="triumphō"/>
                <ITEXT CH=" is masculine. Therefore, "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="clāra"/>
                <ITEXT CH=" must be plural neuter accusative and modify "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="vēxilla"/>
                <ITEXT CH=" in the next line."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="He (Charlemagne), the victor, carried back the flags of the Lombards."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
