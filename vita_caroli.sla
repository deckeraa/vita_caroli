        <PAGEOBJECT XPOS="136.0008" YPOS="43064.7006980892" OwnPage="101" ItemID="1115384042" PTYPE="4" WIDTH="522" HEIGHT="111.146496815287" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 111.146 L0 111.146 L0 0 Z" copath="M0 0 L522 0 L522 111.146 L0 111.146 L0 0 Z" gXpos="136.0008" gYpos="43064.7006980892" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
