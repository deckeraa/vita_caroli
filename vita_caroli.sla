        <PAGEOBJECT XPOS="136.0008" YPOS="36664.1424" OwnPage="87" ItemID="1057307274" PTYPE="4" WIDTH="522" HEIGHT="230.828936305723" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 230.829 L0 230.829 L0 0 Z" copath="M0 0 L522 0 L522 230.829 L0 230.829 L0 0 Z" gXpos="136.0008" gYpos="36664.1424" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Cūnctās quās poterant vīllās invādere, flammīs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Trādiderant. Ipsīs etiam nōn īra pepercit"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ecclesiīs"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=", nec erat hominum caedis modus ūllus."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nōn aliquod sexūs, aetātis, condiciōnis"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ūllīus furor immītis"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" discrīmen agēbat;"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Omnia sed ferrum vel edāx cōnsūmpserat"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" ignis."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hinc nōn praedandī studiō"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=", sed ut ultio"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" quaedam"/>
                <para PARENT="Latin"/>
                <ITEXT CH="In Francōs fieret, hoc eōs gessisse probātur."/>
                <trail PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="36899.888533758" OwnPage="87" ItemID="1057560778" PTYPE="4" WIDTH="522" HEIGHT="106.853503184677" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 106.854 L0 106.854 L0 0 Z" copath="M0 0 L522 0 L522 106.854 L0 106.854 L0 0 Z" gXpos="136.0008" gYpos="36899.888533758" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH="Spelled "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Aecclesiis"/>
                <ITEXT CH=" in the critical text. The second syllable is short for it to fit the meter; the line scans as DDDSDS."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="The cruel furor made no distinction, not of sex or age or any other condition."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="But the sword or greedy fire had consumed all."/>
                <para PARENT="footnotes"/>
                <ITEXT FONT="DejaVu Serif Italic" FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Hence not out of eagerness of plundering, but in order that a certain vengeance might occur against the Franks, it is proved that they had done this."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH="Normally spelled "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="ultiō"/>
                <ITEXT CH="; the Saxon poet appears to use it with a short final syllable."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="36664.1424" OwnPage="88" ItemID="1060014250" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="36664.1424" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="aetātis: of age; singular feminine genitive from aetās, aetātis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="agēbat: it carried out; 3rd person singular imperfect active from agō, agere, ēgī, āctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aliquod: anyone; neuter singular nominative or accusative from aliqui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="caedis: of slaughter; singular feminine genitive from caedis, caedis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="condiciōnis: condition; singular feminine genitive from condiciō, condiciōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnsūmpserat: it had consumed; 3rd person singular pluperfect active from cōnsūmō, cōnsūmere, cōnsūmpsī, cōnsūmptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cūnctās: all, whole; plural feminine accusative from cūnctus, cūncta, cūnctum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="discrīmen: distinction, division; singular neuter nominative from discrīmen, discrīminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ecclēsiīs: churches; plural feminine dative from ecclēsia, ecclēsiae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="edāx: greedy, gluttonous, voracious, destructive; singular  nominative from edāx, edācis (gen.), edācior -or -us, edācissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eōs: to them; plural masculine accusative from is, ea, id"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="erat: he was; 3rd person singular imperfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="etiam: still"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ferrum: iron; singular neuter nominative from ferrum, ferrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fieret: it might happen; 3rd person singular imperfect active subjunctive from fīō, fierī, factus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="flammīs: flames; plural feminine dative from flamma, flammae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōs: the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="furor: frenzy, rage, madness; singular masculine nominative from furor, furōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gessisse: to have born, carried; perfect active infinitive from gerō, gerere, gessī, gestus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hinc: hence, from here"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hoc: this; singular neuter accusative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hominum: of persons, of men; plural masculine genitive from homō, hominis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īgnis: fire; singular masculine nominative from īgnis, īgnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="immītis: savage, cruel; singular common nominative from immītis, immīte, immītior -or -us, immītissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="invādere: to invade; present active infinitive from invādō, invādere, invāsī, invāsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipsīs: itself; plural dative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īra: anger; singular feminine nominative from īra, īrae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="modus: limit; singular masculine nominative from modus, modī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nec: nor, not either"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōn: not"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="omnia: all, every; plural neuter accusative from omnis, omnis, omne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pepercit: it spared, saved; 3rd person singular perfect active from parcō, parcere, pepercī, parsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="poterant: they were able to; 3rd person plural imperfect active from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praedandī: of pillaging; genitive gerund from praedor, praedārī, praedātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="probātur: it is shown, proved; 3rd person singular present passive from probō, probāre, probāvī, probātus"/>
                <para PARENT="Vocab"/>
