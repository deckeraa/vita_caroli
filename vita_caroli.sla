        <PAGEOBJECT XPOS="136.0008" YPOS="13368.0528" OwnPage="31" ItemID="947081434" PTYPE="4" WIDTH="522" HEIGHT="291.091280254777" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 291.091 L0 291.091 L0 0 Z" copath="M0 0 L522 0 L522 291.091 L0 291.091 L0 0 Z" gXpos="136.0008" gYpos="13368.0528" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Dēnique Westfalos vocitant in parte manentēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Occiduā, quōrum nōn longē terminus amne"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ā Rhēnō distat; regiōnem sōlis ad ortum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Inhabitābant Osterliudī, quōs nōmine quīdam"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ostvalos aliō vocitant, cōnfīnia"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" quōrum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Īnfestant coniūncta suīs gēns perfida Sclāvī."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Inter praedictōs mediā regiōne morantur"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Angariī, populus Saxonum tertius; hōrum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Patria Francōrum terrīs sotiātur ab austrō,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ōceanōque"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" eadem coniungitur ex aquilōne."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="13665.1440802548" OwnPage="31" ItemID="947623066" PTYPE="4" WIDTH="522" HEIGHT="65.9999999999973" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 66 L0 66 L0 0 Z" copath="M0 0 L522 0 L522 66 L0 66 L0 0 Z" gXpos="136.0008" gYpos="13665.1440802548" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Thereupon they call (them) Westphalians in the part remaining to the west, whose border lies not far from the Rhine river."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Whose boundaries the Slavs, a perfidious people joined to them, makes dangerous."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH="For scansion: elision occurs here, so "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="que"/>
                <ITEXT CH=" + "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="ea"/>
                <ITEXT CH=" becomes one long syllable."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="13368.0528" OwnPage="32" ItemID="949582602" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="13368.0528" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ā: from, out of, by, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ab: from, out of, by, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ad: to, towards, at, according to"/>
