                <para PARENT="Vocab"/>
                <ITEXT CH="Rōmae: of Rome; singular feminine genitive from Rōma, Rōmae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sāncta: holy, saint"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēcum: with himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="semper: always"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sōlātia: comfort, relief, solace; plural neuter accusative from solatium, solatiī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sōlus: alone; singular masculine nominative from sōlus, sōla, sōlum (gen -ius)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="statuī: I decided; 1st person singular perfect from statuō, statuere, statuī, statūtus"/>
