                <para PARENT="Vocab"/>
                <ITEXT CH="longē: afar; (adverb)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="manentēs: remaining; plural common nominative present participle from maneō, manēre, mānsī, mānsus"/>
                <para PARENT="Vocab"/>
