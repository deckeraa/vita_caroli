                <ITEXT CH="nīmīrum: certainly"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nōmina: names; plural neuter nominative from nōmen, nōminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nunc: now"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ōlim: one day, once upon a time"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="omnis: all, every; singular common nominative from omnis, omnis, omne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="orbem: world; singular masculine accusative from orbis, orbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="paene: almost"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pāgōs: district, region; plural masculine accusative from pāgus, pāgī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pariter: together"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="per: through"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plēbs: common people; singular feminine nominative from plēbs, plēbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populīs: people, populace; plural masculine dative from populus, populī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populōs: peoples, populaces; plural masculine accusative from populus, populī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="poterant: they were able to; 3rd person plural imperfect active from possum, posse, potuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="precipuē: especially, chiefly; variant spelling from praecipuē (adverb)"/>
                <para PARENT="Vocab"/>
