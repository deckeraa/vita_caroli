                <para PARENT="Vocab"/>
                <ITEXT CH="prīma: first; singular feminine nominative from prīmus, prīma, prīmum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Pyrēneī: of the Pyrenee mountains"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quāsdam: certain; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quī: who; plural masculine nominative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quod: which; singular neuter accusative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quōs: whom; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rebellis: rebellious; singular common nominative from rebellis, rebellis, rebelle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="recessit: he withdrew; 3rd person singular perfect active from recēdō, recēdere, recessī, recessus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rediēns: returning; singular nominative present participle from redeō, redīre, redivī(iī), reditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Sarrācēnī: of the Saracen (muslim)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sē: himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sibi: to himself; singular dative of sē"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sīc: thus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="spērāret: he had hoped; 3rd person singular imperfect active subjunctive from spērō, spērāre, spērāvī, spērātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sua: his; plural neuter accusative from suus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="subdere: to place under; present active infinitive from subdō, subdere, subdidī, subditus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="superāvisset: he (might) have overcome; 3rd person singular pluperfect active subjunctive from superō, superāre, superāvī, superātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tamen: however"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="terram: land"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="terrīs: lands; plural feminine ablative from terra, terrae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trāiciēns: transferring, transporting, passing through; singular nominative present participle from trāiciō, trāicere, trāiēcī, trāiectus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbem: city; singular feminine accusative from urbs, urbis"/>
                <para PARENT="Vocab"/>
