                <ITEXT CH="dōnō: gift; singular neuter ablative or dative from dōnum, dōnī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ērēsburg: a Saxon refuge castle near modern-day Obermarsberg"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="et: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ex: out of, from"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="expugnātam: fighting; singular feminine accusative gerund from expugnō, expugnāre, expugnāvī, expugnātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="expulsum: having been driven out; singular neuter nominative perfect passive participle from expuls.um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fāma: report, news, rumor; singular feminine nominative from fāma, fāmae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fēcit: he did; 3rd person singular perfect active from faciō, facere, fēcī, factus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fore: to be; future active infinitive from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Francōrum: of the Franks"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fuit: it was; 3rd person singular perfect active from sum, esse, fuī, futūrus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hōs: these; plural masculine accusative from hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="huic: to this; singular dative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illī: that; singular dative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="illīs: those; plural dative or ablative from ille, illa, illud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="inde: from there, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ingrātus: ungrateful, unpleasant; singular masculine nominative from ingrātus, ingrāta, ingrātum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="interitū: death, ruin; singular neuter ablative from intereo, interire, interivi(ii), interitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ipse: himself; singular masculine nominative from ipse, ipsa, ipsum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Ītaliam: Italy (accusative case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iuga: peaks (of a mountain); plural neuter accusative from iugum, iugī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iussit: he commanded; 3rd person singular perfect from iubeō, iubēre, iussī, iussus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iussū: order, command, decree; singular neuter ablative from iubeō, iubēre, iussī, iussus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="iūstō: iust, righteous; singular masculine ablative from iūstus, iūsta -um, iūstior -or -us, iūstissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="locābat: he stationed; 3rd person singular imperfect active from locō, locāre, locāvī, locātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="male: in an evil manner; adverb from malus, mala -um, peior -or -us, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mandāverat: he had entrusted; 3rd person singular pluperfect active from mandō, mandāre, mandāvī, mandātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="meritō: merited; singular masculine ablative perfect passive participle from mereō, merēre, meruī, meritus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mīlitibus: soldiers; plural masculine ablative from mīles, mīlitis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="morātus: mōrātus est = he stayed, dwelled, delayed, est omitted for metrical reasons; singular masculine nominative perfect participle from moror, morārī, morātus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="mōtūs: rebellions, tumults, movements; plural masculine accusative from mōtus, mōtūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="multīs: many; plural ablative from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nil: not at all"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nimis: too much, extremely"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nivium: of snow; plural feminine genitive from nix, nivis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="obvia: in the path"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ōlim: one day, once upon a time"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plēctēns: punishing; singular nominative present participle from plēctō, plēctere"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populōs: peoples, populaces; plural masculine accusative from populus, populī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praesidium: garrison; singular neuter nominative from praesidium, praesidiī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="properāns: hurrying; singular nominative present participle from properō, properāre, properāvī, properātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="proxima: nearest; plural neuter accusative from proximus, proxima, proximum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quam: very"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quibus: with whom; plural dative or ablative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quōs: whom; plural masculine accusative of quis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="raptim: quickly, hastily"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="receptās: having been recovered; plural feminine accusative perfect passive participle from recipiō, recipere, recēpī, receptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="recessit: he withdrew; 3rd person singular perfect active from recēdō, recēdere, recessī, recessus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="referēns: reporting; singular nominative present participle from referō, referre, rettulī, relātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxonēs: the Saxons"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sē: himself"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="servāre: to watch over, to guard, to preserve, to save; present active infinitive from servō, servāre, servāvī, servātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sīc: thus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sollicitābat: he was stirring up, agitating; 3rd person singular imperfect active from sollicitō, sollicitāre, sollicitāvī, sollicitātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sprētō: having been scorned, despised; singular masculine ablative perfect passive participle from spernō, spernere, sprēvī, sprētus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="strēnua: brisk, vigorous; plural feminine accusative from strēnuus, strēnua, strēnuum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suis: their; plural dative or ablative of suus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suum: his; singular masculine accusative from suus, sui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trānsgressō: having crossed over; singular masculine ablative perfect participle from transgredior, transgredi, transgressus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="trīstis: sad; singular common nominative from trīstis, trīstis, trīste"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tuendam: protecting, looking after; singular feminine accusative gerund from tueor, tuērī, tuitus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tyrannum: tyrant; singular masculine accusative from tyrannus, tyrannī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbem: city; singular feminine accusative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbēs: cities; plural feminine accuative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbibus: cities; plural feminine ablative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ut: so that"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēlōx: quick; singular nominative from vēlōx, vēlōcis (gen.), vēlōcior -or -us, vēlōcissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēnit: he came; 3rd person singular present active from veniō, venīre, vēnī, ventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="violenter: violently"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vix: barely"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vocat: he calls; 3rd person singular present active from vocō, vocāre, vocāvī, vocātus"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="28344.1104" OwnPage="67" ItemID="1017904378" PTYPE="4" WIDTH="522" HEIGHT="412.107343949046" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 412.107 L0 412.107 L0 0 Z" copath="M0 0 L522 0 L522 412.107 L0 412.107 L0 0 Z" gXpos="136.0008" gYpos="28344.1104" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Tum Sigiburg"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" aliud multō cōnāmine castrum"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Oppugnāre quidem studuit, nec vincere quīvit"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Gēns eadem, cupiēns ab eā rēgis legiōnēs"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Pellere; sed pugnae populus Saxōnicus īnstāns,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ā tergō circumventus"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" fuit atque fugātus,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Interius positīs"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=" simul ērumpentibus, atque"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Incautōs"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" plāgā facile sternentibus amplā."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Hic rūmor Carolī cum prīmum vēnit ad aurēs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Conventum procerum fierī praecoepit in urbe"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Wormaciā, statuitque morās innectere"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" nūllās,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quīn"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" lueret tantī sceleris gēns perfida poenās."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ergo suīs exercitibus rēx undique lectīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cōnātūs"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT CH=" celer hostīlēs praevertitur omnēs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Temptāvēre quibus prīmō dēfendere sēsē."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="28756.217743949" OwnPage="67" ItemID="1018419594" PTYPE="4" WIDTH="522" HEIGHT="157.757961783485" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 157.758 L0 157.758 L0 0 Z" copath="M0 0 L522 0 L522 157.758 L0 157.758 L0 0 Z" gXpos="136.0008" gYpos="28756.217743949" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Then the same people (the Saxons) hastened to attack another castle, Sigiburg (Castle), with a great attempt, but were not able to prevail."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="They (the Saxon people) were surrounded from behind and put to flight."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Those (Frankish soldiers) placed (within Sigiburg castle) at the same time sallied forth (from the castle to attack the fleeing Saxons)."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Striking down easily the unguarded (Saxons who were fleeing) with a great blow."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="He decided to contrive no delays."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="So that the treacherous people (the Saxons) might pay the penalties for such a crime."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Therefore the swift king, with his chosen armies from all around, pre-empted the hostile enemy attacks, with which they had tried at first to defend themselves."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="766.0008" YPOS="28344.1104" OwnPage="68" ItemID="1022088234" PTYPE="4" WIDTH="522" HEIGHT="720" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="2" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 720 L0 720 L0 0 Z" copath="M0 0 L522 0 L522 720 L0 720 L0 0 Z" gXpos="766.0008" gYpos="28344.1104" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="ā: from, out of, by, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ab: from, out of, by, since"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ad: to, towards, at, according to"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aliud: another; singular neuter accusative from alius, alia, aliud"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="amplā: large; singular feminine ablative from amplus, ampla -um, amplior -or -us, amplissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="atque: and"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="aurēs: ears; plural feminine accusative from auris, auris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Carolī: of Charlemagne, AD 748-814, King of the Franks and Emperor of the Western Roman Empire, member of the Carolingian Dynasty (genitive case)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="castrum: fort, castle; singular neuter accusataive from castrum, castrī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="celer: quick; singular masculine nominative from celer, celeris, celere"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="circumventus: circumventus fuit = they had been surrounded; singular masculine nominative perfect passive participle from circumveniō, circumvenīre, circumvēnī, circumventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praecoepit: he ordered started; 3rd person singular perfect active variant spelling from praecipiō, praecipere, praecēpī, praeceptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnāmine: effort, struggle; singular neuter ablative from cōnāmen, cōnāminis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cōnātūs: efforts; plural masculine accusative from cōnātus, cōnātūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="conventum: meeting, convention; singular masculine accusative from conventus, conventūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cum: with"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="cupiēns: desiring; singular nominative present participle from cupiō, cupere, cupīvī, cupītus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="dēfendere: to defend; active infinitive from dēfendō, dēfendere, dēfendī, dēfēnsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eā: it; singular feminine ablative from is, ea, id"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="eadem: the same, singular feminine nominative frorm īdem, eadem, idem"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ergo: therefore"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="ērumpentibus: breaking out, erupting; plural ablative present participle from ērumpō, ērumpere, ērūpī, ēruptus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="exercitibus: armies; plural masculine ablative from exercitus, exercitūs"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="facile: easily; adverb from facilis, facile, facilior -or -us, facillimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fierī: to happen, to occur; active infinitive from fīō, fierī, factus sum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="fugātus: having been routed, chased away; singular masculine nominative perfect passive participle from fugō, fugāre, fugāvī, fugātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="gēns: people, clan, nation; singular feminine nominative from gēns, gentis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hic: this; singular masculine nominative of hic, haec, hoc"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="hostīlēs: enemies; plural common accusative from hostīlis, hostīlis, hostīle"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="in: into (with accusative), in (with ablative)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="incautōs: off one's guard, unprotected, incautious; plural masculine accusative from incautus, incauta -um, incautior -or -us, incautissimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="innectere: to tie, fasten; active infinitive from innectō, innectere, innexuī, innexus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="īnstāns: pressing forward; singular nominative present participle from īnstō, īnstāre, īnstitī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="interius: interiorly, inside; adverb from interior, interior, interius"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="lectīs: chosen; plural ablative perfect passive participle from legō, legere, lēgī, lēctus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="legiōnēs: legions; plural feminine accusative from legiō, legiōnis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="lueret: they might pay, expiate; 3rd person singular imperfect active subjunctive from luō, luere, luī, lutus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="morās: delays; plural feminine accusative from mora, morae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="multō: great, many; singular masculine ablative from multus, multa -um, -, plūrimus -a -um"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nec: nor, not either"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="nūllās: no, none, not any; plural feminine accusative from nūllus, nūlla, nūllum (gen -ius)"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="omnēs: all, every; plural common accusative from omnis, omnis, omne"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="oppūgnāre: to attack; active infinitive from oppūgnō, oppūgnāre, oppūgnāvī, oppūgnātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pellere: to drive away; active infinitive from pellō, pellere, pepulī, pulsus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="perfida: treacherous, deceitful; singular feminine nominative from perfidus, perfida, perfidum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="plāgā: strike, blow; singular feminine ablative from plāga, plāgae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="poenās: penalties, punishments; plural feminine accusative from poena, poenae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="populus: people, populace; singular masculine nominative from populus, populī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="positīs: having been placed; plural ablative perfect passive participle from pōnō, pōnere, posuī, positus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="praevertitur: he pre-empted, anticipated; 3rd person singular present passive from praeverto, praevertere, praeverti, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prīmō: first; singular masculine ablative from prīmus, prīma, prīmum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="prīmum: first; singular neuter nominative from prīmus, prīma, prīmum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="procerum: of noblemen; plural masculine genitive from procer, proceris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="pugnae: to the battle; singular feminine dative from pugna, pugnae"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quibus: with which; plural ablative of qui"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quidem: indeed, at last"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quīn: even, in fact"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="quīvit: they (the Saxon people) were able; 3rd person singular perfect active from queō, quīre, quivī, quitus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēgis: of the king; singular masculine genitive from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rēx: king; singular masculine nominative from rēx, rēgis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="rūmor: rumor; singular masculine nominative from rūmor, rūmōris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Saxōnicus: Saxon"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sceleris: crime; singular neuter genitive from scelus, sceleris"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sed: but"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sēsē: themselves"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Sigiburg: A Saxon hillfort in Western Germany"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="simul: at the same time as"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="statuit: he decided; 3rd person singular present active from statuō, statuere, statuī, statūtus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="sternentibus: striking down, spreading, laying out; plural ablative present participle from sternō, sternere, strāvī, strātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="studuit: they (the Saxon people) hastened; 3rd person singular perfect active from studeō, studēre, studuī, -"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="suīs: his; plural ablative of suus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tantī: such, so much, so great, this many; singular masculine genitive from tantus, tanta, tantum"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="temptavere: they tried, attempted; 3rd person plural perfect active from temptō, temptāre, temptāvī, temptātus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tergō: back; singular neuter ablative from tergum, tergī"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="tum: then"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="undique: from all sides"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="urbe: city; singular feminine ablative from urbs, urbis"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vēnit: he came; 3rd person singular present active from veniō, venīre, vēnī, ventus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="vincere: to conquer; active infinitive from vincō, vincere, vīcī, victus"/>
                <para PARENT="Vocab"/>
                <ITEXT CH="Wormaciā: Worms, a city in Germany; singular feminine ablative from Wormacia, Wormaciae"/>
                <trail PARENT="Vocab"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="29176.1136" OwnPage="69" ItemID="1022483882" PTYPE="4" WIDTH="522" HEIGHT="469.785872611457" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 469.786 L0 469.786 L0 0 Z" copath="M0 0 L522 0 L522 469.786 L0 469.786 L0 0 Z" gXpos="136.0008" gYpos="29176.1136" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Nam fontēs adiēns, ubi Lyppia nāscitur amnis,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Repperit ex ipsā numerōsās gente catervās"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Illīc collēctās, humilēs veniamque precantēs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Quod nōn servāssent"/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT CH=" annō prōmissa priōrī."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Cum vērō Carolus clēmēns ignōsceret"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT CH=" illīs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Complūrēs"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT CH=", Dominō sē Chrīstō crēdere velle"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Spondentēs simulācrōrumque relinquere cultūs,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Pūrgārī"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT CH=" iussit sacrī baptismatis undā,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Servandaeque"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT CH=" iterum fideī prōmissa recēpit"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Obsidibus firmāta datīs, quibus ipse volēbat."/>
                <para PARENT="Latin"/>
                <ITEXT CH="Ēresburg iterum firmat mūnīmine fortī,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Et iuxtā fluvium quem Lyppia dīximus ante"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Castellum condēns"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT CH=" aliud, complēvit utrumque"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Mīlitibus lectīs; tum Gallica rūrsus ad arva"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Regrediēns, hiemis tempus trānsēgit in aulā,"/>
                <para PARENT="Latin"/>
                <ITEXT CH="Nōmen"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT CH=" Heristallī dederat cui barbara lingua."/>
                <para PARENT="Latin"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="29650.8994726115" OwnPage="69" ItemID="1022914330" PTYPE="4" WIDTH="522" HEIGHT="228.32218343949" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L522 0 L522 228.322 L0 228.322 L0 0 Z" copath="M0 0 L522 0 L522 228.322 L0 228.322 L0 0 Z" gXpos="136.0008" gYpos="29650.8994726115" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FEATURES="inherit superscript" CH="1"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Because they hadn't kept the promises of the prior year."/>
                <ITEXT CH=" After Charlemagne put down some of the Saxon rebellions, a group of Saxons gathered to ask for clemency, which Charlemagne granted."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="2"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="When clement Charlemagne forgave them."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Ignōscere"/>
                <ITEXT CH=" takes the dative instead of the accusative (hence "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="illīs"/>
                <ITEXT CH="); the subjunctive is used because it is in a "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="cum"/>
                <ITEXT CH=" circumstantial clause."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="3"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="Many (persons), promising themselves to want to believe in the Lord Christ and to relinguish the cult/worship of idols."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="4"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="He (Charlemagne) ordered to be purged/cleansed by the wave/waters of sacred baptism."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="5"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="He received promises of keeping faith again, confirmed with hostages being given, which he (Charlemagne) himself had wanted."/>
                <ITEXT CH=" In Jaffé's critical text "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="servandeque"/>
                <ITEXT CH=", not "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="servandaeque"/>
                <ITEXT CH=", is given. The dictionaries I consulted all listed "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="servande"/>
                <ITEXT CH=" as being in the vocative, which doesn't fit the context. Additionally, the third syllable must be long for to fit the meter, thus leaving three possibilities: (1) "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="servandeque"/>
                <ITEXT CH=" represents an uncommon spelling or convention of which I am unaware, (2) it should read "/>
                <ITEXT FONT="DejaVu Serif Condensed Italic" CH="servandōque"/>
                <ITEXT CH=", making it an ablative gerund, or (3) the "/>
                <ITEXT FONT="DejaVu Serif Italic" CH="a"/>
                <ITEXT CH=" was dropped due to a misprint."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="6"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="And next to the river, which we above called Lyppia, building another castle, he filled both with chosen soldiers."/>
                <para PARENT="footnotes"/>
                <ITEXT FEATURES="inherit superscript" CH="7"/>
                <ITEXT FONT="DejaVu Serif Italic" CH="To which the barbarian tongue had given the name Herstal."/>
                <trail PARENT="footnotes"/>
            </StoryText>
        </PAGEOBJECT>
